@{
    ViewData["Title"] = "Acceso Denegado";
}

<div class="access-denied-container">
    <div class="access-denied-card">
        <div class="denied-header">
            <div class="denied-icon">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <h1 class="denied-title">Acceso Denegado</h1>
        </div>
        
        <div class="denied-content">
            <div class="denied-message">
                <h2 class="message-title">No tienes permisos para acceder a esta página</h2>
                <p class="message-description">
                    La página que intentas acceder requiere permisos especiales que tu cuenta actual no posee.
                </p>
                
                <div class="action-buttons">
                    <a href="@Url.Action("Home", "Clients")" class="btn btn-primary">
                        <i class="fas fa-home me-2"></i>
                        Ir al Inicio
                    </a>
                    <a href="@Url.Action("Logout", "Account")" class="btn btn-secondary">
                        <i class="fas fa-sign-out-alt me-2"></i>
                        Cerrar Sesión
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body { 
        background: var(--us-surface) !important; 
        color: var(--us-ink) !important; 
        font-family: var(--us-font) !important; 
        margin: 0; 
        padding: 0; 
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .access-denied-container {
        width: 100%;
        max-width: 600px;
        margin: 0 auto;
        padding: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
    }

    .access-denied-card {
        background: linear-gradient(135deg, var(--us-surface-alt), var(--us-surface-2));
        border: 1px solid var(--us-border);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        width: 100%;
        animation: slideInUp 0.6s ease-out;
    }

    .denied-header {
        background: linear-gradient(135deg, #c8102e, #a30d25);
        text-align: center;
        padding: 3rem 2rem 2rem;
        position: relative;
    }

    .denied-icon {
        font-size: 4rem;
        color: var(--us-ink);
        margin-bottom: 1rem;
        animation: bounceIn 0.8s ease-out 0.2s both;
    }

    .denied-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--us-ink);
        margin: 0;
        text-shadow: 0 2px 10px rgba(0, 0, 0, 0.2);
    }

    .denied-content {
        padding: 2.5rem;
    }

    .denied-message {
        text-align: center;
        animation: fadeInUp 0.6s ease-out 0.4s both;
    }

    .message-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: #c8102e;
        margin-bottom: 1rem;
    }

    .message-description {
        font-size: 1.1rem;
        color: var(--us-ink-soft);
        line-height: 1.6;
        margin-bottom: 2rem;
        max-width: 400px;
        margin-left: auto;
        margin-right: auto;
    }

    .action-buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-top: 2.5rem;
        animation: fadeInUp 0.6s ease-out 0.8s both;
    }

    .btn {
        padding: 12px 24px;
        border-radius: 25px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        font-size: 1rem;
        min-width: 160px;
    }

    .btn-primary {
        background: linear-gradient(135deg, #c8102e, #a30d25);
        color: #ffffff;
        box-shadow: 0 4px 15px rgba(200, 16, 46, 0.3);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(200, 16, 46, 0.4);
        color: #ffffff;
    }

    .btn-secondary {
        background: transparent;
        color: var(--us-ink-soft);
        border: 1px solid var(--us-border);
    }

    .btn-secondary:hover {
        background: var(--us-surface-alt);
        color: var(--us-ink);
        border-color: #c8102e;
        transform: translateY(-2px);
    }

    @@keyframes slideInUp {
        from {
            opacity: 0;
            transform: translateY(50px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes bounceIn {
        0% {
            transform: scale(0);
            opacity: 0;
        }
        50% {
            transform: scale(1.1);
            opacity: 1;
        }
        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    header, footer { display: none !important; }
    
    .fas { 
        font-family: "Font Awesome 5 Free" !important; 
        font-weight: 900 !important; 
    }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
