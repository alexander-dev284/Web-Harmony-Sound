@{
    ViewData["Title"] = "Pago Exitoso";
}

<div class="payment-success-container">
    <div class="payment-success-card">
        <div class="success-header">
            <div class="success-icon">
                <i class="fas fa-check-circle"></i>
            </div>
            <h1 class="success-title">¡Pago Exitoso!</h1>
        </div>
        
        <div class="success-content">
            <div class="success-message">
                <h2 class="activation-title">Tu suscripción ha sido activada</h2>
                <p class="success-description">
                    ¡Felicidades! Ahora puedes disfrutar de todas las características premium de UniSound.
                </p>
                
                <div class="premium-features">
                    <h3 class="features-title">Ahora tienes acceso a:</h3>
                    <div class="features-grid">
                        <div class="feature-item">
                            <i class="fas fa-check feature-check"></i>
                            <span>Sin anuncios</span>
                        </div>
                        <div class="feature-item">
                            <i class="fas fa-check feature-check"></i>
                            <span>Audio HD</span>
                        </div>
                        <div class="feature-item">
                            <i class="fas fa-check feature-check"></i>
                            <span>Soporte prioritario</span>
                        </div>
                    </div>
                </div>
                
                <!--  Información de duración y expiración -->
                <div class="subscription-details">
                    <div class="detail-item">
                        <i class="fas fa-calendar-alt"></i>
                        <span>Duración: 30 días</span>
                    </div>
                    <div class="detail-item">
                        <i class="fas fa-clock"></i>
                        <span>Expira: @DateTime.Now.AddDays(30).ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="detail-item">
                        <i class="fas fa-sync-alt"></i>
                        <span>Renovación automática activada</span>
                    </div>
                </div>
                
                <div class="action-buttons">
                    <a href="@Url.Action("Index", "Plans")" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-2"></i>
                        Volver a Planes
                    </a>
                    <a href="@Url.Action("Home", "Clients")" class="btn btn-primary">
                        <i class="fas fa-music me-2"></i>
                        Explorar Música
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* CSS Base - Mantener consistencia con la app */
    body { 
        background: var(--us-surface) !important; 
        color: var(--us-ink) !important; 
        font-family: var(--us-font) !important; 
        margin: 0; 
        padding: 0; 
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Contenedor principal */
    .payment-success-container {
        width: 100%;
        max-width: 600px;
        margin: 0 auto;
        padding: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
    }

    /* Tarjeta de éxito */
    .payment-success-card {
        background: linear-gradient(135deg, var(--us-surface-alt), var(--us-surface-2));
        border: 1px solid var(--us-border);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        width: 100%;
        animation: slideInUp 0.6s ease-out;
    }

    /* Header con ícono de éxito */
    .success-header {
        background: linear-gradient(135deg, #c8102e, #a30d25);
        text-align: center;
        padding: 3rem 2rem 2rem;
        position: relative;
    }

    .success-icon {
        font-size: 4rem;
        color: var(--us-ink);
        margin-bottom: 1rem;
        animation: bounceIn 0.8s ease-out 0.2s both;
    }

    .success-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--us-ink);
        margin: 0;
        text-shadow: 0 2px 10px rgba(0, 0, 0, 0.2);
    }

    /* Contenido principal */
    .success-content {
        padding: 2.5rem;
    }

    .success-message {
        text-align: center;
        animation: fadeInUp 0.6s ease-out 0.4s both;
    }

    .activation-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: #c8102e;
        margin-bottom: 1rem;
    }

    .success-description {
        font-size: 1.1rem;
        color: var(--us-ink-soft);
        line-height: 1.6;
        margin-bottom: 2rem;
        max-width: 400px;
        margin-left: auto;
        margin-right: auto;
    }

    /* Características premium */
    .premium-features {
        background: var(--us-surface-alt);
        border: 1px solid var(--us-border);
        border-radius: 15px;
        padding: 2rem;
        margin: 2rem 0;
        animation: fadeInUp 0.6s ease-out 0.6s both;
    }

    .features-title {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--us-ink);
        margin-bottom: 1.5rem;
        text-align: center;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
    }

    .feature-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem;
        background: var(--us-surface);
        border-radius: 10px;
        border: 1px solid var(--us-surface-2);
        transition: all 0.3s ease;
    }

    .feature-item:hover {
        border-color: #c8102e;
        transform: translateY(-2px);
    }

    .feature-check {
        color: #c8102e;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .feature-item span {
        color: var(--us-ink);
        font-weight: 500;
        font-size: 0.95rem;
    }

    /* Detalles de la suscripción */
    .subscription-details {
        background: var(--us-surface-alt);
        border: 1px solid var(--us-border);
        border-radius: 15px;
        padding: 1.5rem;
        margin: 2rem 0;
        animation: fadeInUp 0.6s ease-out 0.6s both;
    }

    .detail-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 0;
        border-bottom: 1px solid var(--us-surface-2);
    }

    .detail-item:last-child {
        border-bottom: none;
    }

    /* Botones de acción */
    .action-buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-top: 2.5rem;
        animation: fadeInUp 0.6s ease-out 0.8s both;
    }

    .btn {
        padding: 12px 24px;
        border-radius: 25px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        font-size: 1rem;
        min-width: 160px;
    }

    .btn-primary {
        background: linear-gradient(135deg, #c8102e, #a30d25);
        color: #ffffff;
        box-shadow: 0 4px 15px rgba(200, 16, 46, 0.3);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(200, 16, 46, 0.4);
        color: #ffffff;
    }

    .btn-secondary {
        background: transparent;
        color: var(--us-ink-soft);
        border: 1px solid var(--us-border);
    }

    .btn-secondary:hover {
        background: var(--us-surface-alt);
        color: var(--us-ink);
        border-color: #c8102e;
        transform: translateY(-2px);
    }

    /* Animaciones */
    @@keyframes slideInUp {
        from {
            opacity: 0;
            transform: translateY(50px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes bounceIn {
        0% {
            transform: scale(0);
            opacity: 0;
        }
        50% {
            transform: scale(1.1);
            opacity: 1;
        }
        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }


    /* Ocultar elementos del layout si es necesario */
    header, footer { display: none !important; }
    
    /* FontAwesome */
    .fas { 
        font-family: "Font Awesome 5 Free" !important; 
        font-weight: 900 !important; 
    }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">