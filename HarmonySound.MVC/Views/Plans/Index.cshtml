        color: #000;
        padding: 1.5rem;
        text-align: center;
    }

    .current-plan-header h3 {
        margin: 0;
        font-weight: 600;
        font-size: 1.5rem;
    }

    .current-plan-body {
        padding: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .current-plan-info h4 {
        color: #fff;
        margin-bottom: 0.5rem;
        font-size: 1.5rem;
    }

    .current-plan-info p {
        color: #b3b3b3;
        margin-bottom: 1rem;
    }

    .current-plan-price {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
    }

    .current-plan-price .price-amount {
        font-size: 2rem;
        font-weight: 700;
        color: #1db954;
    }

    .current-plan-price .price-period {
        color: #b3b3b3;
        font-size: 1rem;
    }

    .btn-cancel {
        background: transparent;
        border: 2px solid #dc3545;
        color: #dc3545;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .btn-cancel:hover {
        background: #dc3545;
        color: #fff;
        transform: translateY(-2px);
    }

    /* ✅ NUEVO: Estilos del Modal de Cancelación */
    .cancel-modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.85);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10000;
        backdrop-filter: blur(8px);
        animation: fadeIn 0.3s ease-out;
    }

    .cancel-modal-overlay.d-none {
        display: none !important;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    .cancel-modal-container {
        background: linear-gradient(135deg, #1a1a1a, #2a2a2a);
        border: 1px solid #444;
        border-radius: 20px;
        padding: 0;
        max-width: 520px;
        width: 90%;
        box-shadow: 0 25px 80px rgba(0, 0, 0, 0.7);
        overflow: hidden;
        animation: modalSlideIn 0.4s ease-out;
        position: relative;
    }

    @@keyframes modalSlideIn {
        from {
            opacity: 0;
            transform: translateY(-30px) scale(0.95);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .cancel-modal-header {
        background: linear-gradient(135deg, #ff6b6b, #ff5252);
        padding: 2rem;
        text-align: center;
        color: #fff;
        position: relative;
    }

    .cancel-modal-icon {
        font-size: 3.5rem;
        margin-bottom: 1rem;
        opacity: 0.9;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0%, 100% {
            transform: scale(1);
        }
        50% {
            transform: scale(1.05);
        }
    }

    .cancel-modal-title {
        font-size: 1.8rem;
        font-weight: 700;
        margin: 0;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    }

    .cancel-modal-body {
        padding: 2rem;
    }

    .cancel-modal-message {
        font-size: 1.2rem;
        color: #fff;
        margin-bottom: 2rem;
        line-height: 1.6;
        text-align: center;
    }

    .cancel-modal-warning {
        background: rgba(255, 193, 7, 0.1);
        border: 1px solid rgba(255, 193, 7, 0.3);
        border-radius: 12px;
        padding: 1.5rem;
        display: flex;
        gap: 1rem;
        align-items: flex-start;
        color: #ffc107;
    }

    .cancel-modal-warning i {
        font-size: 1.5rem;
        margin-top: 0.2rem;
        flex-shrink: 0;
    }

    .warning-title {
        font-weight: 700;
        margin-bottom: 0.75rem;
        font-size: 1.1rem;
        color: #ffc107;
    }

    .warning-list {
        margin: 0;
        padding-left: 1.5rem;
        color: #e0e0e0;
    }

    .warning-list li {
        margin-bottom: 0.5rem;
        line-height: 1.4;
    }

    .cancel-modal-actions {
        padding: 2rem;
        display: flex;
        gap: 1rem;
        justify-content: center;
        background: rgba(0, 0, 0, 0.2);
    }

    .btn-modal {
        padding: 12px 28px;
        border-radius: 25px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        border: none;
        font-size: 1rem;
        display: inline-flex;
        align-items: center;
        min-width: 180px;
        justify-content: center;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .btn-keep {
        background: linear-gradient(135deg, #1db954, #1ed760);
        color: #000;
        box-shadow: 0 4px 15px rgba(29, 185, 84, 0.3);
    }

    .btn-keep:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(29, 185, 84, 0.4);
        background: linear-gradient(135deg, #1ed760, #22c55e);
    }

    .btn-confirm-cancel {
        background: linear-gradient(135deg, #dc3545, #c82333);
        color: #fff;
        box-shadow: 0 4px 15px rgba(220, 53, 69, 0.3);
    }

    .btn-confirm-cancel:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(220, 53, 69, 0.4);
        background: linear-gradient(135deg, #c82333, #a71e2a);
    }

    /* Grid de Planes - mantener estilos existentes */
    .plans-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 2rem;
    }

    .plan-card {
        background: linear-gradient(135deg, #1a1a1a, #2a2a2a);
        border: 2px solid #333;
        border-radius: 12px;
        overflow: hidden;
        transition: all 0.3s ease;
        position: relative;
    }

    .plan-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);
        border-color: #1db954;
    }

    .plan-card.active-plan {
        border-color: #1db954;
        box-shadow: 0 8px 25px rgba(29, 185, 84, 0.3);
    }

    .plan-header {
        padding: 2rem;
        text-align: center;
        border-bottom: 1px solid #333;
    }

    .plan-name {
        font-size: 1.5rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 0.5rem;
    }

    .plan-description {
        color: #b3b3b3;
        margin: 0;
        font-size: 0.95rem;
    }

    .plan-features {
        padding: 2rem;
        flex-grow: 1;
    }

    .features-list {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .feature-item {
        display: flex;
        align-items: center;
        padding: 0.75rem 0;
        color: #fff;
        font-weight: 500;
    }

    .feature-item:not(:last-child) {
        border-bottom: 1px solid #333;
    }

    .plan-footer {
        padding: 2rem;
        text-align: center;
        border-top: 1px solid #333;
    }

    .plan-price {
        margin-bottom: 1.5rem;
        display: flex;
        align-items: baseline;
        justify-content: center;
        gap: 0.5rem;
    }

    .plan-price .price-amount {
        font-size: 2.5rem;
        font-weight: 700;
        color: #1db954;
    }

    .plan-price .price-period {
        color: #b3b3b3;
        font-size: 1rem;
    }

    .btn {
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        border: none;
        width: 100%;
        font-size: 1rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

    .btn-subscribe {
        background: linear-gradient(135deg, #1db954, #1ed760);
        color: #000;
        box-shadow: 0 4px 15px rgba(29, 185, 84, 0.3);
    }

    .btn-subscribe:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(29, 185, 84, 0.4);
        color: #000;
    }

    .btn-active {
        background: #28a745;
        color: #fff;
        cursor: not-allowed;
        opacity: 0.8;
    }

    .subscription-form {
        width: 100%;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .plans-container {
            padding: 1rem;
        }

        .plans-title {
            font-size: 2rem;
        }

        .plans-grid {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }

        .current-plan-body {
            flex-direction: column;
            gap: 1.5rem;
            text-align: center;
        }

        .plan-header {
            padding: 1.5rem;
        }

        .plan-features {
            padding: 1.5rem;
        }

        .plan-footer {
            padding: 1.5rem;
        }

        .cancel-modal-container {
            width: 95%;
            margin: 1rem;
        }

        .cancel-modal-actions {
            flex-direction: column;
        }

        .btn-modal {
            width: 100%;
        }

        .cancel-modal-header {
            padding: 1.5rem;
        }

        .cancel-modal-body {
            padding: 1.5rem;
        }

        .cancel-modal-icon {
            font-size: 3rem;
        }

        .cancel-modal-title {
            font-size: 1.5rem;
        }
    }

    /* Ocultar elementos del layout principal */
    header, footer {
        display: none !important;
    }

    /* FontAwesome */
    .fas, .fab {
        font-family: "Font Awesome 5 Free" !important;
        font-weight: 900 !important;
    }

    .fab {
        font-family: "Font Awesome 5 Brands" !important;
        font-weight: 400 !important;
    }
</style>

<!-- FontAwesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const subscriptionForms = document.querySelectorAll('.subscription-form');
        
        subscriptionForms.forEach(form => {
            form.addEventListener('submit', function(e) {
                const button = this.querySelector('.btn-subscribe');
                
                // Mostrar loading
                button.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Procesando...';
                button.disabled = true;
                
                // Crear y mostrar modal de carga
                showPaymentModal();
            });
        });
        
        function showPaymentModal() {
            const modalHtml = `
                <div class="modal fade" id="paymentModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content" style="background: #1a1a1a; border: 1px solid #333;">
                            <div class="modal-body text-center p-4">
                                <div class="spinner-border text-primary mb-3" role="status">
                                    <span class="visually-hidden">Cargando...</span>
                                </div>
                                <h5 style="color: #fff;">Procesando pago...</h5>
                                <p style="color: #b3b3b3;">Serás redirigido a PayPal para completar el pago.</p>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            
            document.body.insertAdjacentHTML('beforeend', modalHtml);
            const modal = new bootstrap.Modal(document.getElementById('paymentModal'));
            modal.show();
        }
    });

    // ✅ NUEVAS FUNCIONES: Modal de cancelación personalizado
    function showCancelModal(planName) {
        document.getElementById('planToCancel').textContent = planName;
        document.getElementById('cancelModal').classList.remove('d-none');
        
        // Prevenir scroll del body
        document.body.style.overflow = 'hidden';
    }

    function hideCancelModal() {
        document.getElementById('cancelModal').classList.add('d-none');
        
        // Restaurar scroll del body
        document.body.style.overflow = 'auto';
    }

    function confirmCancelSubscription() {
        // Mostrar loading en el botón
        const confirmBtn = document.querySelector('.btn-confirm-cancel');
        const originalContent = confirmBtn.innerHTML;
        confirmBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Cancelando...';
        confirmBtn.disabled = true;
        
        // Simular delay para mejor UX
        setTimeout(() => {
            document.getElementById('cancelForm').submit();
        }, 1000);
    }

    // Cerrar modal al hacer click fuera
    document.addEventListener('click', function(e) {
        const modal = document.getElementById('cancelModal');
        if (e.target === modal) {
            hideCancelModal();
        }
    });

    // Cerrar modal con Escape
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            hideCancelModal();
        }
    });
</script>
