@model HarmonySound.MVC.Models.LoginViewModel

@{
    ViewBag.Title = "Iniciar sesión";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Iniciar sesión - UniSound</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link rel="stylesheet" href="~/css/dark-theme.css" />
</head>
<body class="us-app auth-page">
    <div class="auth-shell">
        <div class="auth-card us-card">
            <div class="auth-brand">
                <span class="auth-logo"><i class="fas fa-music"></i></span>
                <span class="auth-wordmark">Uni<span class="accent">Sound</span></span>
            </div>

            <h1 class="auth-title">Iniciar sesión</h1>
            <p class="auth-subtitle">Bienvenido de vuelta a UniSound</p>

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                @if (TempData["Success"] != null)
                {
                    <div class="us-alert us-alert-success">
                        <i class="fas fa-check-circle"></i>
                        @TempData["Success"]
                    </div>
                }

                @Html.ValidationSummary(true, "", new { @class = "us-alert us-alert-error validation-summary" })

                <div class="form-field">
                    @Html.LabelFor(m => m.Email, "Correo electrónico", new { @class = "us-label" })
                    <div class="us-input-group">
                        <span class="us-input-icon"><i class="fas fa-envelope"></i></span>
                        @Html.TextBoxFor(m => m.Email, new { @placeholder = "tu@utn.edu.ec", @class = "us-input" })
                    </div>
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "field-error" })
                </div>

                <div class="form-field">
                    @Html.LabelFor(m => m.Password, "Contraseña", new { @class = "us-label" })
                    <div class="us-input-group">
                        <span class="us-input-icon"><i class="fas fa-lock"></i></span>
                        @Html.PasswordFor(m => m.Password, new { @placeholder = "••••••••", @class = "us-input" })
                    </div>
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "field-error" })
                </div>

                <button type="submit" class="us-btn us-btn-primary us-btn-block">
                    <i class="fas fa-sign-in-alt"></i>
                    Iniciar sesión
                </button>

                <div class="auth-links">
                    <p>¿No tienes una cuenta? <a href="@Url.Action("Register", "Account")">Regístrate aquí</a></p>
                    <p>
                        <a class="forgot-link" href="@Url.Action("ForgotPassword", "Account")">
                            <i class="fas fa-key"></i> ¿Olvidaste tu contraseña?
                        </a>
                    </p>
                </div>
            }
        </div>
    </div>

    <style>
        .auth-page {
            min-height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background:
                radial-gradient(1200px 500px at 50% -10%, var(--us-surface-alt) 0%, transparent 60%),
                var(--us-bg);
            padding: 2rem 1rem;
        }

        .auth-shell { width: 100%; max-width: 440px; }

        .auth-card {
            padding: 2.75rem 2.25rem;
            text-align: center;
            box-shadow: var(--us-shadow-lg);
        }

        .auth-brand {
            display: inline-flex;
            align-items: center;
            gap: 0.65rem;
            margin-bottom: 1.75rem;
        }

        .auth-logo {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            background: var(--us-accent);
            color: #ffffff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.15rem;
            box-shadow: var(--us-shadow-sm);
        }

        .auth-wordmark {
            font-size: 1.4rem;
            font-weight: 800;
            letter-spacing: -0.02em;
            color: var(--us-ink);
        }
        .auth-wordmark .accent { color: var(--us-accent); }

        .auth-title {
            font-size: 1.75rem;
            font-weight: 800;
            margin: 0 0 0.35rem;
        }
        .auth-subtitle {
            color: var(--us-ink-soft);
            margin: 0 0 2rem;
            font-size: 0.98rem;
        }

        .form-field { text-align: left; margin-bottom: 1.25rem; }

        .us-btn-block { margin-top: 0.5rem; }

        .field-error { display: block; color: var(--us-accent); font-size: 0.85rem; margin-top: 0.4rem; }
        .validation-summary ul { margin: 0; padding-left: 1.1rem; }
        .validation-summary { text-align: left; }

        .auth-links { margin-top: 1.75rem; font-size: 0.95rem; color: var(--us-ink-soft); }
        .auth-links p { margin: 0.4rem 0; }
        .auth-links a { color: var(--us-accent); font-weight: 600; text-decoration: none; }
        .auth-links a:hover { color: var(--us-accent-hover); text-decoration: underline; }
        .forgot-link { color: var(--us-ink-soft) !important; }
        .forgot-link:hover { color: var(--us-accent) !important; }
    </style>
</body>
</html>
