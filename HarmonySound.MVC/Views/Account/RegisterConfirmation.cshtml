@{
    ViewBag.Title = "Confirma tu email";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <title>Confirm your email - HarmonySound</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        body {
            background: linear-gradient(135deg, #000000, #1a1a1a) !important;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        .auth-container {
            width: 100%;
            max-width: 500px;
            padding: 2rem;
        }

        .auth-card {
            background: linear-gradient(135deg, #1e1e1e, #2d2d2d);
            border: 1px solid #404040;
            border-radius: 16px;
            padding: 3rem 2rem;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6);
            color: #ffffff !important;
            text-align: center;
        }

        .auth-card h2 {
            color: #1db954 !important;
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
            background: linear-gradient(135deg, #1db954, #1ed760);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .auth-card p {
            color: #e0e0e0 !important;
            font-size: 1.1rem;
            line-height: 1.6;
            margin-bottom: 2rem;
        }

        .btn-primary {
            background: linear-gradient(135deg, #1db954, #1ed760) !important;
            border: none !important;
            color: #000000 !important;
            font-weight: 600;
            padding: 12px 24px;
            border-radius: 25px;
            font-size: 1rem;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(29, 185, 84, 0.3);
        }

        .btn-primary:hover {
            background: linear-gradient(135deg, #1ed760, #22c55e) !important;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(29, 185, 84, 0.4);
            color: #000000 !important;
        }

        .btn-primary:focus,
        .btn-primary:active {
            background: linear-gradient(135deg, #1db954, #1ed760) !important;
            color: #000000 !important;
            box-shadow: 0 0 0 0.2rem rgba(29, 185, 84, 0.5) !important;
        }

        /* Animación de entrada */
        .auth-card {
            animation: slideInUp 0.6s ease-out;
        }

        @@keyframes slideInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Responsive */
        @@media (max-width: 576px) {
            .auth-container {
                padding: 1rem;
            }

            .auth-card {
                padding: 2rem 1.5rem;
            }

            .auth-card h2 {
                font-size: 1.75rem;
            }

            .auth-card p {
                font-size: 1rem;
            }
        }
    </style>
</head>

<body>
    <div class="auth-container">
        <div class="auth-card text-center">
            <h2>Check your email</h2>
            <p>
                Enviamos un enlace para verificar tu correo.<br />
                Por favor verifica tu correo para activar tu cuenta.
            </p>
            <a href="@Url.Action("Login", "Account")" class="btn btn-primary mt-3">Volver al inicio de sesión</a>
        </div>
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
