@model HarmonySound.MVC.Models.AdminLoginViewModel

@{
    ViewData["Title"] = "Acceso Administrativo";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HarmonySound</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
</head>
<body>
    <div class="admin-login-container">
        <div class="admin-login-card">
            <div class="admin-header">
                <div class="admin-icon">
                    <i class="fas fa-shield-alt"></i>
                </div>
                <h1>Acceso Administrativo</h1>
                <p>Panel de Control HarmonySound</p>
            </div>

            <div asp-validation-summary="All" class="alert-error-box" id="validationAlert"></div>

            <form asp-action="AdminLogin" method="post" class="admin-form">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label asp-for="Email" class="form-label">
                        <i class="fas fa-envelope"></i>
                        @Html.DisplayNameFor(m => m.Email)
                    </label>
                    <input asp-for="Email" class="form-control" placeholder="admin@harmonysound.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password" class="form-label">
                        <i class="fas fa-lock"></i>
                        @Html.DisplayNameFor(m => m.Password)
                    </label>
                    <input asp-for="Password" class="form-control" placeholder="••••••••" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>

                <button type="submit" class="btn-admin-login">
                    <i class="fas fa-sign-in-alt"></i>
                    Acceder al Panel
                </button>
            </form>

            <div class="security-notice">
                <i class="fas fa-info-circle"></i>
                Se enviará un código de verificación a tu email
            </div>
        </div>
    </div>

    <style>
        *, *::before, *::after {
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #334155 100%);
            color: #fff;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            margin: 0;
            padding: 1rem;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .admin-login-container {
            width: 100%;
            max-width: 420px;
        }

        .admin-login-card {
            background: linear-gradient(135deg, #1e293b, #2d3f55);
            border: 1.5px solid rgba(239, 68, 68, 0.6);
            border-radius: 20px;
            padding: 2.5rem 2.25rem;
            box-shadow: 0 25px 60px rgba(0, 0, 0, 0.5), 0 0 40px rgba(239, 68, 68, 0.15);
        }

        .admin-header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .admin-icon {
            width: 76px;
            height: 76px;
            background: linear-gradient(135deg, #ef4444, #b91c1c);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.25rem;
            font-size: 1.9rem;
            color: #fff;
            box-shadow: 0 8px 20px rgba(239, 68, 68, 0.4);
        }

        .admin-header h1 {
            font-size: 1.6rem;
            font-weight: 700;
            margin: 0 0 0.4rem;
            color: #ef4444;
            letter-spacing: -0.5px;
        }

        .admin-header p {
            color: #94a3b8;
            margin: 0;
            font-size: 0.95rem;
        }

        /* Alert de error */
        .alert-error-box {
            display: none;
            background: rgba(239, 68, 68, 0.12);
            border: 1px solid rgba(239, 68, 68, 0.45);
            border-radius: 10px;
            padding: 0.9rem 1.1rem;
            margin-bottom: 1.5rem;
            color: #fca5a5;
            font-size: 0.9rem;
            line-height: 1.5;
        }

        .alert-error-box.validation-summary-errors {
            display: flex;
            align-items: flex-start;
            gap: 0.6rem;
        }

        .alert-error-box .alert-icon {
            flex-shrink: 0;
            font-size: 1rem;
            margin-top: 0.1rem;
            color: #f87171;
        }

        .alert-error-box ul {
            margin: 0;
            padding: 0;
            list-style: none;
        }

        .alert-error-box li {
            margin: 0;
            padding: 0;
        }

        .admin-form {
            text-align: left;
        }

        .form-group {
            margin-bottom: 1.4rem;
        }

        .form-label {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 0.5rem;
            color: #e2e8f0;
            font-weight: 600;
            font-size: 0.9rem;
        }

        .form-label i {
            color: #ef4444;
            font-size: 0.85rem;
            width: 14px;
        }

        .form-control {
            width: 100%;
            padding: 11px 15px;
            background: rgba(255, 255, 255, 0.07);
            border: 1px solid #475569;
            border-radius: 9px;
            color: #f1f5f9;
            font-size: 0.97rem;
            transition: border-color 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
        }

        .form-control:focus {
            background: rgba(255, 255, 255, 0.11);
            border-color: #ef4444;
            box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.2);
            outline: none;
        }

        .form-control::placeholder {
            color: #64748b;
        }

        .field-error {
            display: block;
            color: #f87171;
            font-size: 0.82rem;
            margin-top: 0.35rem;
        }

        .btn-admin-login {
            width: 100%;
            background: linear-gradient(135deg, #ef4444, #b91c1c);
            color: #fff;
            padding: 12px 24px;
            border: none;
            border-radius: 25px;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            font-size: 1rem;
            margin-top: 0.5rem;
            margin-bottom: 1.25rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.6rem;
            letter-spacing: 0.3px;
        }

        .btn-admin-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(239, 68, 68, 0.45);
        }

        .btn-admin-login:active {
            transform: translateY(0);
        }

        .security-notice {
            background: rgba(239, 68, 68, 0.08);
            color: #fca5a5;
            padding: 0.75rem 1rem;
            border-radius: 8px;
            font-size: 0.85rem;
            border: 1px solid rgba(239, 68, 68, 0.25);
            display: flex;
            align-items: center;
            gap: 0.6rem;
            text-align: left;
        }

        .security-notice i {
            flex-shrink: 0;
            font-size: 0.9rem;
        }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var alertBox = document.getElementById('validationAlert');
            if (alertBox && alertBox.classList.contains('validation-summary-errors')) {
                var icon = document.createElement('i');
                icon.className = 'fas fa-exclamation-circle alert-icon';
                alertBox.insertBefore(icon, alertBox.firstChild);
            }
        });
    </script>
</body>
</html>
