@model HarmonySound.MVC.Models.ResetPasswordViewModel

@{
    ViewBag.Title = "Restablecer Contraseþa";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Restablecer Contraseþa - UniSound</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link rel="stylesheet" href="~/css/design-system.css" />
    <link rel="stylesheet" href="~/css/dark-theme.css" />
</head>
<body>
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-logo">
                <i class="fas fa-shield-alt"></i>
            </div>
            
            <h2>Nueva Contraseþa</h2>
            <p class="auth-subtitle">
                Ingresa el cµdigo que recibiste por email y tu nueva contraseþa
                @if (Model?.Email != null)
                {
                    <br><strong>@Model.Email</strong>
                }
            </p>

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.UserId)
                @Html.HiddenFor(m => m.Email)

                <!-- Mostrar errores de validaciµn -->
                @Html.ValidationSummary(true, "", new { @class = "validation-summary" })

                <div class="form-group">
                    @Html.LabelFor(m => m.Code, "Cµdigo de verificaciµn", new { @class = "form-label" })
                    <div class="input-group">
                        <span class="input-icon">
                            <i class="fas fa-shield-alt"></i>
                        </span>
                        @Html.TextBoxFor(m => m.Code, new { @placeholder = "Cµdigo de 6 dÚgitos", @class = "form-control code-input", @maxlength = "6", @pattern = "[0-9]{6}" })
                    </div>
                    @Html.ValidationMessageFor(m => m.Code, "", new { @class = "validation-error" })
                </div>

                <div class="form-group">
                    @Html.LabelFor(m => m.NewPassword, "Nueva contraseþa", new { @class = "form-label" })
                    <div class="input-group">
                        <span class="input-icon">
                            <i class="fas fa-lock"></i>
                        </span>
                        @Html.PasswordFor(m => m.NewPassword, new { @placeholder = "MÚnimo 6 caracteres", @class = "form-control", @id = "NewPassword" })
                        <button type="button" class="password-toggle" onclick="togglePassword('NewPassword')">
                            <i class="fas fa-eye" id="toggleIcon1"></i>
                        </button>
                    </div>
                    @Html.ValidationMessageFor(m => m.NewPassword, "", new { @class = "validation-error" })
                </div>

                <div class="form-group">
                    @Html.LabelFor(m => m.ConfirmPassword, "Confirmar nueva contraseþa", new { @class = "form-label" })
                    <div class="input-group">
                        <span class="input-icon">
                            <i class="fas fa-lock"></i>
                        </span>
                        @Html.PasswordFor(m => m.ConfirmPassword, new { @placeholder = "Repite tu nueva contraseþa", @class = "form-control", @id = "ConfirmPassword" })
                        <button type="button" class="password-toggle" onclick="togglePassword('ConfirmPassword')">
                            <i class="fas fa-eye" id="toggleIcon2"></i>
                        </button>
                    </div>
                    @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "validation-error" })
                </div>

                <!-- Indicador de seguridad de contraseþa -->
                <div class="password-strength" id="passwordStrength" style="display: none;">
                    <div class="strength-bar">
                        <div class="strength-fill" id="strengthFill"></div>
                    </div>
                    <span class="strength-text" id="strengthText">DÕbil</span>
                </div>

                <button type="submit" class="btn-primary" id="submitBtn">
                    <i class="fas fa-save me-2"></i>
                    Restablecer Contraseþa
                </button>

                <!-- Enlaces de navegaciµn -->
                <div class="auth-links">
                    <p class="back-to-forgot">
                        <a href="@Url.Action("ForgotPassword", "Account")">
                            <i class="fas fa-redo me-1"></i>
                            Enviar nuevo cµdigo
                        </a>
                    </p>
                    
                    <p class="back-to-login">
                        <a href="@Url.Action("Login", "Account")">
                            <i class="fas fa-arrow-left me-1"></i>
                            Volver al inicio de sesiµn
                        </a>
                    </p>
                </div>
            }
        </div>
    </div>

    <style>
        body {
            background: linear-gradient(135deg, var(--us-surface), var(--us-surface-alt)) !important;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            color: var(--us-ink);
            padding: 2rem 0;
        }

        .auth-container {
            width: 100%;
            max-width: 500px;
            padding: 1rem;
        }

        .auth-card {
            background: linear-gradient(135deg, var(--us-surface-alt), var(--us-surface-alt));
            border: 1px solid var(--us-border);
            border-radius: 20px;
            padding: 3rem 2rem;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.6);
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .auth-card::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(45deg, transparent, rgba(200, 16, 46, 0.05), transparent);
            animation: shimmer 3s infinite;
        }

        .auth-logo {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #c8102e, #a30d25);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            font-size: 2rem;
            color: #ffffff;
            position: relative;
            z-index: 2;
        }

        .auth-card h2 {
            color: var(--us-ink);
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            position: relative;
            z-index: 2;
        }

        .auth-subtitle {
            color: var(--us-ink-soft);
            font-size: 1rem;
            margin-bottom: 2rem;
            position: relative;
            z-index: 2;
            line-height: 1.5;
        }

        .auth-subtitle strong {
            color: #c8102e;
            font-weight: 600;
        }

        .form-group {
            margin-bottom: 1.5rem;
            text-align: left;
            position: relative;
            z-index: 2;
        }

        .form-label {
            display: block;
            color: var(--us-ink);
            font-weight: 600;
            margin-bottom: 0.5rem;
            font-size: 0.95rem;
        }

        .input-group {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #c8102e;
            z-index: 3;
        }

        .form-control {
            width: 100%;
            padding: 14px 16px 14px 48px;
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 12px;
            color: var(--us-ink);
            font-size: 1rem;
            transition: all 0.3s ease;
            box-sizing: border-box;
        }

        .code-input {
            text-align: center;
            font-size: 1.5rem;
            font-weight: 600;
            letter-spacing: 8px;
            font-family: 'Courier New', monospace;
        }

        .password-toggle {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: var(--us-ink-soft);
            cursor: pointer;
            font-size: 1.1rem;
            transition: color 0.3s ease;
            z-index: 3;
        }

        .password-toggle:hover {
            color: #c8102e;
        }

        .form-control:focus {
            background: rgba(255, 255, 255, 0.15);
            border-color: #c8102e;
            box-shadow: 0 0 0 0.2rem rgba(200, 16, 46, 0.25);
            outline: none;
        }

        .form-control::placeholder {
            color: var(--us-ink-faint);
        }

        .password-strength {
            margin: 1rem 0;
            text-align: left;
        }

        .strength-bar {
            width: 100%;
            height: 6px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 3px;
            overflow: hidden;
            margin-bottom: 0.5rem;
        }

        .strength-fill {
            height: 100%;
            border-radius: 3px;
            transition: all 0.3s ease;
            width: 0%;
        }

        .strength-text {
            font-size: 0.9rem;
            font-weight: 600;
        }

        .btn-primary {
            width: 100%;
            background: linear-gradient(135deg, #c8102e, #a30d25);
            border: none;
            color: #ffffff;
            font-weight: 600;
            padding: 14px 24px;
            border-radius: 25px;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(200, 16, 46, 0.3);
            margin: 1rem 0;
            position: relative;
            z-index: 2;
        }

        .btn-primary:hover:not(:disabled) {
            background: linear-gradient(135deg, #a30d25, #22c55e);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(200, 16, 46, 0.4);
        }

        .btn-primary:disabled {
            background: var(--us-ink-faint);
            color: var(--us-ink-faint);
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        .auth-links {
            margin-top: 1.5rem;
            position: relative;
            z-index: 2;
        }

        .back-to-forgot, .back-to-login {
            margin-bottom: 0.5rem;
        }

        .back-to-forgot a, .back-to-login a {
            color: var(--us-ink-soft);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
            display: inline-flex;
            align-items: center;
            transition: color 0.3s ease;
        }

        .back-to-forgot a:hover {
            color: #c8102e;
        }

        .back-to-login a:hover {
            color: #c8102e;
        }

        .validation-summary, .validation-error {
            color: #c8102e;
            font-size: 0.875rem;
            margin-top: 0.5rem;
            display: block;
        }

        .validation-summary {
            background: rgba(255, 107, 107, 0.1);
            border: 1px solid rgba(255, 107, 107, 0.3);
            padding: 1rem;
            border-radius: 8px;
            margin-bottom: 1rem;
            position: relative;
            z-index: 2;
        }

        @@keyframes shimmer {
            0% {
                transform: translateX(-100%) translateY(-100%) rotate(45deg);
            }
            100% {
                transform: translateX(100%) translateY(100%) rotate(45deg);
            }
        }

        .fas {
            font-family: "Font Awesome 5 Free" !important;
            font-weight: 900 !important;
        }

        .me-1 { margin-right: 0.25rem !important; }
        .me-2 { margin-right: 0.5rem !important; }
    </style>

    <script>
        // FUNCIONALIDAD RESTABLECER CONTRASEîA 

        document.addEventListener('DOMContentLoaded', function() {
            const newPasswordInput = document.getElementById('NewPassword');
            const confirmPasswordInput = document.getElementById('ConfirmPassword');
            const codeInput = document.querySelector('.code-input');
            const submitBtn = document.getElementById('submitBtn');
            const strengthIndicator = document.getElementById('passwordStrength');
            const strengthFill = document.getElementById('strengthFill');
            const strengthText = document.getElementById('strengthText');

            // Validaciµn en tiempo real
            function validateForm() {
                const code = codeInput.value.trim();
                const newPassword = newPasswordInput.value;
                const confirmPassword = confirmPasswordInput.value;

                const isValid = code.length === 6 && 
                               newPassword.length >= 6 && 
                               newPassword === confirmPassword;

                submitBtn.disabled = !isValid;
            }

            // Evaluador de fuerza de contraseþa
            function evaluatePasswordStrength(password) {
                let score = 0;
                let feedback = [];

                if (password.length >= 6) score += 1;
                if (password.length >= 8) score += 1;
                if (/[a-z]/.test(password)) score += 1;
                if (/[A-Z]/.test(password)) score += 1;
                if (/[0-9]/.test(password)) score += 1;
                if (/[^A-Za-z0-9]/.test(password)) score += 1;

                let strength = 'Muy dÕbil';
                let color = '#c8102e';
                let width = '20%';

                if (score >= 2) {
                    strength = 'DÕbil';
                    color = '#c8102e';
                    width = '40%';
                }
                if (score >= 3) {
                    strength = 'Regular';
                    color = '#c8102e';
                    width = '60%';
                }
                if (score >= 4) {
                    strength = 'Buena';
                    color = '#c8102e';
                    width = '80%';
                }
                if (score >= 5) {
                    strength = 'Muy fuerte';
                    color = '#0ed145';
                    width = '100%';
                }

                return { strength, color, width };
            }

            // Event listeners
            newPasswordInput.addEventListener('input', function() {
                const password = this.value;
                
                if (password.length > 0) {
                    strengthIndicator.style.display = 'block';
                    const evaluation = evaluatePasswordStrength(password);
                    
                    strengthFill.style.width = evaluation.width;
                    strengthFill.style.backgroundColor = evaluation.color;
                    strengthText.textContent = evaluation.strength;
                    strengthText.style.color = evaluation.color;
                } else {
                    strengthIndicator.style.display = 'none';
                }
                
                validateForm();
            });

            confirmPasswordInput.addEventListener('input', validateForm);
            codeInput.addEventListener('input', function() {
                // Solo nºmeros y mÃximo 6 dÚgitos
                this.value = this.value.replace(/[^0-9]/g, '').slice(0, 6);
                validateForm();
            });

            // Auto-focus en cµdigo
            codeInput.focus();

            // Validaciµn inicial
            validateForm();
        });

        // Funciµn para alternar visibilidad de contraseþa
        function togglePassword(inputId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(inputId === 'NewPassword' ? 'toggleIcon1' : 'toggleIcon2');
            
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        }
    </script>
</body>
</html>