@model HarmonySound.MVC.Models.ForgotPasswordViewModel

@{
    ViewBag.Title = "Recuperar Contraseña";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Recuperar Contraseña - UniSound</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link rel="stylesheet" href="~/css/design-system.css" />
    <link rel="stylesheet" href="~/css/dark-theme.css" />
</head>
<body>
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-logo">
                <i class="fas fa-key"></i>
            </div>
            
            <h2>Recuperar Contraseña</h2>
            <p class="auth-subtitle">Te enviaremos un código de verificación a tu email</p>

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                <!-- Mostrar errores de validación -->
                @Html.ValidationSummary(true, "", new { @class = "validation-summary" })

                <div class="form-group">
                    @Html.LabelFor(m => m.Email, "Correo electrónico", new { @class = "form-label" })
                    <div class="input-group">
                        <span class="input-icon">
                            <i class="fas fa-envelope"></i>
                        </span>
                        @Html.TextBoxFor(m => m.Email, new { @placeholder = "Ingresa tu email registrado", @class = "form-control" })
                    </div>
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "validation-error" })
                </div>

                <button type="submit" class="btn-primary">
                    <i class="fas fa-paper-plane me-2"></i>
                    Enviar Código
                </button>

                <!-- Enlaces de navegación -->
                <div class="auth-links">
                    <p class="back-to-login">
                        <a href="@Url.Action("Login", "Account")">
                            <i class="fas fa-arrow-left me-1"></i>
                            Volver al inicio de sesión
                        </a>
                    </p>
                    
                    <p class="register-link">
                        ¿No tienes una cuenta? 
                        <a href="@Url.Action("Register", "Account")">Regístrate aquí</a>
                    </p>
                </div>
            }
        </div>
    </div>

    <style>
        body {
            background: linear-gradient(135deg, var(--us-surface), var(--us-surface-alt)) !important;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            color: var(--us-ink);
        }

        .auth-container {
            width: 100%;
            max-width: 450px;
            padding: 2rem;
        }

        .auth-card {
            background: linear-gradient(135deg, var(--us-surface-alt), var(--us-surface-alt));
            border: 1px solid var(--us-border);
            border-radius: 20px;
            padding: 3rem 2rem;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.6);
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .auth-card::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(45deg, transparent, rgba(200, 16, 46, 0.05), transparent);
            animation: shimmer 3s infinite;
        }

        .auth-logo {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #c8102e, #a30d25);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            font-size: 2rem;
            color: #ffffff;
            position: relative;
            z-index: 2;
        }

        .auth-card h2 {
            color: var(--us-ink);
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            position: relative;
            z-index: 2;
        }

        .auth-subtitle {
            color: var(--us-ink-soft);
            font-size: 1rem;
            margin-bottom: 2rem;
            position: relative;
            z-index: 2;
        }

        .form-group {
            margin-bottom: 1.5rem;
            text-align: left;
            position: relative;
            z-index: 2;
        }

        .form-label {
            display: block;
            color: var(--us-ink);
            font-weight: 600;
            margin-bottom: 0.5rem;
            font-size: 0.95rem;
        }

        .input-group {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #c8102e;
            z-index: 3;
        }

        .form-control {
            width: 100%;
            padding: 14px 16px 14px 48px;
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 12px;
            color: var(--us-ink);
            font-size: 1rem;
            transition: all 0.3s ease;
            box-sizing: border-box;
        }

        .form-control:focus {
            background: rgba(255, 255, 255, 0.15);
            border-color: #c8102e;
            box-shadow: 0 0 0 0.2rem rgba(200, 16, 46, 0.25);
            outline: none;
        }

        .form-control::placeholder {
            color: var(--us-ink-faint);
        }

        .btn-primary {
            width: 100%;
            background: linear-gradient(135deg, #c8102e, #a30d25);
            border: none;
            color: #ffffff;
            font-weight: 600;
            padding: 14px 24px;
            border-radius: 25px;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(200, 16, 46, 0.3);
            margin: 1rem 0;
            position: relative;
            z-index: 2;
        }

        .btn-primary:hover {
            background: linear-gradient(135deg, #a30d25, #e3a3ab);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(200, 16, 46, 0.4);
        }

        .auth-links {
            margin-top: 1.5rem;
            position: relative;
            z-index: 2;
        }

        .back-to-login {
            margin-bottom: 1rem;
        }

        .back-to-login a {
            color: #c8102e;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
            display: inline-flex;
            align-items: center;
            transition: color 0.3s ease;
        }

        .back-to-login a:hover {
            color: #a30d25;
        }

        .register-link {
            color: var(--us-ink-soft);
            font-size: 0.9rem;
            margin: 0;
        }

        .register-link a {
            color: #c8102e;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.3s ease;
        }

        .register-link a:hover {
            color: #a30d25;
        }

        .validation-summary, .validation-error {
            color: #c8102e;
            font-size: 0.875rem;
            margin-top: 0.5rem;
            display: block;
        }

        .validation-summary {
            background: rgba(255, 107, 107, 0.1);
            border: 1px solid rgba(255, 107, 107, 0.3);
            padding: 1rem;
            border-radius: 8px;
            margin-bottom: 1rem;
            position: relative;
            z-index: 2;
        }

        @@keyframes shimmer {
            0% {
                transform: translateX(-100%) translateY(-100%) rotate(45deg);
            }
            100% {
                transform: translateX(100%) translateY(100%) rotate(45deg);
            }
        }

       

        .fas {
            font-family: "Font Awesome 5 Free" !important;
            font-weight: 900 !important;
        }

        .me-1 { margin-right: 0.25rem !important; }
        .me-2 { margin-right: 0.5rem !important; }
    </style>
</body>
</html>
