@model List<HarmonySound.API.DTOs.UserRoleDto>

@{
    ViewData["Title"] = "Gesti¾n de Roles";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HarmonySound Admin</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="admin-body">
    <div class="admin-dashboard">
        <!-- Sidebar -->
        <nav class="admin-sidebar">
            <div class="sidebar-header">
                <div class="logo">
                    <i class="fas fa-shield-alt"></i>
                    <h2>HarmonySound</h2>
                    <span>Admin Panel</span>
                </div>
            </div>

            <div class="sidebar-menu">
                <a href="@Url.Action("Dashboard", "Admin")" class="menu-item">
                    <i class="fas fa-tachometer-alt"></i>
                    <span>Dashboard</span>
                </a>
                <a href="@Url.Action("Users", "Admin")" class="menu-item">
                    <i class="fas fa-users"></i>
                    <span>Usuarios</span>
                </a>
                <a href="@Url.Action("Content", "Admin")" class="menu-item">
                    <i class="fas fa-music"></i>
                    <span>Contenido</span>
                </a>
                <a href="@Url.Action("UserRoles", "Admin")" class="menu-item active">
                    <i class="fas fa-user-shield"></i>
                    <span>Roles</span>
                </a>
            </div>

            <div class="sidebar-footer">
                <form asp-action="Logout" asp-controller="Account" method="post">
                    <button type="submit" class="logout-btn">
                        <i class="fas fa-sign-out-alt"></i>
                        <span>Cerrar Sesi¾n</span>
                    </button>
                </form>
            </div>
        </nav>

        <!-- Main Content -->
        <main class="admin-main">
            <div class="admin-header">
                <h1>
                    <i class="fas fa-user-shield me-3"></i>
                    Gesti¾n de Roles
                </h1>
                <p>Administrar asignaci¾n de roles a usuarios del sistema</p>
            </div>

            <!-- Mensajes de feedback -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    <i class="fas fa-check-circle"></i>
                    @TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-error">
                    <i class="fas fa-exclamation-circle"></i>
                    @TempData["Error"]
                </div>
            }

            <!-- Filtros y b·squeda -->
            <div class="filters-section">
                <div class="filters-row">
                    <input type="text" id="search-users" placeholder="Buscar por usuario o email..." class="search-input">
                    <select id="role-filter" class="filter-select">
                        <option value="">Todos los roles</option>
                        <option value="Admin">Administradores</option>
                        <option value="artist">Artistas</option>
                        <option value="client">Clientes</option>
                    </select>
                </div>
            </div>

            <!-- EstadĒsticas rßpidas -->
            <div class="stats-cards">
                <div class="stat-card">
                    <div class="stat-icon admin-icon">
                        <i class="fas fa-crown"></i>
                    </div>
                    <div class="stat-info">
                        <h3>@Model.Count(r => r.RoleName == "Admin")</h3>
                        <p>Administradores</p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon artist-icon">
                        <i class="fas fa-microphone"></i>
                    </div>
                    <div class="stat-info">
                        <h3>@Model.Count(r => r.RoleName == "artist")</h3>
                        <p>Artistas</p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon client-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <div class="stat-info">
                        <h3>@Model.Count(r => r.RoleName == "client")</h3>
                        <p>Clientes</p>
                    </div>
                </div>
            </div>

            <!-- Tabla de roles -->
            <div class="roles-table-container">
                <table class="roles-table">
                    <thead>
                        <tr>
                            <th>Usuario</th>
                            <th>Email</th>
                            <th>Rol Actual</th>
                            <th>ID Usuario</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var userRole in Model.OrderBy(ur => ur.UserName))
                        {
                            <tr class="user-role-row" data-role="@userRole.RoleName">
                                <td>
                                    <div class="user-info">
                                        <div class="user-avatar">
                                            <i class="fas fa-user"></i>
                                        </div>
                                        <div class="user-details">
                                            <div class="user-name">@userRole.UserName</div>
                                            <div class="user-id">#@userRole.UserId</div>
                                        </div>
                                    </div>
                                </td>
                                <td>@userRole.UserEmail</td>
                                <td>
                                    <span class="role-badge role-@userRole.RoleName.ToLower()">
                                        <i class="fas @GetRoleIcon(userRole.RoleName) me-2"></i>
                                        @userRole.RoleName
                                    </span>
                                </td>
                                <td>@userRole.UserId</td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (!Model.Any())
                {
                    <div class="empty-state">
                        <i class="fas fa-user-shield"></i>
                        <h3>No hay roles asignados</h3>
                        <p>Comienza asignando roles a los usuarios del sistema</p>
                        <button class="btn-primary" onclick="showAssignRoleModal()">
                            Asignar Primer Rol
                        </button>
                    </div>
                }
            </div>
        </main>
    </div>

    <!-- Modal para asignar rol -->
    <div id="assignRoleModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-user-plus me-2"></i>Asignar Rol</h3>
                <button class="modal-close" onclick="hideAssignRoleModal()">&times;</button>
            </div>
            <form asp-action="AssignRole" method="post">
                <div class="modal-body">
                    <div class="form-group">
                        <label for="userId">ID del Usuario:</label>
                        <input type="number" id="userId" name="userId" class="form-control" required>
                        <small class="form-text">Ingresa el ID numķrico del usuario</small>
                    </div>
                    <div class="form-group">
                        <label for="roleName">Rol:</label>
                        <select id="roleName" name="roleName" class="form-control" required>
                            <option value="">Seleccionar rol...</option>
                            @if (ViewBag.AllRoles != null)
                            {
                                @foreach (string role in ViewBag.AllRoles)
                                {
                                    <option value="@role">@role</option>
                                }
                            }
                            else
                            {
                                <option value="Admin">Admin</option>
                                <option value="Artist">Artist</option>
                                <option value="Client">Client</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-secondary" onclick="hideAssignRoleModal()">Cancelar</button>
                    <button type="submit" class="btn-primary">Asignar Rol</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal para editar rol -->
    <div id="editRoleModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-edit me-2"></i>Cambiar Rol</h3>
                <button class="modal-close" onclick="hideEditRoleModal()">&times;</button>
            </div>
            <form id="editRoleForm" asp-action="AssignRole" method="post">
                <div class="modal-body">
                    <div class="form-group">
                        <label>Usuario:</label>
                        <input type="text" id="editUserName" class="form-control" readonly>
                        <input type="hidden" id="editUserId" name="userId">
                    </div>
                    <div class="form-group">
                        <label for="editRoleName">Nuevo Rol:</label>
                        <select id="editRoleName" name="roleName" class="form-control" required>
                            <option value="Admin">Admin</option>
                            <option value="Artist">Artist</option>
                            <option value="Client">Client</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-secondary" onclick="hideEditRoleModal()">Cancelar</button>
                    <button type="submit" class="btn-primary">Guardar Cambios</button>
                </div>
            </form>
        </div>
    </div>

    <style>
        .admin-body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #000;
            color: #fff;
        }

        .admin-dashboard {
            display: flex;
            min-height: 100vh;
        }

        .admin-sidebar {
            width: 250px;
            background: linear-gradient(180deg, #1a1a1a, #2a2a2a);
            border-right: 1px solid #333;
            display: flex;
            flex-direction: column;
        }

        .sidebar-header {
            padding: 2rem 1rem;
            border-bottom: 1px solid #333;
            text-align: center;
        }

        .logo i {
            font-size: 2rem;
            color: #ef4444;
            margin-bottom: 0.5rem;
        }

        .logo h2 {
            margin: 0;
            color: #fff;
            font-size: 1.2rem;
        }

        .logo span {
            color: #888;
            font-size: 0.9rem;
        }

        .sidebar-menu {
            flex: 1;
            padding: 1rem 0;
        }

        .menu-item {
            display: flex;
            align-items: center;
            padding: 1rem 1.5rem;
            color: #ccc;
            text-decoration: none;
            transition: all 0.3s ease;
            border-left: 3px solid transparent;
        }

        .menu-item:hover, .menu-item.active {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
            border-left-color: #ef4444;
        }

        .menu-item i {
            margin-right: 1rem;
            width: 20px;
        }

        .sidebar-footer {
            padding: 1rem;
            border-top: 1px solid #333;
        }

        .logout-btn {
            width: 100%;
            background: transparent;
            border: 1px solid #333;
            color: #ccc;
            padding: 0.75rem;
            border-radius: 6px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }

        .logout-btn:hover {
            background: #dc3545;
            border-color: #dc3545;
            color: #fff;
        }

        .logout-btn i {
            margin-right: 0.5rem;
        }

        .admin-main {
            flex: 1;
            padding: 2rem;
            overflow-y: auto;
        }

        .admin-header {
            margin-bottom: 2rem;
        }

        .admin-header h1 {
            margin: 0 0 0.5rem 0;
            font-size: 2.5rem;
            color: #ef4444;
            display: flex;
            align-items: center;
        }

        .admin-header p {
            margin: 0;
            color: #888;
            font-size: 1.1rem;
        }

        .alert {
            padding: 1rem 1.5rem;
            border-radius: 8px;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
        }

        .alert i {
            margin-right: 0.75rem;
            font-size: 1.2rem;
        }

        .alert-success {
            background: rgba(34, 197, 94, 0.1);
            border: 1px solid rgba(34, 197, 94, 0.3);
            color: #4ade80;
        }

        .alert-error {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.3);
            color: #f87171;
        }

        .filters-section {
            background: linear-gradient(135deg, #1a1a1a, #2a2a2a);
            padding: 1.5rem;
            border-radius: 12px;
            border: 1px solid #333;
            margin-bottom: 2rem;
        }

        .filters-row {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr auto;
            gap: 1rem;
            align-items: center;
        }

        .search-input, .filter-select {
            padding: 0.75rem 1rem;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid #444;
            border-radius: 6px;
            color: #fff;
            font-size: 0.95rem;
        }

        .search-input:focus, .filter-select:focus {
            outline: none;
            border-color: #ef4444;
            box-shadow: 0 0 0 2px rgba(239, 68, 68, 0.2);
        }

        .btn-primary {
            background: linear-gradient(135deg, #ef4444, #dc2626);
            color: #fff;
            border: none;
            padding: 0.75rem 1.5rem;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(239, 68, 68, 0.4);
        }

        .stats-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .stat-card {
            background: linear-gradient(135deg, #1a1a1a, #2a2a2a);
            padding: 1.5rem;
            border-radius: 12px;
            border: 1px solid #333;
            display: flex;
            align-items: center;
        }

        .stat-icon {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 1rem;
            font-size: 1.2rem;
            color: #fff;
        }

        .admin-icon { background: #ef4444; }
        .artist-icon { background: #8b5cf6; }
        .client-icon { background: #06b6d4; }

        .stat-info h3 {
            margin: 0;
            font-size: 1.5rem;
            color: #fff;
        }

        .stat-info p {
            margin: 0;
            color: #888;
            font-size: 0.9rem;
        }

        .roles-table-container {
            background: linear-gradient(135deg, #1a1a1a, #2a2a2a);
            border-radius: 12px;
            border: 1px solid #333;
            overflow: hidden;
        }

        .roles-table {
            width: 100%;
            border-collapse: collapse;
        }

        .roles-table th {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
            padding: 1rem 1.5rem;
            text-align: left;
            font-weight: 600;
            border-bottom: 1px solid #333;
        }

        .roles-table td {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid #333;
            vertical-align: middle;
        }

        .user-role-row:hover {
            background: rgba(255, 255, 255, 0.02);
        }

        .user-info {
            display: flex;
            align-items: center;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            background: #333;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 1rem;
            color: #888;
        }

        .user-details {
            flex: 1;
        }

        .user-name {
            font-weight: 600;
            color: #fff;
        }

        .user-id {
            font-size: 0.85rem;
            color: #888;
        }

        .role-badge {
            padding: 0.4rem 0.8rem;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
        }

        .role-admin {
            background: rgba(239, 68, 68, 0.2);
            color: #ef4444;
            border: 1px solid rgba(239, 68, 68, 0.3);
        }

        .role-artist {
            background: rgba(139, 92, 246, 0.2);
            color: #8b5cf6;
            border: 1px solid rgba(139, 92, 246, 0.3);
        }

        .role-client {
            background: rgba(6, 182, 212, 0.2);
            color: #06b6d4;
            border: 1px solid rgba(6, 182, 212, 0.3);
        }

        .action-buttons {
            display: flex;
            gap: 0.5rem;
        }

        .btn-action {
            width: 35px;
            height: 35px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }

        .btn-edit {
            background: rgba(34, 197, 94, 0.2);
            color: #22c55e;
            border: 1px solid rgba(34, 197, 94, 0.3);
        }

        .btn-edit:hover {
            background: rgba(34, 197, 94, 0.3);
            transform: translateY(-2px);
        }

        .btn-delete {
            background: rgba(239, 68, 68, 0.2);
            color: #ef4444;
            border: 1px solid rgba(239, 68, 68, 0.3);
        }

        .btn-delete:hover {
            background: rgba(239, 68, 68, 0.3);
            transform: translateY(-2px);
        }

        .empty-state {
            text-align: center;
            padding: 3rem;
            color: #888;
        }

        .empty-state i {
            font-size: 4rem;
            margin-bottom: 1rem;
            color: #333;
        }

        .empty-state h3 {
            margin-bottom: 0.5rem;
            color: #ccc;
        }

        .empty-state p {
            margin-bottom: 2rem;
        }

        /* Modal Styles */
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(5px);
        }

        .modal-content {
            background: linear-gradient(135deg, #1a1a1a, #2a2a2a);
            margin: 5% auto;
            padding: 0;
            border: 1px solid #333;
            border-radius: 12px;
            width: 90%;
            max-width: 500px;
            position: relative;
        }

        .modal-header {
            padding: 1.5rem;
            border-bottom: 1px solid #333;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-header h3 {
            margin: 0;
            color: #ef4444;
            display: flex;
            align-items: center;
        }

        .modal-close {
            background: none;
            border: none;
            color: #888;
            font-size: 1.5rem;
            cursor: pointer;
            padding: 0;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .modal-close:hover {
            color: #ef4444;
        }

        .modal-body {
            padding: 1.5rem;
        }

        .modal-footer {
            padding: 1.5rem;
            border-top: 1px solid #333;
            display: flex;
            gap: 1rem;
            justify-content: flex-end;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            color: #ccc;
            font-weight: 600;
        }

        .form-control {
            width: 100%;
            padding: 0.75rem 1rem;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid #444;
            border-radius: 6px;
            color: #fff;
            font-size: 0.95rem;
        }

        .form-control:focus {
            outline: none;
            border-color: #ef4444;
            box-shadow: 0 0 0 2px rgba(239, 68, 68, 0.2);
        }

        .form-text {
            color: #888;
            font-size: 0.85rem;
            margin-top: 0.25rem;
        }

        .btn-secondary {
            background: transparent;
            color: #ccc;
            border: 1px solid #444;
            padding: 0.75rem 1.5rem;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .btn-secondary:hover {
            background: #333;
            color: #fff;
        }

        .me-2 { margin-right: 0.5rem; }
        .me-3 { margin-right: 1rem; }

        }
    </style>

    <script>
        // Funci¾n para mostrar el modal de asignar rol
        function showAssignRoleModal() {
            document.getElementById('assignRoleModal').style.display = 'block';
        }

        // Funci¾n para ocultar el modal de asignar rol
        function hideAssignRoleModal() {
            document.getElementById('assignRoleModal').style.display = 'none';
        }

        // Funci¾n para mostrar el modal de editar rol
        function editUserRole(userId, currentRole, userName) {
            document.getElementById('editUserId').value = userId;
            document.getElementById('editUserName').value = userName;
            document.getElementById('editRoleName').value = currentRole;
            document.getElementById('editRoleModal').style.display = 'block';
        }

        // Funci¾n para ocultar el modal de editar rol
        function hideEditRoleModal() {
            document.getElementById('editRoleModal').style.display = 'none';
        }

        // Funci¾n para obtener el icono del rol
        function getRoleIcon(roleName) {
            switch(roleName) {
                case 'Admin': return 'fa-crown';
                case 'Artist': return 'fa-microphone';
                case 'Client': return 'fa-user';
                default: return 'fa-user';
            }
        }

        // Filtrado en tiempo real
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('search-users');
            const roleFilter = document.getElementById('role-filter');
            const rows = document.querySelectorAll('.user-role-row');

            function filterRows() {
                const searchTerm = searchInput.value.toLowerCase();
                const selectedRole = roleFilter.value;

                rows.forEach(row => {
                    const userName = row.querySelector('.user-name').textContent.toLowerCase();
                    const userEmail = row.cells[1].textContent.toLowerCase();
                    const userRole = row.dataset.role;

                    const matchesSearch = userName.includes(searchTerm) || userEmail.includes(searchTerm);
                    const matchesRole = !selectedRole || userRole === selectedRole;

                    row.style.display = matchesSearch && matchesRole ? '' : 'none';
                });
            }

            searchInput.addEventListener('input', filterRows);
            roleFilter.addEventListener('change', filterRows);

            // Cerrar modales al hacer click fuera
            window.addEventListener('click', function(event) {
                const assignModal = document.getElementById('assignRoleModal');
                const editModal = document.getElementById('editRoleModal');
                
                if (event.target === assignModal) {
                    hideAssignRoleModal();
                }
                if (event.target === editModal) {
                    hideEditRoleModal();
                }
            });
        });
    </script>
</body>
</html>

@functions {
    private string GetRoleIcon(string roleName)
    {
        return roleName switch
        {
            "Admin" => "fa-crown",
            "artist" => "fa-microphone",
            "client" => "fa-user",
            _ => "fa-user"
        };
    }
}