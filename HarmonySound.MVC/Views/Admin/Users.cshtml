@model List<HarmonySound.MVC.Models.AdminUserViewModel>

@{
    ViewData["Title"] = "Gestión de Usuarios";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HarmonySound Admin</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="admin-body">
    <div class="admin-dashboard">
        <nav class="admin-sidebar">
            <div class="sidebar-header">
                <div class="logo">
                    <i class="fas fa-shield-alt"></i>
                    <h2>HarmonySound</h2>
                    <span>Admin Panel</span>
                </div>
            </div>

            <div class="sidebar-menu">
                <a href="@Url.Action("Dashboard", "Admin")" class="menu-item">
                    <i class="fas fa-tachometer-alt"></i>
                    <span>Dashboard</span>
                </a>
                <a href="@Url.Action("Users", "Admin")" class="menu-item active">
                    <i class="fas fa-users"></i>
                    <span>Usuarios</span>
                </a>
                <a href="@Url.Action("Content", "Admin")" class="menu-item">
                    <i class="fas fa-music"></i>
                    <span>Contenido</span>
                </a>
                <a href="@Url.Action("UserRoles", "Admin")" class="menu-item">
                    <i class="fas fa-user-shield"></i>
                    <span>Roles</span>
                </a>
            </div>

            <div class="sidebar-footer">
                <form asp-action="Logout" asp-controller="Account" method="post">
                    <button type="submit" class="logout-btn">
                        <i class="fas fa-sign-out-alt"></i>
                        <span>Cerrar Sesión</span>
                    </button>
                </form>
            </div>
        </nav>

        <main class="admin-main">
            <div class="admin-header">
                <h1>
                    <i class="fas fa-users me-3"></i>
                    Gestión de Usuarios
                </h1>
                <p>Administrar cuentas de usuarios del sistema</p>
                
                <!-- Estadísticas rápidas -->
                <div class="stats-summary">
                    <div class="stat-item">
                        <i class="fas fa-users"></i>
                        <span>Total: @Model.Count</span>
                    </div>
                    <div class="stat-item">
                        <i class="fas fa-user-tie"></i>
                        <span>Admins: @Model.Count(u => u.Role == "Admin")</span>
                    </div>
                    <div class="stat-item">
                        <i class="fas fa-microphone-alt"></i>
                        <span>Artistas: @Model.Count(u => u.Role == "artist")</span>
                    </div>
                    <div class="stat-item">
                        <i class="fas fa-user"></i>
                        <span>Clientes: @Model.Count(u => u.Role == "client")</span>
                    </div>
                </div>
            </div>

            <!-- Filtros -->
            <div class="filters-section">
                <div class="filters-card">
                    <h3><i class="fas fa-filter me-2"></i>Filtros</h3>
                    <div class="filters-row">
                        <div class="filter-group">
                            <label>Buscar usuario</label>
                            <input type="text" id="search-users" placeholder="Nombre o email..." class="search-input">
                        </div>
                        <div class="filter-group">
                            <label>Rol</label>
                            <select id="role-filter" class="filter-select">
                                <option value="">Todos los roles</option>
                                <option value="Admin">Administradores</option>
                                <option value="artist">Artistas</option>
                                <option value="client">Clientes</option>
                            </select>
                        </div>
                        <div class="filter-group">
                            <label>Estado</label>
                            <select id="status-filter" class="filter-select">
                                <option value="">Todos los estados</option>
                                <option value="Active">Activos</option>
                                <option value="Suspended">Suspendidos</option>
                                <option value="Inactive">Inactivos</option>
                            </select>
                        </div>
                        <div class="filter-group">
                            <button type="button" class="btn-clear-filters" onclick="clearFilters()">
                                <i class="fas fa-broom me-2"></i>Limpiar
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tabla de usuarios -->
            <div class="users-table-container">
                <div class="table-header">
                    <h3><i class="fas fa-table me-2"></i>Lista de Usuarios</h3>
                    <div class="table-actions">
                        <span class="results-count">Mostrando <span id="visible-count">@Model.Count</span> de @Model.Count usuarios</span>
                    </div>
                </div>
                
                <div class="table-wrapper">
                    <table class="users-table">
                        <thead>
                            <tr>
                                <th><i class="fas fa-user me-2"></i>Usuario</th>
                                <th><i class="fas fa-envelope me-2"></i>Email</th>
                                <th><i class="fas fa-user-tag me-2"></i>Rol</th>
                                <th><i class="fas fa-circle me-2"></i>Estado</th>
                                <th><i class="fas fa-calendar me-2"></i>Registro</th>
                                <th><i class="fas fa-cogs me-2"></i>Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="users-tbody">
                            @foreach (var user in Model)
                            {
                                <tr class="user-row" data-role="@user.Role" data-status="@user.State" data-name="@user.Name.ToLower()" data-email="@user.Email.ToLower()">
                                    <td>
                                        <div class="user-info">
                                            <div class="user-avatar">
                                                @if (!string.IsNullOrEmpty(user.ProfileImageUrl))
                                                {
                                                    <img src="@user.ProfileImageUrl" alt="@user.Name" />
                                                }
                                                else
                                                {
                                                    <div class="avatar-placeholder">
                                                        <i class="fas fa-user"></i>
                                                    </div>
                                                }
                                            </div>
                                            <div class="user-details">
                                                <div class="user-name">@user.Name</div>
                                                <div class="user-id">ID: @user.Id</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="email-cell">
                                            <i class="fas fa-envelope me-2"></i>
                                            @user.Email
                                        </div>
                                    </td>
                                    <td>
                                        <span class="role-badge role-@user.Role.ToLower()">
                                            @if (user.Role == "Admin")
                                            {
                                                <i class="fas fa-crown me-1"></i>
                                            }
                                            else if (user.Role == "Artist")
                                            {
                                                <i class="fas fa-microphone-alt me-1"></i>
                                            }
                                            else
                                            {
                                                <i class="fas fa-user me-1"></i>
                                            }
                                            @user.Role
                                        </span>
                                    </td>
                                    <td>
                                        <span class="status-badge status-@user.State.ToLower()">
                                            @if (user.State == "Active")
                                            {
                                                <i class="fas fa-check-circle me-1"></i>
                                            }
                                            else if (user.State == "Suspended")
                                            {
                                                <i class="fas fa-ban me-1"></i>
                                            }
                                            else
                                            {
                                                <i class="fas fa-pause-circle me-1"></i>
                                            }
                                            @user.State
                                        </span>
                                    </td>
                                    <td>
                                        <div class="date-cell">
                                            <i class="fas fa-calendar-alt me-2"></i>
                                            <span>@user.RegisterDate.ToString("dd/MM/yyyy")</span>
                                            <small>@user.RegisterDate.ToString("HH:mm")</small>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="action-buttons">
                                            @if (user.State == "Active")
                                            {
                                                <button type="button" class="btn-action btn-suspend" 
                                                        onclick="suspendUser(@user.Id, '@user.Name')"
                                                        title="Suspender usuario">
                                                    <i class="fas fa-ban"></i>
                                                </button>
                                            }
                                            else if (user.State == "Suspended")
                                            {
                                                <button type="button" class="btn-action btn-activate" 
                                                        onclick="activateUser(@user.Id, '@user.Name')"
                                                        title="Activar usuario">
                                                    <i class="fas fa-check"></i>
                                                </button>
                                            }
                                            <button class="btn-action btn-edit" 
                                                    onclick="editUserRoles(@user.Id, '@user.Name')"
                                                    title="Editar roles">
                                                <i class="fas fa-user-cog"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <!-- Modal para suspender usuario -->
    <div id="suspendModal" class="modal-overlay d-none">
        <div class="modal-container">
            <div class="modal-header">
                <h3><i class="fas fa-ban me-2"></i>Suspender Usuario</h3>
            </div>
            <div class="modal-body">
                <p>¿Estás seguro de que quieres suspender al usuario <strong id="userToSuspend"></strong>?</p>
                <div class="modal-warning">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    El usuario no podrá acceder al sistema hasta ser reactivado.
                </div>
            </div>
            <div class="modal-actions">
                <button type="button" class="btn-cancel" onclick="closeSuspendModal()">Cancelar</button>
                <button type="button" class="btn-confirm" onclick="confirmSuspend()">Suspender</button>
            </div>
        </div>
    </div>

    <!-- Formularios ocultos -->
    <form id="suspendForm" asp-action="ToggleUserStatus" method="post" style="display: none;">
        <input type="hidden" name="userId" id="userIdToSuspend" />
        <input type="hidden" name="action" value="suspend" />
    </form>

    <form id="activateForm" asp-action="ToggleUserStatus" method="post" style="display: none;">
        <input type="hidden" name="userId" id="userIdToActivate" />
        <input type="hidden" name="action" value="activate" />
    </form>

