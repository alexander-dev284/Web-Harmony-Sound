    <!-- Script para mejor manejo de estados -->
    <script>
        // Variables globales
        let userIdToSuspend = null;
        let userIdToActivate = null;

        // Función de filtrado 
        function filterUsers() {
            const searchTerm = document.getElementById('search-users').value.toLowerCase();
            const roleFilter = document.getElementById('role-filter').value;
            const statusFilter = document.getElementById('status-filter').value;
            
            const rows = document.querySelectorAll('.user-row');
            let visibleCount = 0;
            
            rows.forEach(row => {
                const name = row.dataset.name;
                const email = row.dataset.email;
                const role = row.dataset.role;
                const status = row.dataset.status;
                
                const matchesSearch = searchTerm === '' || name.includes(searchTerm) || email.includes(searchTerm);
                const matchesRole = roleFilter === '' || role === roleFilter;
                const matchesStatus = statusFilter === '' || status === statusFilter;
                
                if (matchesSearch && matchesRole && matchesStatus) {
                    row.classList.remove('hidden');
                    visibleCount++;
                } else {
                    row.classList.add('hidden');
                }
            });
            
            document.getElementById('visible-count').textContent = visibleCount;
        }

        // Event listeners para filtros
        document.getElementById('search-users').addEventListener('input', filterUsers);
        document.getElementById('role-filter').addEventListener('change', filterUsers);
        document.getElementById('status-filter').addEventListener('change', filterUsers);

        // Limpiar filtros
        function clearFilters() {
            document.getElementById('search-users').value = '';
            document.getElementById('role-filter').value = '';
            document.getElementById('status-filter').value = '';
            filterUsers();
        }

        // Funciones para suspender usuario con mejor UX
        function suspendUser(userId, userName) {
            userIdToSuspend = userId;
            document.getElementById('userToSuspend').textContent = userName;
            document.getElementById('suspendModal').classList.remove('d-none');
        }

        function closeSuspendModal() {
            document.getElementById('suspendModal').classList.add('d-none');
            userIdToSuspend = null;
        }

        function confirmSuspend() {
            if (userIdToSuspend) {
                // Deshabilitar botón durante el procesamiento
                const submitBtn = document.querySelector('#suspendModal .btn-confirm');
                const originalText = submitBtn.innerHTML;
                
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Suspendiendo...';
                
                document.getElementById('userIdToSuspend').value = userIdToSuspend;
                document.getElementById('suspendForm').submit();
            }
        }

        // Función para activar usuario con confirmación
        function activateUser(userId, userName) {
            if (confirm(`¿Estás seguro de que quieres activar al usuario ${userName}?\n\nEsto le permitirá volver a acceder al sistema.`)) {
                // MOSTRAR INDICADOR DE CARGA
                const button = event.target.closest('.btn-action');
                const originalHTML = button.innerHTML;
                
                button.disabled = true;
                button.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
                
                // ENVIAR FORMULARIO
                document.getElementById('userIdToActivate').value = userId;
                document.getElementById('activateForm').submit();
            }
        }

        // Función para editar roles (mantener existente)
        function editUserRoles(userId, userName) {
            window.location.href = `/Admin/UserRoles#user-${userId}`;
        }

        // Cerrar modal al hacer clic fuera
        document.addEventListener('click', function(e) {
            if (e.target.classList.contains('modal-overlay')) {
                closeSuspendModal();
            }
        });

        // Actualizar UI después de cambios de estado
        document.addEventListener('DOMContentLoaded', function() {
            // Verificar si hay mensajes de éxito/error y mostrar notificaciones
            const successMsg = document.querySelector('.alert-success');
            const errorMsg = document.querySelector('.alert-error');
            
            if (successMsg) {
                setTimeout(() => {
                    successMsg.style.transition = 'opacity 0.5s';
                    successMsg.style.opacity = '0';
                    setTimeout(() => successMsg.remove(), 500);
                }, 4000);
            }
            
            if (errorMsg) {
                setTimeout(() => {
                    errorMsg.style.transition = 'opacity 0.5s';
                    errorMsg.style.opacity = '0';
                    setTimeout(() => errorMsg.remove(), 500);
                }, 6000);
            }
        });
    </script>
</body>
</html>