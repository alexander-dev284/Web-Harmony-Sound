@model HarmonySound.MVC.Models.AdminDashboardViewModel

@{
    ViewData["Title"] = "Dashboard Administrativo";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HarmonySound Admin</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="admin-body">
    <div class="admin-dashboard">
        <nav class="admin-sidebar">
            <div class="sidebar-header">
                <div class="logo">
                    <i class="fas fa-shield-alt"></i>
                    <h2>HarmonySound</h2>
                    <span>Admin Panel</span>
                </div>
            </div>

            <div class="sidebar-menu">
                <a href="@Url.Action("Dashboard", "Admin")" class="menu-item active">
                    <i class="fas fa-tachometer-alt"></i>
                    <span>Dashboard</span>
                </a>
                <a href="@Url.Action("Users", "Admin")" class="menu-item">
                    <i class="fas fa-users"></i>
                    <span>Usuarios</span>
                </a>
                <a href="@Url.Action("Content", "Admin")" class="menu-item">
                    <i class="fas fa-music"></i>
                    <span>Contenido</span>
                </a>
                <a href="@Url.Action("UserRoles", "Admin")" class="menu-item">
                    <i class="fas fa-user-shield"></i>
                    <span>Roles</span>
                </a>
            </div>

            <div class="sidebar-footer">
                <form asp-action="Logout" asp-controller="Account" method="post">
                    <button type="submit" class="logout-btn">
                        <i class="fas fa-sign-out-alt"></i>
                        <span>Cerrar Sesión</span>
                    </button>
                </form>
            </div>
        </nav>

        <!-- Content -->
        <main class="admin-main">
            <div class="admin-header">
                <h1>Dashboard Administrativo</h1>
                <p>Bienvenido, @ViewBag.AdminName</p>
            </div>

            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <div class="stat-info">
                        <h3>@Model.TotalUsers</h3>
                        <p>Total Usuarios</p>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-microphone-alt"></i>
                    </div>
                    <div class="stat-info">
                        <h3>@Model.TotalArtists</h3>
                        <p>Total Artistas</p>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-user"></i>
                    </div>
                    <div class="stat-info">
                        <h3>@Model.TotalClients</h3>
                        <p>Total Clientes</p>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-music"></i>
                    </div>
                    <div class="stat-info">
                        <h3>@Model.TotalSongs</h3>
                        <p>Total Canciones</p>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-album"></i>
                    </div>
                    <div class="stat-info">
                        <h3>@Model.TotalAlbums</h3>
                        <p>Total Álbumes</p>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-crown"></i>
                    </div>
                    <div class="stat-info">
                        <h3>@Model.ActiveSubscriptions</h3>
                        <p>Suscripciones Activas</p>
                    </div>
                </div>
            </div>

            <div class="quick-actions">
                <h3>Acciones Rápidas</h3>
                <div class="actions-grid">
                    <a href="@Url.Action("Users", "Admin")" class="action-card">
                        <i class="fas fa-users-cog"></i>
                        <span>Gestionar Usuarios</span>
                    </a>
                    <a href="@Url.Action("Content", "Admin")" class="action-card">
                        <i class="fas fa-music"></i>
                        <span>Gestionar Contenido</span>
                    </a>
                    <a href="@Url.Action("UserRoles", "Admin")" class="action-card">
                        <i class="fas fa-user-shield"></i>
                        <span>Gestionar Roles</span>
                    </a>
                </div>
            </div>
        </main>
    </div>

    <style>
        .admin-body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #000;
            color: #fff;
        }

        .admin-dashboard {
            display: flex;
            min-height: 100vh;
        }

        .admin-sidebar {
            width: 250px;
            background: linear-gradient(180deg, #1a1a1a, #2a2a2a);
            border-right: 1px solid #333;
            display: flex;
            flex-direction: column;
        }

        .sidebar-header {
            padding: 2rem 1rem;
            border-bottom: 1px solid #333;
            text-align: center;
        }

        .logo i {
            font-size: 2rem;
            color: #ef4444;
            margin-bottom: 0.5rem;
        }

        .logo h2 {
            margin: 0;
            color: #fff;
            font-size: 1.2rem;
        }

        .logo span {
            color: #888;
            font-size: 0.9rem;
        }

        .sidebar-menu {
            flex: 1;
            padding: 1rem 0;
        }

        .menu-item {
            display: flex;
            align-items: center;
            padding: 1rem 1.5rem;
            color: #ccc;
            text-decoration: none;
            transition: all 0.3s ease;
            border-left: 3px solid transparent;
        }

        .menu-item:hover, .menu-item.active {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
            border-left-color: #ef4444;
        }

        .menu-item i {
            margin-right: 1rem;
            width: 20px;
        }

        .sidebar-footer {
            padding: 1rem;
            border-top: 1px solid #333;
        }

        .logout-btn {
            width: 100%;
            background: transparent;
            border: 1px solid #333;
            color: #ccc;
            padding: 0.75rem;
            border-radius: 6px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }

        .logout-btn:hover {
            background: #dc3545;
            border-color: #dc3545;
            color: #fff;
        }

        .logout-btn i {
            margin-right: 0.5rem;
        }

        .admin-main {
            flex: 1;
            padding: 2rem;
            overflow-y: auto;
        }

        .admin-header {
            margin-bottom: 3rem;
        }

        .admin-header h1 {
            margin: 0 0 0.5rem 0;
            font-size: 2.5rem;
            color: #ef4444;
        }

        .admin-header p {
            margin: 0;
            color: #888;
            font-size: 1.1rem;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
            margin-bottom: 3rem;
        }

        .stat-card {
            background: linear-gradient(135deg, #1a1a1a, #2a2a2a);
            padding: 2rem;
            border-radius: 12px;
            border: 1px solid #333;
            display: flex;
            align-items: center;
        }

        .stat-icon {
            background: #ef4444;
            color: #fff;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 1.5rem;
            font-size: 1.5rem;
        }

        .stat-info h3 {
            margin: 0;
            font-size: 2rem;
            color: #fff;
        }

        .stat-info p {
            margin: 0;
            color: #888;
        }

        .quick-actions {
            margin-bottom: 2rem;
        }

        .quick-actions h3 {
            margin-bottom: 1.5rem;
            color: #fff;
        }

        .actions-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
        }

        .action-card {
            background: linear-gradient(135deg, #1a1a1a, #2a2a2a);
            padding: 1.5rem;
            border-radius: 8px;
            border: 1px solid #333;
            text-decoration: none;
            color: #ccc;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            transition: all 0.3s ease;
        }

        .action-card:hover {
            background: rgba(239, 68, 68, 0.1);
            border-color: #ef4444;
            color: #ef4444;
            transform: translateY(-2px);
        }

        .action-card i {
            font-size: 2rem;
            margin-bottom: 0.5rem;
        }
    </style>
</body>
</html>