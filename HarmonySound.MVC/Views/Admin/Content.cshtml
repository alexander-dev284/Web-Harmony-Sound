            font-size: 0.9rem;
        }

        .btn-bulk-actions {
            background: #1db954;
            color: #000;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
            transition: background 0.3s ease;
        }

        .btn-bulk-actions:hover {
