@model List<HarmonySound.MVC.Models.AdminContentViewModel>

@{
    ViewData["Title"] = "Gestión de Contenido";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HarmonySound Admin</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="admin-body">
    <div class="admin-dashboard">
        <!-- Sidebar -->
        <nav class="admin-sidebar">
            <div class="sidebar-header">
                <div class="logo">
                    <i class="fas fa-shield-alt"></i>
                    <h2>HarmonySound</h2>
                    <span>Admin Panel</span>
                </div>
            </div>

            <div class="sidebar-menu">
                <a href="@Url.Action("Dashboard", "Admin")" class="menu-item">
                    <i class="fas fa-tachometer-alt"></i>
                    <span>Dashboard</span>
                </a>
                <a href="@Url.Action("Users", "Admin")" class="menu-item">
                    <i class="fas fa-users"></i>
                    <span>Usuarios</span>
                </a>
                <a href="@Url.Action("Content", "Admin")" class="menu-item active">
                    <i class="fas fa-music"></i>
                    <span>Contenido</span>
                </a>
                <a href="@Url.Action("UserRoles", "Admin")" class="menu-item">
                    <i class="fas fa-user-shield"></i>
                    <span>Roles</span>
                </a>
            </div>

            <div class="sidebar-footer">
                <form asp-action="Logout" asp-controller="Account" method="post">
                    <button type="submit" class="logout-btn">
                        <i class="fas fa-sign-out-alt"></i>
                        <span>Cerrar Sesión</span>
                    </button>
                </form>
            </div>
        </nav>

        <!-- Main Content -->
        <main class="admin-main">
            <div class="admin-header">
                <h1>
                    <i class="fas fa-music me-3"></i>
                    Gestión de Contenido
                </h1>
                <p>Administrar todas las canciones y contenido musical del sistema</p>
                
                <!-- Estadísticas de contenido -->
                <div class="content-stats">
                    <div class="stat-item">
                        <i class="fas fa-music"></i>
                        <span>Total Canciones: @Model.Count</span>
                    </div>
                    <div class="stat-item">
                        <i class="fas fa-microphone-alt"></i>
                        <span>Artistas: @Model.Select(c => c.ArtistName).Distinct().Count()</span>
                    </div>
                    <div class="stat-item">
                        <i class="fas fa-clock"></i>
                        <span>Duración Total: @TimeSpan.FromMinutes(Model.Sum(c => c.Duration.TotalMinutes)).ToString(@"hh\:mm")</span>
                    </div>
                </div>
            </div>

            <!-- Filtros para contenido -->
            <div class="filters-section">
                <div class="filters-card">
                    <h3><i class="fas fa-filter me-2"></i>Filtros de Contenido</h3>
                    <div class="filters-row">
                        <div class="filter-group">
                            <label>Buscar canción</label>
                            <input type="text" id="search-content" placeholder="Título o artista..." class="search-input">
                        </div>
                        <div class="filter-group">
                            <label>Tipo</label>
                            <select id="type-filter" class="filter-select">
                                <option value="">Todos los tipos</option>
                                <option value="Song">Canción</option>
                                <option value="Podcast">Podcast</option>
                                <option value="Audio">Audio</option>
                            </select>
                        </div>
                        <div class="filter-group">
                            <label>Artista</label>
                            <select id="artist-filter" class="filter-select">
                                <option value="">Todos los artistas</option>
                                @foreach (var artist in Model.Select(c => c.ArtistName).Distinct().OrderBy(a => a))
                                {
                                    <option value="@artist">@artist</option>
                                }
                            </select>
                        </div>
                        <div class="filter-group">
                            <button type="button" class="btn-clear-filters" onclick="clearContentFilters()">
                                <i class="fas fa-broom me-2"></i>Limpiar
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Lista de contenido -->
            <div class="content-grid-container">
                <div class="content-header">
                    <h3><i class="fas fa-list me-2"></i>Biblioteca Musical</h3>
                    <div class="content-actions">
                        <span class="results-count">Mostrando <span id="visible-content-count">@Model.Count</span> de @Model.Count canciones</span>
                        <button type="button" class="btn-bulk-actions" onclick="toggleBulkMode()">
                            <i class="fas fa-check-square me-2"></i>Selección múltiple
                        </button>
                    </div>
                </div>

                @if (Model.Any())
                {
                    <div class="content-grid" id="content-grid">
                        @foreach (var content in Model)
                        {
                            <div class="content-card" 
                                 data-title="@content.Title.ToLower()" 
                                 data-artist="@content.ArtistName.ToLower()" 
                                 data-type="@content.Type">
                                
                                <div class="content-checkbox" style="display: none;">
                                    <input type="checkbox" class="bulk-checkbox" value="@content.Id">
                                </div>

                                <div class="content-info">
                                    <h4 class="content-title">@content.Title</h4>
                                    <p class="content-artist">@content.ArtistName</p>
                                    <div class="content-meta">
                                        <span class="content-type">@content.Type</span>
                                        <span class="content-duration">
                                            <i class="fas fa-clock me-1"></i>
                                            @content.Duration.ToString(@"mm\:ss")
                                        </span>
                                    </div>
                                    <div class="content-date">
                                        <i class="fas fa-calendar me-1"></i>
                                        @content.UploadDate.ToString("dd/MM/yyyy")
                                    </div>
                                </div>
                                
                                <!-- ✅ ACTUALIZADO: Solo botón de eliminar -->
                                <div class="content-actions">
                                    <button class="btn-content-action btn-danger" 
                                            onclick="deleteContent(@content.Id, '@content.Title', '@content.ArtistName')"
                                            title="Eliminar">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-content">
                        <i class="fas fa-music-slash"></i>
                        <h3>No hay contenido disponible</h3>
                        <p>No se encontraron canciones en el sistema</p>
                    </div>
                }
            </div>

            <!-- Acciones masivas -->
            <div class="bulk-actions-bar" id="bulk-actions-bar" style="display: none;">
                <div class="bulk-info">
                    <span id="selected-count">0</span> elementos seleccionados
                </div>
                <div class="bulk-buttons">
                    <button type="button" class="btn-bulk btn-select-all" onclick="selectAllContent()">
                        Seleccionar todo
                    </button>
                    <button type="button" class="btn-bulk btn-clear-selection" onclick="clearSelection()">
                        Limpiar selección
                    </button>
                    <button type="button" class="btn-bulk btn-bulk-delete" onclick="bulkDeleteContent()">
                        <i class="fas fa-trash-alt me-2"></i>Eliminar seleccionados
                    </button>
                </div>
            </div>
        </main>
    </div>

    <!-- Modal para eliminar contenido -->
    <div id="deleteContentModal" class="modal-overlay d-none">
        <div class="modal-container">
            <div class="modal-header">
                <h3><i class="fas fa-exclamation-triangle me-2"></i>Eliminar Contenido</h3>
            </div>
            <div class="modal-body">
                <p>¿Estás seguro de que quieres eliminar la canción <strong id="contentToDelete"></strong>?</p>
                <div class="content-details">
                    <p><strong>Artista:</strong> <span id="artistToDelete"></span></p>
                </div>
                <div class="modal-warning">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    Esta acción eliminará permanentemente el archivo y no se puede deshacer.
                </div>
            </div>
            <div class="modal-actions">
                <button type="button" class="btn-cancel" onclick="closeDeleteModal()">Cancelar</button>
                <button type="button" class="btn-confirm-delete" onclick="confirmDeleteContent()">Eliminar</button>
            </div>
        </div>
    </div>

    <!-- Formulario oculto para eliminar -->
    <form id="deleteContentForm" asp-action="DeleteContent" method="post" style="display: none;">
        <input type="hidden" name="contentId" id="contentIdToDelete" />
    </form>

