        }

        .modal-warning {
            background: rgba(255, 193, 7, 0.1);
            border: 1px solid rgba(255, 193, 7, 0.3);
            padding: 1rem;
            border-radius: 6px;
            margin-top: 1rem;
            color: #ffc107;
            display: flex;
            align-items: center;
        }

        .modal-actions {
            display: flex;
            gap: 1rem;
            justify-content: flex-end;
            padding: 1.5rem;
            background: #333;
            border-radius: 0 0 12px 12px;
        }

        .btn-cancel, .btn-confirm-delete {
            padding: 0.75rem 1.5rem;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
            transition: background 0.3s ease;
        }

        .btn-cancel {
            background: #666;
            color: #fff;
        }

        .btn-cancel:hover {
            background: #777;
        }

        .btn-confirm-delete {
            background: #dc3545;
            color: #fff;
        }

        .btn-confirm-delete:hover {
            background: #c82333;
        }

    </style>

    <script>
        // Variables globales
        let contentIdToDelete = null;
        let bulkModeActive = false;
        let selectedContent = [];

        // Filtrado de contenido
        function filterContent() {
            const searchTerm = document.getElementById('search-content').value.toLowerCase();
            const typeFilter = document.getElementById('type-filter').value;
            const artistFilter = document.getElementById('artist-filter').value;
            
            const cards = document.querySelectorAll('.content-card');
            let visibleCount = 0;
            
            cards.forEach(card => {
                const title = card.dataset.title;
                const artist = card.dataset.artist;
                const type = card.dataset.type;
                
                const matchesSearch = searchTerm === '' || title.includes(searchTerm) || artist.includes(searchTerm);
                const matchesType = typeFilter === '' || type === typeFilter;
                const matchesArtist = artistFilter === '' || artist.includes(artistFilter.toLowerCase());
                
                if (matchesSearch && matchesType && matchesArtist) {
                    card.style.display = 'block';
                    visibleCount++;
                } else {
                    card.style.display = 'none';
                }
            });
            
            document.getElementById('visible-content-count').textContent = visibleCount;
        }

        // Event listeners para filtros
        document.getElementById('search-content').addEventListener('input', filterContent);
        document.getElementById('type-filter').addEventListener('change', filterContent);
        document.getElementById('artist-filter').addEventListener('change', filterContent);

        // Limpiar filtros
        function clearContentFilters() {
            document.getElementById('search-content').value = '';
            document.getElementById('type-filter').value = '';
            document.getElementById('artist-filter').value = '';
            filterContent();
        }

        // Modo de selección masiva
        function toggleBulkMode() {
            bulkModeActive = !bulkModeActive;
            const checkboxes = document.querySelectorAll('.content-checkbox');
            const bulkBar = document.getElementById('bulk-actions-bar');
            
            if (bulkModeActive) {
                checkboxes.forEach(cb => cb.style.display = 'block');
                bulkBar.style.display = 'flex';
            } else {
                checkboxes.forEach(cb => cb.style.display = 'none');
                bulkBar.style.display = 'none';
                clearSelection();
            }
        }

        // Seleccionar todo el contenido
        function selectAllContent() {
            const visibleCheckboxes = document.querySelectorAll('.content-card:not([style*="display: none"]) .bulk-checkbox');
            visibleCheckboxes.forEach(cb => {
                cb.checked = true;
                cb.closest('.content-card').classList.add('selected');
            });
            updateSelectedCount();
        }

        // Limpiar selección
        function clearSelection() {
            const checkboxes = document.querySelectorAll('.bulk-checkbox');
            checkboxes.forEach(cb => {
                cb.checked = false;
                cb.closest('.content-card').classList.remove('selected');
            });
            selectedContent = [];
            updateSelectedCount();
        }

        // Actualizar contador de seleccionados
        function updateSelectedCount() {
            const selected = document.querySelectorAll('.bulk-checkbox:checked');
            selectedContent = Array.from(selected).map(cb => cb.value);
            document.getElementById('selected-count').textContent = selectedContent.length;
        }

        // Event listeners para checkboxes
        document.addEventListener('change', function(e) {
            if (e.target.classList.contains('bulk-checkbox')) {
                if (e.target.checked) {
                    e.target.closest('.content-card').classList.add('selected');
                } else {
                    e.target.closest('.content-card').classList.remove('selected');
                }
                updateSelectedCount();
            }
        });

        // Eliminar contenido individual
        function deleteContent(contentId, title, artist) {
            contentIdToDelete = contentId;
            document.getElementById('contentToDelete').textContent = title;
            document.getElementById('artistToDelete').textContent = artist;
            document.getElementById('deleteContentModal').classList.remove('d-none');
        }

        function closeDeleteModal() {
            document.getElementById('deleteContentModal').classList.add('d-none');
            contentIdToDelete = null;
        }

        function confirmDeleteContent() {
            if (contentIdToDelete) {
                document.getElementById('contentIdToDelete').value = contentIdToDelete;
                document.getElementById('deleteContentForm').submit();
            }
        }

        // Eliminar contenido masivo
        function bulkDeleteContent() {
            if (selectedContent.length === 0) {
                alert('Por favor selecciona al menos un elemento para eliminar.');
                return;
            }
            
            if (confirm(`¿Estás seguro de que quieres eliminar ${selectedContent.length} canciones?`)) {
                // Implementar eliminación masiva
                console.log('Eliminar canciones:', selectedContent);
                // Aquí enviarías los IDs al servidor para eliminación masiva
            }
        }

        // ✅ REMOVIDO: Funciones viewContentDetails y editContent eliminadas

        // Cerrar modal al hacer clic fuera
        document.addEventListener('click', function(e) {
            if (e.target.classList.contains('modal-overlay')) {
                closeDeleteModal();
            }
        });
    </script>
</body>
</html>