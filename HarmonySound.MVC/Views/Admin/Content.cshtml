        .content-duration {
            color: #888;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
        }

        .content-date {
            color: #666;
            font-size: 0.85rem;
            display: flex;
            align-items: center;
        }

        /* ✅ ACTUALIZADO: Acciones de contenido centradas con solo el botón de eliminar */
        .content-actions {
            display: flex;
            justify-content: center;
            padding: 1rem 1.5rem;
            background: rgba(0, 0, 0, 0.2);
            border-top: 1px solid #444;
        }

        .btn-content-action {
