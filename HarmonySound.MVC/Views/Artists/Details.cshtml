    /* Ocultar elementos del layout */
    header, footer {
        display: none !important;
    }

    .fas {
        font-family: "Font Awesome 5 Free" !important;
        font-weight: 900 !important;
    }

    /* Clases de utilidad */
    .noselect {
        user-select: none !important;
    }

    .dragging {
        cursor: grabbing !important;
    }

    /* === Override: reproductor oscuro (consistencia con _PlayerBar) === */
    .custom-player { background: linear-gradient(135deg, #181818, #1a1a1a) !important; border-top: 1px solid #2a2b2e !important; }
    .now-playing .track-title { color: #f4f5f6 !important; }
    .now-playing .track-artist { color: #b9bdc2 !important; }
    .track-cover .cover-placeholder { background: linear-gradient(135deg, #2a2b2e, #34363a) !important; color: #b9bdc2 !important; }
    .control-btn { color: #b9bdc2 !important; }
    .control-btn:hover { color: #ffffff !important; }
    .control-btn.active { color: #c8102e !important; background: rgba(200,16,46,0.15) !important; }
    .control-btn.play-btn { background: var(--us-surface) !important; color: #1c1c1e !important; }
    .control-btn.play-btn:hover { background: #f0f0f0 !important; }
    .time { color: #b9bdc2 !important; }
    .progress-background { background: #4a4d52 !important; }
    .volume-background { background: #4a4d52 !important; }
</style>


<script>
    let contentIdToDelete = null;

    function showDeleteModal(contentId, songTitle) {
        contentIdToDelete = contentId;
        document.getElementById('songToDelete').textContent = songTitle;
        document.getElementById('contentIdToDelete').value = contentId;
        document.getElementById('deleteModal').classList.remove('d-none');
    }

    function hideDeleteModal() {
        document.getElementById('deleteModal').classList.add('d-none');
        contentIdToDelete = null;
    }

    function confirmDelete() {
        if (contentIdToDelete) {
            document.getElementById('deleteForm').submit();
        }
    }

    // Cerrar modal al hacer click fuera
    document.addEventListener('click', function(e) {
        const modal = document.getElementById('deleteModal');
        if (e.target === modal) {
            hideDeleteModal();
        }
    });

    // Cerrar modal con Escape
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            hideDeleteModal();
        }
    });
</script>
