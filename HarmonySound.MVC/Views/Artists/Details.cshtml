@model HarmonySound.Models.Content

@{
    ViewData["Title"] = "Detalles de la Canción";
}

<div class="details-container">
    <div class="details-header">
        <!-- Navegación -->
        <div class="navigation-bar">
            <a href="@Url.Action("Index", "Artists")" class="btn-back">
                <i class="fas fa-arrow-left me-2"></i>
                Volver a Mis Canciones
            </a>
        </div>

        <h1 class="details-title">
            <i class="fas fa-info-circle me-3"></i>
            Detalles de la Canción
        </h1>
    </div>

    <div class="details-content">
        <div class="song-showcase">
            <div class="song-cover-large">
                <div class="cover-placeholder-large">
                    <i class="fas fa-music"></i>
                </div>
                <div class="play-overlay">
                    <button class="play-large-btn play-in-player-btn"
                            data-content-id="@Model.Id"
                            data-title="@Model.Title"
                            data-artist="@ViewBag.ArtistName"
                            data-url="@Model.UrlMedia"
                            title="Reproducir">
                        <i class="fas fa-play"></i>
                    </button>
                </div>
            </div>

            <div class="song-info">
                <h2 class="song-title-large">@Model.Title</h2>
                <p class="song-artist-large">@ViewBag.ArtistName</p>
                <span class="song-type-badge">@Model.Type</span>
            </div>
        </div>

        <div class="song-details-grid">
            <div class="detail-card">
                <div class="detail-icon">
                    <i class="fas fa-clock"></i>
                </div>
                <div class="detail-info">
                    <h3>Duración</h3>
                    <p>@(Model.Duration.TotalSeconds > 0 ? Model.Duration.ToString(@"mm\:ss") : "No disponible")</p>
                </div>
            </div>

            <div class="detail-card">
                <div class="detail-icon">
                    <i class="fas fa-calendar-alt"></i>
                </div>
                <div class="detail-info">
                    <h3>Fecha de Subida</h3>
                    <p>@Model.UploadDate.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
            </div>

            <div class="detail-card">
                <div class="detail-icon">
                    <i class="fas fa-file-audio"></i>
                </div>
                <div class="detail-info">
                    <h3>Tipo de Contenido</h3>
                    <p>@Model.Type</p>
                </div>
            </div>

            <!--  Tarjeta con nombre del artista -->
            <div class="detail-card">
                <div class="detail-icon">
                    <i class="fas fa-user"></i>
                </div>
                <div class="detail-info">
                    <h3>Artista</h3>
                    <p>@ViewBag.ArtistName</p>
                </div>
            </div>
        </div>

        <div class="action-buttons">
            <a href="@Url.Action("Edit", "Artists", new { id = Model.Id })" class="btn-action btn-edit">
                <i class="fas fa-edit me-2"></i>
                Editar Canción
            </a>

            <!-- Botón de eliminar con modal -->
            <button type="button" class="btn-action btn-delete" onclick="showDeleteModal(@Model.Id, '@Model.Title')">
                <i class="fas fa-trash-alt me-2"></i>
                Eliminar Canción
            </button>
        </div>
    </div>
</div>

<!--  Modal de confirmación para eliminar -->
<div id="deleteModal" class="modal-overlay d-none">
    <div class="modal-container">
        <div class="modal-header">
            <div class="modal-icon">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <h3 class="modal-title">Confirmar Eliminación</h3>
        </div>
        
        <div class="modal-body">
            <p class="modal-message">¿Estás seguro de que quieres eliminar la canción <strong id="songToDelete"></strong>?</p>
            <div class="modal-warning">
                <i class="fas fa-info-circle"></i>
                <span>Esta acción eliminará el archivo de Azure Storage y no se puede deshacer.</span>
            </div>
        </div>
        
        <div class="modal-actions">
            <button type="button" class="btn-modal btn-cancel" onclick="hideDeleteModal()">
                <i class="fas fa-times me-2"></i>
                Cancelar
            </button>
            <button type="button" class="btn-modal btn-confirm" onclick="confirmDelete()">
                <i class="fas fa-trash-alt me-2"></i>
                Eliminar Canción
            </button>
        </div>
    </div>
</div>

<!-- Formulario oculto para eliminar -->
<form id="deleteForm" asp-action="Delete" asp-controller="Artists" method="post" style="display: none;">
    <input type="hidden" id="contentIdToDelete" name="id" value="" />
</form>
@await Html.PartialAsync("_PlayerBar")
