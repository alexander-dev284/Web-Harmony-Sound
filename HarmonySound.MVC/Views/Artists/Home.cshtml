@model HarmonySound.MVC.Models.ProfileEditViewModel

@{
    ViewData["Title"] = "Bienvenido Artista";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="artist-dashboard">
    <!-- Header con información del artista -->
    <div class="dashboard-header">
        <!-- Botón de cerrar sesión elegante -->
        <div class="logout-section">
            <form asp-action="Logout" asp-controller="Account" method="post" class="logout-form">
                <button type="submit" class="btn-logout">
                    <i class="fas fa-sign-out-alt me-2"></i>
                    Cerrar Sesión
                </button>
            </form>
        </div>

        <!-- Hero Section -->
        <div class="hero-section">
            <div class="artist-profile">
                <div class="profile-image-container">
                    @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
                    {
                        <img src="@Model.ProfileImageUrl" alt="Profile Image" class="profile-image" />
                    }
                    else
                    {
                        <img src="~/images/default-profile.png" alt="Profile Image" class="profile-image" />
                    }
                    <div class="profile-overlay">
                        <i class="fas fa-camera"></i>
                    </div>
                </div>
                
                <div class="artist-info">
                    <span class="artist-badge">
                        <i class="fas fa-microphone-alt me-2"></i>
                        Artista
                    </span>
                    <h1 class="artist-name">Bienvenido, @Model.Name!</h1>
                    <p class="artist-bio">@(!string.IsNullOrEmpty(Model.Biography) ? Model.Biography : "Comparte tu música con el mundo")</p>
                    <p class="artist-email">@Model.Email</p>
                    <div class="followers-badge">
                        <i class="fas fa-users me-2"></i>
                        <strong>@(ViewBag.FollowersCount ?? 0)</strong>
                        <span>seguidor@((ViewBag.FollowersCount ?? 0) == 1 ? "" : "es")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Mensajes de estado -->
    @if (ViewBag.Success != null)
    {
        <div class="alert alert-success">
            <i class="fas fa-check-circle me-2"></i>
            @ViewBag.Success
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-circle me-2"></i>
            @TempData["Error"]
        </div>
    }

    <!-- Dashboard Principal -->
    <div class="dashboard-content">
        <!-- Sección de acciones rápidas -->
        <div class="quick-actions-section">
            <h2 class="section-title">
                <i class="fas fa-bolt me-2"></i>
                Acciones Rápidas
            </h2>
            
            <div class="quick-actions-grid">
                <!-- Editar Perfil -->
                <a href="@Url.Action("EditProfile", "Artists")" class="action-card profile-card">
                    <div class="card-icon">
                        <i class="fas fa-user-edit"></i>
                    </div>
                    <div class="card-content">
                        <h3>Editar Perfil</h3>
                        <p>Actualiza tu información personal</p>
                    </div>
                    <div class="card-arrow">
                        <i class="fas fa-arrow-right"></i>
                    </div>
                </a>

                <!-- Subir Contenido -->
                <a href="@Url.Action("Upload", "Artists")" class="action-card upload-card">
                    <div class="card-icon">
                        <i class="fas fa-upload"></i>
                    </div>
                    <div class="card-content">
                        <h3>Subir Contenido</h3>
                        <p>Comparte tu nueva música</p>
                    </div>
                    <div class="card-arrow">
                        <i class="fas fa-arrow-right"></i>
                    </div>
                </a>
            </div>
        </div>

        <!-- Sección de gestión de contenido -->
        <div class="content-management-section">
            <h2 class="section-title">
                <i class="fas fa-folder-open me-2"></i>
                Gestionar Contenido
            </h2>
            
            <div class="management-grid">
                <!-- Mis Canciones -->
                <a href="@Url.Action("Index", "Artists")" class="management-card songs-card">
                    <div class="card-background">
                        <i class="fas fa-music"></i>
                    </div>
                    <div class="card-overlay">
                        <div class="card-info">
                            <h3>Mis Canciones</h3>
                            <p>Administra tu biblioteca musical</p>
                            <span class="card-badge">
                                <i class="fas fa-headphones me-1"></i>
                                Audio
                            </span>
                        </div>
                        <div class="card-action">
                            <i class="fas fa-play"></i>
                        </div>
                    </div>
                </a>

                <!-- Mis Álbumes -->
                <a href="@Url.Action("Index", "Albums")" class="management-card albums-card">
                    <div class="card-background">
                        <i class="fas fa-compact-disc"></i>
                    </div>
                    <div class="card-overlay">
                        <div class="card-info">
                            <h3>Mis Álbumes</h3>
                            <p>Organiza tus colecciones</p>
                            <span class="card-badge">
                                <i class="fas fa-layer-group me-1"></i>
                                Colecciones
                            </span>
                        </div>
                        <div class="card-action">
                            <i class="fas fa-plus"></i>
                        </div>
                    </div>
                </a>
            </div>
        </div>

        <!-- Estadísticas rápidas -->
        <div class="stats-section">
            <h2 class="section-title">
                <i class="fas fa-chart-line me-2"></i>
                Tu Actividad
            </h2>
            
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-music"></i>
                    </div>
                    <div class="stat-info">
                        <h4>Total Canciones</h4>
                        <span class="stat-number" id="total-songs">--</span>
                    </div>
                </div>
                
                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-compact-disc"></i>
                    </div>
                    <div class="stat-info">
                        <h4>Álbumes</h4>
                        <span class="stat-number" id="total-albums">--</span>
                    </div>
                </div>
                
                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-clock"></i>
                    </div>
                    <div class="stat-info">
                        <h4>Última Subida</h4>
                        <span class="stat-text" id="last-upload">--</span>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-heart"></i>
                    </div>
                    <div class="stat-info">
                        <h4>Likes Totales</h4>
                        <span class="stat-number" id="total-likes">--</span>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-play-circle"></i>
                    </div>
                    <div class="stat-info">
                        <h4>Reproducciones</h4>
                        <span class="stat-number" id="total-reproductions">--</span>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <div class="stat-info">
                        <h4>Seguidores</h4>
                        <span class="stat-number">@(ViewBag.FollowersCount ?? 0)</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Rendimiento: top canciones y gráfico -->
        <div class="performance-section">
            <h2 class="section-title">
                <i class="fas fa-chart-bar me-2"></i>
                Rendimiento de tus canciones
            </h2>

            <div class="performance-grid">
                <div class="performance-panel">
                    <h3><i class="fas fa-trophy me-2"></i>Top canciones por likes</h3>
                    <div id="top-songs-list" class="top-songs-list">
                        <p class="loading-text">Cargando...</p>
                    </div>
                </div>
                <div class="performance-panel">
                    <h3><i class="fas fa-chart-bar me-2"></i>Likes por canción</h3>
                    <div class="chart-wrapper">
                        <canvas id="topSongsChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Últimos en seguir -->
        <div class="followers-section">
            <h2 class="section-title">
                <i class="fas fa-user-friends me-2"></i>
                Últimos en seguir
            </h2>

            @{
                var recentFollowers = ViewBag.RecentFollowers as List<HarmonySound.MVC.Models.FollowerViewModel>;
            }
            @if (recentFollowers != null && recentFollowers.Any())
            {
                <div class="followers-list">
                    @foreach (var f in recentFollowers)
                    {
                        <div class="follower-card">
                            <div class="follower-avatar">
                                @if (!string.IsNullOrEmpty(f.ProfileImageUrl))
                                {
                                    <img src="@f.ProfileImageUrl" alt="@f.Name" />
                                }
                                else
                                {
                                    <div class="follower-avatar-placeholder"><i class="fas fa-user"></i></div>
                                }
                            </div>
                            <div class="follower-info">
                                <span class="follower-name">@f.Name</span>
                                <span class="follower-date">@f.FollowDate.ToLocalTime().ToString("dd/MM/yyyy")</span>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="no-followers-text">
                    <i class="fas fa-info-circle me-2"></i>
                    Aún no tienes seguidores. ¡Comparte tu música para conseguir los primeros!
                </p>
            }
        </div>
    </div>
</div>

<style>
    /* Reset base */
    .container {
        max-width: none !important;
        padding: 0 !important;
    }

    body {
        background: linear-gradient(135deg, var(--us-surface), var(--us-surface)) !important;
        color: var(--us-ink) !important;
        font-family: var(--us-font) !important;
        margin: 0;
        padding: 0;
        min-height: 100vh;
    }

    /* Dashboard principal */
    .artist-dashboard {
        min-height: 100vh;
        position: relative;
    }

    /* Header del dashboard */
    .dashboard-header {
        position: relative;
        background: linear-gradient(135deg, var(--us-surface-alt) 0%, var(--us-surface-2) 50%, var(--us-surface-alt) 100%);
        padding: 2rem 0;
        margin-bottom: 3rem;
    }

    .dashboard-header::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="grain" width="100" height="100" patternUnits="userSpaceOnUse"><circle cx="25" cy="25" r="1" fill="%23ffffff" opacity="0.02"/><circle cx="75" cy="75" r="1" fill="%23ffffff" opacity="0.02"/><circle cx="50" cy="10" r="1" fill="%23ffffff" opacity="0.02"/><circle cx="10" cy="60" r="1" fill="%23ffffff" opacity="0.02"/><circle cx="90" cy="40" r="1" fill="%23ffffff" opacity="0.02"/></pattern></defs><rect width="100" height="100" fill="url(%23grain)"/></svg>');
        opacity: 0.3;
        z-index: 1;
    }

    /* Botón de logout elegante */
    .logout-section {
        position: absolute;
        top: 2rem;
        right: 2rem;
        z-index: 10;
    }

    .logout-form {
        margin: 0;
        padding: 0;
    }

    .btn-logout {
        background: linear-gradient(135deg, #c8102e, #c8102e);
        color: #ffffff !important;
        border: 1px solid rgba(220, 38, 38, 0.5);
        padding: 10px 20px;
        border-radius: 25px;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(220, 38, 38, 0.3);
        font-size: 0.9rem;
        text-decoration: none;
        backdrop-filter: blur(10px);
    }

    .btn-logout:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(220, 38, 38, 0.5);
        background: linear-gradient(135deg, #c8102e, #c8102e);
        border-color: #c8102e;
        color: #ffffff !important;
    }

    /* Hero section */
    .hero-section {
        position: relative;
        z-index: 2;
        max-width: 1200px;
        margin: 0 auto;
        padding: 4rem 2rem;
    }

    .artist-profile {
        display: flex;
        align-items: center;
        gap: 3rem;
        flex-wrap: wrap;
    }

    .profile-image-container {
        position: relative;
        flex-shrink: 0;
    }

    .profile-image {
        width: 200px;
        height: 200px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid #c8102e;
        box-shadow: 0 8px 32px rgba(200, 16, 46, 0.3);
        transition: all 0.3s ease;
    }

    .profile-image:hover {
        transform: scale(1.05);
        box-shadow: 0 12px 40px rgba(200, 16, 46, 0.4);
    }

    .profile-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.6);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s ease;
        color: #c8102e;
        font-size: 2rem;
    }

    .profile-image-container:hover .profile-overlay {
        opacity: 1;
    }

    .artist-info {
        flex: 1;
        min-width: 300px;
    }

    .artist-badge {
        display: inline-flex;
        align-items: center;
        background: linear-gradient(135deg, #c8102e, #a30d25);
        color: #ffffff;
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 1rem;
    }

    .artist-name {
        font-size: 3rem;
        font-weight: 700;
        margin-bottom: 1rem;
        color: var(--us-ink);
        line-height: 1.2;
    }

    .artist-bio {
        font-size: 1.2rem;
        color: var(--us-ink-soft);
        margin-bottom: 1rem;
        line-height: 1.6;
        max-width: 600px;
    }

    .artist-email {
        color: var(--us-ink-faint);
        font-size: 1rem;
        font-style: italic;
    }

    .followers-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        margin-top: 0.75rem;
        padding: 0.45rem 1rem;
        background: rgba(200, 16, 46, 0.12);
        border: 1px solid rgba(200, 16, 46, 0.35);
        border-radius: 20px;
        color: var(--us-ink);
        font-size: 0.95rem;
    }

    .followers-badge strong {
        font-size: 1.05rem;
        color: #c8102e;
    }

    /* Sección "Últimos en seguir" */
    .followers-section {
        margin-top: 3rem;
    }

    .followers-list {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 1rem;
        margin-top: 1.5rem;
    }

    .follower-card {
        display: flex;
        align-items: center;
        gap: 1rem;
        background: var(--us-surface-alt);
        border: 1px solid var(--us-surface-2);
        border-radius: 12px;
        padding: 1rem;
        transition: all 0.25s ease;
    }

    .follower-card:hover {
        border-color: #c8102e;
        transform: translateY(-3px);
    }

    .follower-avatar img,
    .follower-avatar-placeholder {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
    }

    .follower-avatar-placeholder {
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--us-surface-2);
        color: #c8102e;
    }

    .follower-info {
        display: flex;
        flex-direction: column;
    }

    .follower-name {
        font-weight: 600;
        color: var(--us-ink);
    }

    .follower-date {
        font-size: 0.85rem;
        color: var(--us-ink-faint);
    }

    .no-followers-text {
        color: var(--us-ink-faint);
        font-style: italic;
        margin-top: 1.5rem;
    }

    /* Contenido del dashboard */
    .dashboard-content {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem 4rem;
    }

    .section-title {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 2rem;
        color: var(--us-ink);
        display: flex;
        align-items: center;
    }

    /* Acciones rápidas */
    .quick-actions-section {
        margin-bottom: 4rem;
    }

    .quick-actions-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
    }

    .action-card {
        background: linear-gradient(135deg, var(--us-surface-alt), var(--us-surface-2));
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
        padding: 2rem;
        display: flex;
        align-items: center;
        gap: 1.5rem;
        text-decoration: none;
        color: var(--us-ink);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .action-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(200, 16, 46, 0.1), transparent);
        transition: left 0.5s ease;
    }

    .action-card:hover::before {
        left: 100%;
    }

    .action-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);
        border-color: rgba(200, 16, 46, 0.5);
        color: var(--us-ink);
    }

    .card-icon {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #c8102e, #a30d25);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: #ffffff;
        flex-shrink: 0;
    }

    .card-content {
        flex: 1;
    }

    .card-content h3 {
        font-size: 1.3rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: var(--us-ink);
    }

    .card-content p {
        color: var(--us-ink-soft);
        margin: 0;
        font-size: 0.95rem;
    }

    .card-arrow {
        font-size: 1.2rem;
        color: var(--us-ink-soft);
        transition: transform 0.3s ease;
    }

    .action-card:hover .card-arrow {
        transform: translateX(5px);
        color: #c8102e;
    }

    /* Gestión de contenido */
    .content-management-section {
        margin-bottom: 4rem;
    }

    .management-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2rem;
    }

    .management-card {
        position: relative;
        height: 200px;
        border-radius: 16px;
        overflow: hidden;
        text-decoration: none;
        transition: all 0.3s ease;
        background: linear-gradient(135deg, var(--us-surface-alt), var(--us-surface-2));
    }

    .management-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);
    }

    .card-background {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
        color: rgba(255, 255, 255, 0.1);
        transition: all 0.3s ease;
    }

    .card-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(135deg, rgba(0, 0, 0, 0.8), rgba(0, 0, 0, 0.4));
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 1.5rem;
        color: var(--us-ink);
    }

    .card-info h3 {
        font-size: 1.4rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        color: var(--us-ink);
    }

    .card-info p {
        color: var(--us-ink-soft);
        margin-bottom: 1rem;
        font-size: 0.95rem;
    }

    .card-badge {
        display: inline-flex;
        align-items: center;
        background: rgba(200, 16, 46, 0.2);
        color: #c8102e;
        padding: 4px 12px;
        border-radius: 12px;
        font-size: 0.8rem;
        font-weight: 600;
        border: 1px solid rgba(200, 16, 46, 0.3);
    }

    .card-action {
        align-self: flex-end;
        width: 50px;
        height: 50px;
        background: rgba(200, 16, 46, 0.2);
        border: 1px solid rgba(200, 16, 46, 0.3);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #c8102e;
        font-size: 1.2rem;
        transition: all 0.3s ease;
    }

    .management-card:hover .card-action {
        background: #c8102e;
        color: #ffffff;
        transform: scale(1.1);
    }

    /* Estadísticas */
    .stats-section {
        margin-bottom: 4rem;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
    }

    .stat-card {
        background: linear-gradient(135deg, var(--us-surface-alt), var(--us-surface-2));
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 1.5rem;
        text-align: center;
        transition: all 0.3s ease;
    }

    .stat-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
        border-color: rgba(200, 16, 46, 0.3);
    }

    .stat-icon {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, #c8102e, #a30d25);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        color: #ffffff;
        margin: 0 auto 1rem;
    }

    .stat-info h4 {
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: var(--us-ink-soft);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .stat-number {
        font-size: 2rem;
        font-weight: 700;
        color: var(--us-ink);
        font-variant-numeric: tabular-nums;
    }

    .stat-text {
        font-size: 1rem;
        font-weight: 600;
        color: var(--us-ink);
    }

    /* Alertas */
    .alert {
        border-radius: 8px;
        border: none;
        margin-bottom: 1.5rem;
        padding: 1rem;
        display: flex;
        align-items: center;
    }

    .alert-success {
        background: rgba(200, 16, 46, 0.1);
        color: #c8102e;
        border: 1px solid rgba(200, 16, 46, 0.3);
    }

    .alert-danger {
        background: rgba(200, 16, 46, 0.1);
        color: #c8102e;
        border: 1px solid rgba(200, 16, 46, 0.3);
    }


    /* Ocultar elementos del layout principal */
    header, footer {
        display: none !important;
    }

    /* Rendimiento */
    .performance-section {
        margin-bottom: 4rem;
    }

    .performance-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 2rem;
    }

    .performance-panel {
        background: linear-gradient(135deg, var(--us-surface-alt), var(--us-surface-2));
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
        padding: 1.75rem;
    }

    .performance-panel h3 {
        font-size: 1.15rem;
        font-weight: 600;
        margin: 0 0 1.5rem 0;
        color: var(--us-ink);
        display: flex;
        align-items: center;
    }

    .performance-panel h3 i { color: #c8102e; }

    .chart-wrapper {
        position: relative;
        height: 280px;
    }

    .top-songs-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .top-song-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.75rem 1rem;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 10px;
        border: 1px solid transparent;
        transition: all 0.3s ease;
    }

    .top-song-row:hover {
        border-color: rgba(200, 16, 46, 0.4);
        background: rgba(200, 16, 46, 0.06);
    }

    .top-song-rank {
        width: 28px;
        height: 28px;
        flex-shrink: 0;
        border-radius: 50%;
        background: linear-gradient(135deg, #c8102e, #a30d25);
        color: #ffffff;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
    }

    .top-song-title {
        flex: 1;
        color: var(--us-ink);
        font-weight: 500;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .top-song-likes {
        color: var(--us-ink);
        font-weight: 600;
        font-variant-numeric: tabular-nums;
    }

    .top-song-likes i { margin-right: 4px; color: #c8102e; }

    .loading-text, .empty-text {
        color: var(--us-ink-soft);
        font-style: italic;
    }

    /* FontAwesome */
    .fas {
        font-family: "Font Awesome 5 Free" !important;
        font-weight: 900 !important;
    }
</style>

<!-- FontAwesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

<script>
    // ===== ARTIST DASHBOARD =====

    class ArtistDashboard {
        constructor() {
            this.init();
        }

        init() {
            console.log('Inicializando Dashboard del Artista...');
            
            this.setupAnimations();
            this.loadArtistStats();
            this.setupEventListeners();
            
            console.log('Dashboard del artista inicializado correctamente');
        }

        setupAnimations() {
            // Animación de entrada para las tarjetas
            const observerOptions = {
                threshold: 0.1,
                rootMargin: '0px 0px -50px 0px'
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.style.opacity = '1';
                        entry.target.style.transform = 'translateY(0)';
                    }
                });
            }, observerOptions);

            // Aplicar animaciones a las tarjetas
            document.querySelectorAll('.action-card, .management-card, .stat-card').forEach((card, index) => {
                card.style.opacity = '0';
                card.style.transform = 'translateY(30px)';
                card.style.transition = `opacity 0.6s ease ${index * 0.1}s, transform 0.6s ease ${index * 0.1}s`;
                observer.observe(card);
            });
        }

        setupEventListeners() {
            // Efecto parallax sutil en el hero
            window.addEventListener('scroll', () => {
                const scrolled = window.pageYOffset;
                const hero = document.querySelector('.hero-section');
                if (hero) {
                    hero.style.transform = `translateY(${scrolled * 0.3}px)`;
                }
            });
        }

        // Función para cargar estadísticas del artista
        async loadArtistStats() {
            try {
                console.log('Cargando estadísticas del artista...');
                
                const response = await fetch('/Artists/GetArtistStats');
                if (response.ok) {
                    const stats = await response.json();
                    
                    console.log('Estadísticas recibidas:', stats);
                    
                    // Actualizar los elementos con animación
                    this.updateStatWithAnimation('total-songs', stats.totalSongs);
                    this.updateStatWithAnimation('total-albums', stats.totalAlbums);
                    this.updateStatWithAnimation('total-likes', stats.totalLikes);
                    this.updateStatWithAnimation('total-reproductions', stats.totalReproductions || 0);
                    this.updateStatText('last-upload', stats.lastUpload);

                    // Desenvuelve por si la API devuelve {$values:[...]} (ReferenceHandler.Preserve)
                    const topSongs = this.unwrap(stats.topSongs);

                    // El render del rendimiento va en su propio try para que un fallo aquí
                    // no marque todas las métricas como "Error".
                    try {
                        this.renderTopSongs(topSongs);
                        this.renderTopSongsChart(topSongs);
                    } catch (renderErr) {
                        console.error('Error al renderizar el rendimiento:', renderErr);
                    }

                    console.log('Estadísticas actualizadas correctamente');
                } else {
                    console.error(' Error al cargar estadísticas:', response.status);
                    this.showErrorStats();
                }
            } catch (error) {
                console.error(' Error al cargar estadísticas:', error);
                this.showErrorStats();
            }
        }

        // Función para actualizar estadística con animación
        updateStatWithAnimation(elementId, value) {
            const element = document.getElementById(elementId);
            if (!element) return;
            
            // Animación de contador
            let current = 0;
            const increment = value / 30; // 30 frames de animación
            const timer = setInterval(() => {
                current += increment;
                if (current >= value) {
                    current = value;
                    clearInterval(timer);
                }
                element.textContent = Math.floor(current).toLocaleString();
            }, 50);
        }

        // Función para actualizar texto simple
        updateStatText(elementId, text) {
            const element = document.getElementById(elementId);
            if (!element) return;
            
            // Efecto de fade
            element.style.opacity = '0.5';
            setTimeout(() => {
                element.textContent = text;
                element.style.opacity = '1';
            }, 200);
        }

        // Renderiza la lista de top canciones
        renderTopSongs(topSongs) {
            const container = document.getElementById('top-songs-list');
            if (!container) return;

            if (!topSongs || topSongs.length === 0) {
                container.innerHTML = '<p class="empty-text">Aún no tienes canciones con likes.</p>';
                return;
            }

            container.innerHTML = topSongs.map((song, i) => `
                <div class="top-song-row">
                    <div class="top-song-rank">${i + 1}</div>
                    <div class="top-song-title">${this.escapeHtml(song.title)}</div>
                    <div class="top-song-likes"><i class="fas fa-heart"></i>${song.likes}</div>
                </div>
            `).join('');
        }

        // Renderiza el gráfico de barras de likes por canción
        renderTopSongsChart(topSongs) {
            const canvas = document.getElementById('topSongsChart');
            if (!canvas || typeof Chart === 'undefined') return;

            if (this._chart) { this._chart.destroy(); }

            // Oscuro por defecto, salvo que el sistema pida claro explícito
            const isLightTheme = window.matchMedia('(prefers-color-scheme: light)').matches;
            const chartTextColor = isLightTheme ? '#374151' : '#cbd5e1';
            const chartGridColor = isLightTheme ? 'rgba(0,0,0,0.06)' : 'rgba(255,255,255,0.08)';

            if (!topSongs || topSongs.length === 0) {
                const ctx = canvas.getContext('2d');
                ctx.font = '14px Segoe UI';
                ctx.fillStyle = chartTextColor;
                ctx.textAlign = 'center';
                ctx.fillText('Sin datos disponibles', canvas.width / 2, canvas.height / 2);
                return;
            }

            Chart.defaults.color = chartTextColor;
            this._chart = new Chart(canvas, {
                type: 'bar',
                data: {
                    labels: topSongs.map(s => s.title),
                    datasets: [{
                        label: 'Me gusta',
                        data: topSongs.map(s => s.likes),
                        backgroundColor: 'rgba(200, 16, 46, 0.7)',
                        borderColor: '#c8102e',
                        borderWidth: 1,
                        borderRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, ticks: { precision: 0 }, grid: { color: chartGridColor } },
                        x: { grid: { display: false } }
                    }
                }
            });
        }

        // Normaliza un posible {$values:[...]} (ReferenceHandler.Preserve) a un arreglo plano.
        unwrap(value) {
            if (Array.isArray(value)) return value;
            if (value && Array.isArray(value.$values)) return value.$values;
            return [];
        }

        escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text == null ? '' : text;
            return div.innerHTML;
        }

        // Función para mostrar error en estadísticas
        showErrorStats() {
            this.updateStatText('total-songs', 'Error');
            this.updateStatText('total-albums', 'Error');
            this.updateStatText('total-likes', 'Error');
            this.updateStatText('total-reproductions', 'Error');
            this.updateStatText('last-upload', 'Error');
        }

        // Función para recargar estadísticas (útil después de subir contenido)
        refreshStats() {
            this.loadArtistStats();
        }
    }

    // Función global para recargar estadísticas
    window.refreshArtistStats = function() {
        if (window.artistDashboard) {
            window.artistDashboard.refreshStats();
        }
    };

    // Inicializar cuando se carga el DOM
    document.addEventListener('DOMContentLoaded', () => {
        window.artistDashboard = new ArtistDashboard();
    });
</script>
