    }

    .profile-image:hover {
        transform: scale(1.05);
        box-shadow: 0 12px 40px rgba(29, 185, 84, 0.4);
    }

    .profile-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.6);
        border-radius: 50%;
        display: flex;
