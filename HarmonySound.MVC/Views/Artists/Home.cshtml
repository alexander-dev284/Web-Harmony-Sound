        letter-spacing: 0.5px;
        margin-bottom: 1rem;
    }

    .artist-name {
        font-size: 3rem;
        font-weight: 700;
        margin-bottom: 1rem;
        background: linear-gradient(135deg, #fff, #b3b3b3);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        line-height: 1.2;
    }

    .artist-bio {
        font-size: 1.2rem;
        color: #b3b3b3;
        margin-bottom: 1rem;
        line-height: 1.6;
        max-width: 600px;
    }

    .artist-email {
        color: #777;
        font-size: 1rem;
        font-style: italic;
    }

    /* Contenido del dashboard */
    .dashboard-content {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem 4rem;
    }

    .section-title {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 2rem;
        color: #fff;
        display: flex;
        align-items: center;
    }

    /* Acciones rápidas */
    .quick-actions-section {
        margin-bottom: 4rem;
    }

    .quick-actions-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
    }

    .action-card {
