        text-align: center;
        transition: all 0.3s ease;
    }

    .stat-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
        border-color: rgba(29, 185, 84, 0.3);
    }

    .stat-icon {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, #1db954, #1ed760);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        color: #000;
        margin: 0 auto 1rem;
    }

    .stat-info h4 {
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: #b3b3b3;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .stat-number {
        font-size: 2rem;
        font-weight: 700;
        color: #fff;
        font-variant-numeric: tabular-nums;
    }

    .stat-text {
        font-size: 1rem;
        font-weight: 600;
        color: #fff;
    }

    /* Alertas */
    .alert {
        border-radius: 8px;
        border: none;
        margin-bottom: 1.5rem;
        padding: 1rem;
        display: flex;
        align-items: center;
    }

    .alert-success {
        background: rgba(29, 185, 84, 0.1);
        color: #1db954;
        border: 1px solid rgba(29, 185, 84, 0.3);
    }

    .alert-danger {
        background: rgba(220, 53, 69, 0.1);
        color: #dc3545;
        border: 1px solid rgba(220, 53, 69, 0.3);
