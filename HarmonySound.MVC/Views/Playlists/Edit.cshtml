@model HarmonySound.MVC.Models.PlaylistDto

@{
    ViewData["Title"] = "Editar Playlist";
}

<div class="edit-playlist-container">
    <!-- Header con navegación -->
    <div class="edit-header">
        <div class="navigation-bar">
            <a href="@Url.Action("Details", "Playlists", new { id = Model.Id })" class="btn-back">
                <i class="fas fa-arrow-left me-2"></i>
                Volver a Detalles
            </a>
        </div>

        <h1 class="edit-title">
            <i class="fas fa-edit me-3"></i>
            Editar Playlist
        </h1>
        <p class="edit-subtitle">Modifica el nombre de tu playlist</p>
    </div>

    <div class="edit-content">
        <form asp-action="Edit" method="post" class="edit-form" id="playlistEditForm" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            
            <!-- Mostrar errores de validación -->
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    @TempData["Error"]
                </div>
            }

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    <i class="fas fa-check-circle me-2"></i>
                    @TempData["Success"]
                </div>
            }

            <!-- Sección de edición del nombre -->
            <div class="form-section">
                <h3 class="section-title">
                    <i class="fas fa-list-music me-2"></i>
                    Información de la Playlist
                </h3>

                <div class="form-group">
                    <label asp-for="Name" class="form-label">
                        <i class="fas fa-signature me-2"></i>
                        Nombre de la Playlist
                    </label>
                    <input asp-for="Name" 
                           class="form-control" 
                           maxlength="50" 
                           required 
                           placeholder="Ingresa el nombre de tu playlist"
                           id="playlist-name-input" />
                    <span asp-validation-for="Name" class="validation-error"></span>
                    <small class="form-text">Máximo 50 caracteres. Elige un nombre memorable.</small>
                </div>

                <!-- Contador de caracteres -->
                <div class="character-counter">
                    <span id="char-count">@(Model.Name?.Length ?? 0)</span> / 50 caracteres
                </div>
            </div>

            <!-- Vista previa -->
            <div class="form-section">
                <h3 class="section-title">
                    <i class="fas fa-eye me-2"></i>
                    Vista Previa
                </h3>

                <div class="preview-card">
                    <div class="preview-cover">
                        <div class="cover-placeholder">
                            <i class="fas fa-list-music"></i>
                        </div>
                    </div>
                    <div class="preview-info">
                        <h4 class="preview-title" id="preview-title">@Model.Name</h4>
                        <p class="preview-creator">Mi Playlist</p>
                        <div class="preview-metadata">
                            <span class="preview-type">
                                <i class="fas fa-list-music me-1"></i>
                                Playlist
                            </span>
                            <span class="preview-count">@(Model.Songs?.Count ?? 0) canción(es)</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Información de las canciones -->
            <div class="form-section">
                <h3 class="section-title">
                    <i class="fas fa-music me-2"></i>
                    Canciones en la Playlist
                </h3>

                @if (Model.Songs?.Any() == true)
                {
                    <div class="songs-info">
                        <div class="songs-count-badge">
                            <i class="fas fa-music me-2"></i>
                            @Model.Songs.Count canción(es) en esta playlist
                        </div>
                        
                        <div class="songs-list-preview">
                            @foreach (var song in Model.Songs.Take(3))
                            {
                                <div class="song-preview-item">
                                    <div class="song-icon">
                                        <i class="fas fa-music"></i>
                                    </div>
                                    <div class="song-details">
                                        <span class="song-title">@song.Title</span>
                                        <span class="song-artist">@song.ArtistName</span>
                                    </div>
                                </div>
                            }
                            
                            @if (Model.Songs.Count > 3)
                            {
                                <div class="song-preview-item more-songs">
                                    <div class="song-icon">
                                        <i class="fas fa-ellipsis-h"></i>
                                    </div>
                                    <div class="song-details">
                                        <span class="song-title">Y @(Model.Songs.Count - 3) canción(es) más</span>
                                    </div>
                                </div>
                            }
                        </div>
                        
                        <div class="songs-note">
                            <i class="fas fa-info-circle me-2"></i>
                            Para agregar varias canciones a la vez, entra a los detalles de la playlist y usa el botón "Añadir canciones".
                        </div>
                    </div>
                }
                else
                {
                    <div class="empty-songs">
                        <div class="empty-icon">
                            <i class="fas fa-list-music"></i>
                        </div>
                        <h4>Esta playlist está vacía</h4>
                        <p>Añade canciones desde la vista de detalles o explora música nueva.</p>
                        <a href="@Url.Action("Index", "Clients")" class="btn-explore">
                            <i class="fas fa-search me-2"></i>
                            Explorar Música
                        </a>
                    </div>
                }
            </div>

            <div class="form-group">
                <label class="form-label">
                    <i class="fas fa-image me-2"></i>
                    Imagen de la Playlist (Opcional)
                </label>
                <!-- Mostrar imagen actual si existe -->
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="current-image-preview">
                        <img src="@Model.ImageUrl" alt="Imagen actual" style="width: 100px; height: 100px; object-fit: cover; border-radius: 8px; margin-bottom: 1rem;" />
                        <p style="color: var(--us-ink-soft); font-size: 0.9rem;">Imagen actual</p>
                    </div>
                }
                <input type="file" name="imageFile" accept="image/*" class="form-control" />
                <small class="form-text">Sube una nueva imagen para cambiar la actual. Formatos soportados: JPG, PNG, GIF, WebP (máx. 5MB)</small>
            </div>

            <!-- Acciones del formulario -->
            <div class="form-actions">
                <button type="submit" class="btn-save">
                    <i class="fas fa-save me-2"></i>
                    Guardar Cambios
                </button>
                <a href="@Url.Action("Details", "Playlists", new { id = Model.Id })" class="btn-details">
                    <i class="fas fa-eye me-2"></i>
                    Ver Detalles
                </a>
                <a href="@Url.Action("Index", "Playlists")" class="btn-cancel">
                    <i class="fas fa-times me-2"></i>
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

<style>
    /* Reset base */
    .container {
        max-width: none !important;
        padding: 0 !important;
    }

    body {
        background: var(--us-surface) !important;
        color: var(--us-ink) !important;
        font-family: var(--us-font) !important;
        margin: 0;
        padding: 0;
        min-height: 100vh;
    }

    /* Contenedor principal */
    .edit-playlist-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem;
        min-height: 100vh;
        position: relative;
    }

    /* Header */
