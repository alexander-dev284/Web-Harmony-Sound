</style>

<!-- FontAwesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Animación de entrada para las tarjetas
        const cards = document.querySelectorAll('.playlist-card');
        cards.forEach((card, index) => {
            card.style.opacity = '0';
            card.style.transform = 'translateY(20px)';

            setTimeout(() => {
                card.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
                card.style.opacity = '1';
                card.style.transform = 'translateY(0)';
            }, index * 100);
        });

        // Mejorar UX de los formularios
        const addForms = document.querySelectorAll('.add-form');
        addForms.forEach(form => {
            form.addEventListener('submit', function(e) {
                const button = this.querySelector('.btn-add');
                button.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Agregando...';
                button.disabled = true;
            });
        });

        console.log('Vista de playlists mejorada cargada correctamente');
    });

    let playlistIdToDelete = null;

    function showDeleteModal(playlistId, playlistName) {
        playlistIdToDelete = playlistId;
        document.getElementById('playlistToDelete').textContent = playlistName;
        document.getElementById('playlistIdToDelete').value = playlistId;
        document.getElementById('deleteModal').classList.remove('d-none');
    }

    function hideDeleteModal() {
        document.getElementById('deleteModal').classList.add('d-none');
        playlistIdToDelete = null;
    }

    function confirmDelete() {
        if (playlistIdToDelete) {
            document.getElementById('deleteForm').submit();
        }
    }

    // Cerrar modal con Escape
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            hideDeleteModal();
        }
    });

    // Cerrar modal al hacer click fuera
    document.addEventListener('click', function(e) {
        const modal = document.getElementById('deleteModal');
        if (e.target === modal) {
            hideDeleteModal();
        }
    });
        /* Importar estilos de suscripción */
    @@import url('/css/subscription-ui.css');
</script>

