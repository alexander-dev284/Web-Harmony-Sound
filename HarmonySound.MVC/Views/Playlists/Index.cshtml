@model List<HarmonySound.MVC.Models.PlaylistDto>

@{
    ViewData["Title"] = "Mis Playlists";
    var selectedContent = ViewBag.SelectedContent as HarmonySound.Models.Content;
    var contentId = ViewBag.ContentId as int?;
}

<div class="playlists-container">
    <div class="playlists-header">
        <!-- Navegación -->
        <div class="navigation-bar">
            <a href="@Url.Action("Home", "Clients")" class="btn-home">
                <i class="fas fa-home me-2"></i>
                Home Cliente
            </a>
        </div>

        <h1 class="playlists-title">
            <i class="fas fa-list-music me-3"></i>
            Mis Playlists
        </h1>
        <p class="playlists-subtitle">Gestiona y organiza tus playlists musicales</p>

        <div class="header-actions">
            <a asp-action="Create" class="btn-create">
                <i class="fas fa-plus me-2"></i>
                Crear Nueva Playlist
            </a>
        </div>
    </div>

    @if (selectedContent != null)
    {
        <div class="song-selection-notice">
            <div class="alert-content">
                <div class="alert-icon">
                    <i class="fas fa-music"></i>
                </div>
                <div class="message-info"> 
                    <h5>Agregando canción a playlist:</h5>
                    <p><strong>Canción:</strong> @selectedContent.Title</p>
                    <p><strong>Tipo:</strong> @selectedContent.Type</p>
                    <p>Selecciona la playlist donde quieres agregar esta canción:</p>
                </div>
            </div>
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            <i class="fas fa-check-circle me-2"></i>
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-circle me-2"></i>
            @TempData["Error"]
        </div>
    }

    @{
        var subscriptionStatus = ViewBag.SubscriptionStatus as dynamic;
    }

    @if (subscriptionStatus?.IsCancelled == true && subscriptionStatus?.IsActive == true)
    {
        <div class="expiration-warning">
            <i class="fas fa-exclamation-triangle"></i>
            <div>
                <strong>Atención:</strong> Tu plan premium expirará el @subscriptionStatus.EndDate.ToString("dd/MM/yyyy"). 
                Después de esa fecha, tus playlists seguirán disponibles, pero con limitaciones.
                <a href="@Url.Action("Index", "Plans")" style="color: #ffc107; text-decoration: underline;">Reactivar plan</a>
            </div>
        </div>
    }

    <div class="playlists-grid">
        @if (Model != null && Model.Any())
        {
            @foreach (var playlist in Model)
            {
                <div class="playlist-card">
                    <div class="playlist-cover">
                        <a href="@Url.Action("Details", "Playlists", new { id = playlist.Id })" class="cover-link">
                            <div class="cover-placeholder">
                                @if (!string.IsNullOrEmpty(playlist.ImageUrl))
                                {
                                    <img src="@playlist.ImageUrl" alt="@playlist.Name" style="width: 100%; height: 100%; object-fit: cover; border-radius: 6px;" />
                                }
                                else
                                {
                                    <i class="fas fa-list-music"></i>
                                }
                            </div>
                            <div class="playlist-overlay">
                                <button class="play-playlist-btn" title="Ir a detalles">
                                    <i class="fas fa-play"></i>
                                </button>
                            </div>
                        </a>
                    </div>

                    <div class="playlist-info">
                        <h3 class="playlist-title">@playlist.Name</h3>
                        <p class="playlist-count">@playlist.Songs.Count canción(es)</p>

                        @if (selectedContent != null)
                        {
                            <div class="playlist-action">
                                <form asp-action="AddToPlaylist" method="post" class="add-form">
                                    <input type="hidden" name="playlistId" value="@playlist.Id" />
                                    <input type="hidden" name="contentId" value="@contentId" />
                                    <button type="submit" class="btn btn-add">
                                        <i class="fas fa-plus me-1"></i>
                                        Agregar aquí
                                    </button>
                                </form>
                            </div>
                        }
                    </div>

                    <div class="playlist-actions">
                        <div class="action-buttons">
                            <a asp-action="Details" asp-route-id="@playlist.Id" class="btn-action btn-details" title="Ver detalles">
                                <i class="fas fa-info-circle"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@playlist.Id" class="btn-action btn-edit" title="Editar">
                                <i class="fas fa-edit"></i>
                            </a>
                            <button type="button" class="btn-action btn-delete" title="Eliminar" onclick="showDeleteModal(@playlist.Id, '@playlist.Name')">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="fas fa-list-music"></i>
                </div>
                <h3>No tienes playlists creadas aún</h3>
                <p>Crea tu primera playlist para organizar tu música favorita</p>
                <a asp-action="Create" class="btn-create">
                    <i class="fas fa-plus me-2"></i>
                    Crear Mi Primera Playlist
                </a>
            </div>
        }
    </div>

    @if (selectedContent != null)
    {
        <div class="back-navigation">
            <a href="@Url.Action("Home", "Clients")" class="btn btn-back">
                <i class="fas fa-arrow-left me-2"></i>
                Volver a la búsqueda
            </a>
        </div>
    }

    <!-- Modal de confirmación para eliminar -->
    <div id="deleteModal" class="modal-overlay d-none">
        <div class="modal-container">
            <div class="modal-header">
                <div class="modal-icon">
                    <i class="fas fa-exclamation-triangle"></i>
                </div>
                <h3 class="modal-title">Confirmar Eliminación</h3>
            </div>

            <div class="modal-body">
                <p class="modal-message">¿Estás seguro de que quieres eliminar la playlist <strong id="playlistToDelete"></strong>?</p>
                <div class="modal-warning">
                    <i class="fas fa-info-circle"></i>
                    <span>Esta acción no se puede deshacer.</span>
                </div>
            </div>

            <div class="modal-actions">
                <button type="button" class="btn-modal btn-cancel" onclick="hideDeleteModal()">
                    <i class="fas fa-times me-2"></i>
                    Cancelar
                </button>
                <button type="button" class="btn-modal btn-confirm" onclick="confirmDelete()">
                    <i class="fas fa-trash-alt me-2"></i>
                    Eliminar Playlist
                </button>
            </div>
        </div>
    </div>

    <!-- Formulario oculto para eliminar -->
    <form id="deleteForm" asp-action="Delete" asp-controller="Playlists" method="post" style="display: none;">
        <input type="hidden" id="playlistIdToDelete" name="id" value="" />
    </form>
</div>

