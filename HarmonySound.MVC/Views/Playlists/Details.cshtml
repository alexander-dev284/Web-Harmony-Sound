<script>
window.harmonyConfig = {
    urls: {
        getUserLikes: '@Url.Action("GetUserLikes",       "Clients")',
        likeContent:  '@Url.Action("LikeContent",        "Clients")',
        checkPremium: '@Url.Action("CheckPremiumStatus", "Clients")',
        getRandomAd:  '@Url.Action("GetRandomAd",        "Clients")'
    },
    userId: '@ViewBag.UserId'
};
</script>
<script src="~/js/harmony-player.js"></script>
<script>
    // ===== FUNCIONES PARA LOS MODALES =====

    // Variables globales
    let playlistIdToDelete = null;
    let trackIdToRemoveFromPlaylist = null;
    let playlistIdForTrackRemoval = null;

    function showDeletePlaylistModal(playlistId, playlistName) {
        playlistIdToDelete = playlistId;
        document.getElementById('playlistToDeleteDetails').textContent = playlistName;
        document.getElementById('playlistIdToDeleteDetails').value = playlistId;
        document.getElementById('deletePlaylistModal').classList.remove('d-none');
    }

    function hideDeletePlaylistModal() {
        document.getElementById('deletePlaylistModal').classList.add('d-none');
        playlistIdToDelete = null;
    }

    function confirmDeletePlaylist() {
        if (playlistIdToDelete) {
            document.getElementById('deletePlaylistForm').submit();
        }
    }

    function removeTrackFromPlaylist(playlistId, contentId, trackTitle) {
        playlistIdForTrackRemoval = playlistId;
        trackIdToRemoveFromPlaylist = contentId;
        document.getElementById('trackToRemove').textContent = trackTitle;
        document.getElementById('playlistIdForTrackRemoval').value = playlistId;
        document.getElementById('trackIdToRemove').value = contentId;
        document.getElementById('removeTrackModal').classList.remove('d-none');

        // Cerrar menú desplegable si está abierto
        const openMenu = document.querySelector('.track-dropdown-menu.show');
        if (openMenu) {
            openMenu.classList.remove('show');
        }
    }

    function hideRemoveTrackModal() {
        document.getElementById('removeTrackModal').classList.add('d-none');
        trackIdToRemoveFromPlaylist = null;
        playlistIdForTrackRemoval = null;
    }

    function confirmRemoveTrack() {
        if (playlistIdForTrackRemoval && trackIdToRemoveFromPlaylist) {
            document.getElementById('removeTrackForm').submit();
        }
    }

    function toggleTrackMenu(contentId) {
        // Cerrar otros menús abiertos
        document.querySelectorAll('.track-dropdown-menu').forEach(menu => {
            if (menu.id !== `trackMenu-${contentId}`) {
                menu.classList.remove('show');
            }
        });

        // Toggle del menú actual
        const menu = document.getElementById(`trackMenu-${contentId}`);
        if (menu) {
            menu.classList.toggle('show');
        }
    }

    // Cerrar modales al hacer click fuera
    document.addEventListener('click', function(e) {
        const playlistModal = document.getElementById('deletePlaylistModal');
        const trackModal = document.getElementById('removeTrackModal');

        if (e.target === playlistModal) {
            hideDeletePlaylistModal();
        }

        if (e.target === trackModal) {
            hideRemoveTrackModal();
        }

        // Cerrar menús desplegables al hacer click fuera
        if (!e.target.closest('.track-menu-container')) {
            document.querySelectorAll('.track-dropdown-menu').forEach(menu => {
                menu.classList.remove('show');
            });
        }
    });

    // Cerrar modales con Escape
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            hideDeletePlaylistModal();
            hideRemoveTrackModal();

            // Cerrar menús desplegables
            document.querySelectorAll('.track-dropdown-menu').forEach(menu => {
                menu.classList.remove('show');
            });
        }
    });

</script>
