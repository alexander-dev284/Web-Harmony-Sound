    /* Reproductor */
    .custom-player { position: fixed; bottom: 0; left: 0; right: 0; background: linear-gradient(135deg, #181818, #1a1a1a); border-top: 1px solid #282828; height: 90px; z-index: 1000; box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.5); }
    .custom-player.d-none { display: none !important; }
    .player-container { display: grid; grid-template-columns: 1fr 2fr 1fr; align-items: center; height: 100%; padding: 0 16px; gap: 16px; }

    .now-playing { display: flex; align-items: center; gap: 12px; min-width: 0; }
    .track-cover { width: 56px; height: 56px; flex-shrink: 0; }
