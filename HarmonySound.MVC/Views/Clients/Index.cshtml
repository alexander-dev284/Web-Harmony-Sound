        // ✅ NUEVO: Verificar soporte de audio
        checkAudioSupport() {
            if (!window.HTMLAudioElement) {
                console.error('❌ El navegador no soporta HTML5 Audio');
                this.showToast('Tu navegador no soporta reproducción de audio', 'error');
                return false;
            }

            // Verificar formatos soportados
            const audio = new Audio();
            const mp3Support = audio.canPlayType('audio/mpeg');
            const m4aSupport = audio.canPlayType('audio/mp4');

            console.log('🎵 Soporte de audio:', { mp3: mp3Support, m4a: m4aSupport });

            if (!mp3Support && !m4aSupport) {
                console.warn('⚠️ Soporte de audio limitado');
                this.showToast('Soporte de audio limitado en tu navegador', 'warning');
            }

            return true;
        }

