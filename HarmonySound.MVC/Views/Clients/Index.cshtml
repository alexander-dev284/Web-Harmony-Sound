        // ✅ MEJORAR: Toggle más visual y claro
        async toggleLike(button) {
            const contentId = button.getAttribute('data-content-id');
            const userId = button.getAttribute('data-user-id');

            if (!contentId || !userId) {
                console.error('❌ Missing contentId or userId');
                return;
            }

            // ✅ Feedback visual inmediato
            button.style.transform = 'scale(1.3)';
            button.style.filter = 'brightness(1.5)';
            setTimeout(() => {
                button.style.transform = 'scale(1)';
                button.style.filter = 'brightness(1)';
            }, 200);

            button.disabled = true;

            try {
                const formData = new FormData();
                formData.append('contentId', contentId);
                formData.append('userId', userId);

                const isCurrentlyLiked = this.likedContentIds.has(contentId);
                console.log(`🔄 Toggling like for ID ${contentId}: Currently ${isCurrentlyLiked ? 'LIKED' : 'NOT LIKED'}`);

                if (isCurrentlyLiked) {
                    // ✅ QUITAR LIKE
                    const response = await fetch('@Url.Action("UnlikeContent", "Clients")', {
                        method: 'POST',
                        body: formData
                    });

                    const data = await response.json();
                    if (data.success) {
                        this.likedContentIds.delete(contentId);
                        this.updateButtonState(button, false);
                        this.showToast('💔 Removido de favoritos', 'info');
                        console.log('✅ Removido de favoritos:', contentId);
                    }
                } else {
                    // ✅ AGREGAR LIKE
                    const response = await fetch('@Url.Action("LikeContent", "Clients")', {
                        method: 'POST',
                        body: formData
                    });

                    const data = await response.json();
                    if (data.success) {
                        this.likedContentIds.add(contentId);
                        this.updateButtonState(button, true);
                        this.showToast('💚 ¡Agregado a favoritos!', 'success');
                        console.log('✅ Agregado a favoritos:', contentId);
                    }
                }

                // ✅ IMPORTANTE: Sincronizar con reproductor si es la canción actual
                if (this.currentTrack && this.currentTrack.id === contentId) {
                    this.updatePlayerHeartButton();
                }

            } catch (error) {
                console.error('❌ Error al procesar like:', error);
                this.showToast('Error al procesar la solicitud', 'error');
            } finally {
                button.disabled = false;
            }
        }

        // ✅ NUEVO: Método para actualizar estado visual de botón
        updateButtonState(button, isLiked) {
