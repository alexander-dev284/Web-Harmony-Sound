            } else {
                button.classList.remove('liked');
                button.style.color = '#b3b3b3';
                button.style.background = 'transparent';
                button.title = 'Agregar a favoritos';

                const icon = button.querySelector('i');
                if (icon) icon.className = 'far fa-heart'; // VACÍO
            }
        }

        buildPlaylist() {
            this.playlist = [];
            const songItems = document.querySelectorAll('.song-item');

            console.log(`🎵 Construyendo playlist con ${songItems.length} canciones`);

            songItems.forEach((item, index) => {
                const playBtn = item.querySelector('.play-in-player-btn');
                if (playBtn) {
                    const trackData = {
                        id: playBtn.getAttribute('data-content-id'),
                        title: playBtn.getAttribute('data-title'),
                        artist: playBtn.getAttribute('data-artist'),
                        url: playBtn.getAttribute('data-url'),
                        index: index
                    };

                    this.playlist.push(trackData);
                }
            });

            console.log(`✅ Playlist construida con ${this.playlist.length} canciones`);
        }

        getElementReferences() {
            this.playerElement = document.getElementById('custom-player');
            this.playPauseBtn = document.getElementById('play-pause-btn');
            this.trackTitle = document.getElementById('track-title');
            this.trackArtist = document.getElementById('track-artist');
            this.currentTimeElement = document.getElementById('current-time');
            this.totalTimeElement = document.getElementById('total-time');
            this.progressBar = document.getElementById('custom-progress-bar');
            this.progressFill = document.getElementById('progress-fill');
            this.progressHandle = document.getElementById('progress-handle');
            this.volumeControl = document.getElementById('custom-volume-slider');
            this.volumeFill = document.getElementById('volume-fill');
            this.volumeHandle = document.getElementById('volume-handle');

            // Referencias a controles de navegación
            this.prevBtn = document.getElementById('prev-btn');
            this.nextBtn = document.getElementById('next-btn');
            this.repeatBtn = document.getElementById('repeat-btn');
            this.shuffleBtn = document.getElementById('shuffle-btn');

            console.log('🔗 Referencias obtenidas:', {
                playerElement: !!this.playerElement,
                playPauseBtn: !!this.playPauseBtn,
                prevBtn: !!this.prevBtn,
                nextBtn: !!this.nextBtn,
                repeatBtn: !!this.repeatBtn,
                shuffleBtn: !!this.shuffleBtn
            });
