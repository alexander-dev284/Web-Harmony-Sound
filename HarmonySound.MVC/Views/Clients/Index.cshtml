<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

<script>
    class IndexAudioPlayer {
        constructor() {
            this.audio = null;
            this.currentTrack = null;
            this.isPlaying = false;
            this.volume = 0.5;
            this.isPremiumUser = false;
            this.playlist = [];
            this.currentTrackIndex = 0;
            this.isLooping = false;
            this.isShuffling = false;
            this.isProgressDragging = false;
            this.isVolumeDragging = false;
            this.likedContentIds = new Set();

            // Variables para anuncios
            this.isPlayingAd = false;
            this.adEndedHandler = null;
            this.originalTrackToPlay = null;
            this.adNotification = null;

            this.init();
        }

        async init() {
            console.log('🎵 Inicializando reproductor...');

            this.audio = document.getElementById('hidden-audio');
            if (!this.audio) {
                this.audio = document.createElement('audio');
                this.audio.id = 'hidden-audio';
                this.audio.style.display = 'none';
                this.audio.preload = 'metadata';
                this.audio.crossOrigin = 'anonymous';
                document.body.appendChild(this.audio);
            }

            this.getElementReferences();
            this.buildPlaylist();
            this.setupEventListeners();
            this.setVolume(this.volume);

            try {
                await this.checkPremiumStatus();
                await this.loadLikeStates();
            } catch (error) {
                console.error('Error en inicialización:', error);
            }

            console.log('Reproductor inicializado correctamente');
        }

        async checkPremiumStatus() {
            try {
                const response = await fetch('@Url.Action("CheckPremiumStatus", "Clients")');
                if (response.ok) {
                    const data = await response.json();
                    this.isPremiumUser = data.isPremium;
                    console.log(' Estado premium:', this.isPremiumUser);
                } else {
                    console.warn('Error al verificar estado premium');
                    this.isPremiumUser = false;
                }
            } catch (error) {
                console.error(' Error al verificar estado premium:', error);
                this.isPremiumUser = false;
            }
        }

        async loadLikeStates() {
            try {
                const response = await fetch('@Url.Action("GetUserLikes", "Clients")');
                if (response.ok) {
                    const likedContentIds = await response.json();
                    this.likedContentIds = new Set(likedContentIds.map(id => id.toString()));
                    this.updateAllLikeButtons();
                    console.log(' Estados de likes cargados');
                }
            } catch (error) {
                console.error('Error al cargar likes:', error);
            }
        }

        updateAllLikeButtons() {
            document.querySelectorAll('.like-btn').forEach(btn => {
                const contentId = btn.getAttribute('data-content-id');
                const isLiked = this.likedContentIds.has(contentId);
                this.updateButtonState(btn, isLiked);
            });
        }

        updateButtonState(button, isLiked) {
            if (isLiked) {
                button.classList.add('liked');
                button.style.color = '#1db954';
                button.style.background = 'rgba(29, 185, 84, 0.1)';
                button.title = 'Quitar de favoritos';
                const icon = button.querySelector('i');
                if (icon) icon.className = 'fas fa-heart';
            } else {
                button.classList.remove('liked');
                button.style.color = '#b3b3b3';
                button.style.background = 'transparent';
                button.title = 'Agregar a favoritos';
                const icon = button.querySelector('i');
                if (icon) icon.className = 'far fa-heart';
            }
        }

        buildPlaylist() {
            this.playlist = [];
            const songItems = document.querySelectorAll('.song-item');
            songItems.forEach((item, index) => {
                const playBtn = item.querySelector('.play-in-player-btn');
                if (playBtn) {
                    this.playlist.push({
                        id: playBtn.getAttribute('data-content-id'),
                        title: playBtn.getAttribute('data-title'),
                        artist: playBtn.getAttribute('data-artist'),
                        url: playBtn.getAttribute('data-url'),
                        index: index
                    });
                }
            });
            console.log(`Playlist construida con ${this.playlist.length} canciones`);
        }

        getElementReferences() {
            this.playerElement = document.getElementById('custom-player');
            this.playPauseBtn = document.getElementById('play-pause-btn');
            this.trackTitle = document.getElementById('track-title');
            this.trackArtist = document.getElementById('track-artist');
            this.currentTimeElement = document.getElementById('current-time');
            this.totalTimeElement = document.getElementById('total-time');
            this.progressBar = document.getElementById('custom-progress-bar');
            this.progressFill = document.getElementById('progress-fill');
            this.progressHandle = document.getElementById('progress-handle');
            this.volumeControl = document.getElementById('custom-volume-slider');
            this.volumeFill = document.getElementById('volume-fill');
            this.volumeHandle = document.getElementById('volume-handle');
        }

        setupEventListeners() {
            if (this.audio) {
                this.audio.addEventListener('loadedmetadata', () => this.onLoadedMetadata());
                this.audio.addEventListener('timeupdate', () => this.onTimeUpdate());
                this.audio.addEventListener('ended', () => this.onTrackEnded());
                this.audio.addEventListener('error', (e) => this.onError(e));

                // Event listeners de diagnóstico
                this.audio.addEventListener('loadstart', () => console.log(' Audio: loadstart'));
                this.audio.addEventListener('canplay', () => console.log(' Audio: canplay'));
                this.audio.addEventListener('play', () => console.log(' Audio: play event'));
                this.audio.addEventListener('pause', () => console.log(' Audio: pause event'));
            }

            if (this.playPauseBtn) {
                this.playPauseBtn.addEventListener('click', () => this.togglePlayPause());
            }

            // Controles de navegación
            const prevBtn = document.getElementById('prev-btn');
            const nextBtn = document.getElementById('next-btn');
            const repeatBtn = document.getElementById('repeat-btn');
            const shuffleBtn = document.getElementById('shuffle-btn');

            if (prevBtn) prevBtn.addEventListener('click', () => this.playPrevious());
            if (nextBtn) nextBtn.addEventListener('click', () => this.playNext());
            if (repeatBtn) repeatBtn.addEventListener('click', () => this.toggleRepeat());
            if (shuffleBtn) shuffleBtn.addEventListener('click', () => this.toggleShuffle());

            this.setupProgressBar();
            this.setupVolumeControl();

            document.querySelectorAll('.play-in-player-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    e.stopPropagation();

                    console.log(' Botón de reproducir clickeado');

                    const track = this.extractTrackData(btn);
                    console.log(' Datos de la canción:', track);

                    if (!track.url || track.url.trim() === '' || track.url === 'null') {
                        console.error(' URL de canción inválida:', track.url);
                        this.showToast('La canción no tiene una URL válida', 'error');
                        return;
                    }

                    this.playTrackAndStart(track);
                });
            });

            // Botones de like
            document.querySelectorAll('.like-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    e.stopPropagation();
                    this.toggleLike(btn);
                });
            });

            // Like en reproductor
            const heartBtn = document.getElementById('like-current-btn');
            if (heartBtn) {
                heartBtn.addEventListener('click', () => {
                    if (this.currentTrack) {
                        const correspondingBtn = document.querySelector(`[data-content-id="${this.currentTrack.id}"]`)?.querySelector('.like-btn');
                        if (correspondingBtn) {
                            this.toggleLike(correspondingBtn);
                        }
                    }
                });
            }
        }

        extractTrackData(button) {
            return {
                id: button.getAttribute('data-content-id'),
                title: button.getAttribute('data-title'),
                artist: button.getAttribute('data-artist'),
                url: button.getAttribute('data-url')
            };
        }

        async playTrackAndStart(track) {
            if (!track || !track.url || track.url.trim() === '' || track.url === 'null') {
                console.error(' Track inválido:', track);
                this.showToast('Error: Canción no válida', 'error');
                return;
            }

            console.log(' Iniciando reproducción:', track.title);

            // Actualizar información del track actual
            this.currentTrack = track;
            this.currentTrackIndex = this.findTrackInPlaylist(track.id);

            // Actualizar UI del reproductor
            if (this.trackTitle) this.trackTitle.textContent = track.title || 'Canción desconocida';
            if (this.trackArtist) this.trackArtist.textContent = track.artist || 'Artista desconocido';

            // Mostrar reproductor
            if (this.playerElement) {
                this.playerElement.classList.remove('d-none');
            }

            // Actualizar UI de la lista
            this.updateTrackListUI(track.id);
            this.updatePlayerHeartButton();

            try {
                if (this.isPremiumUser) {
                    console.log(' Usuario premium - reproduciendo directamente');
                    await this.playDirectly(track);
                } else {
                    console.log(' Usuario gratuito - reproduciendo con anuncio');
                    await this.playWithAds(track);
                }
            } catch (error) {
                console.error(' Error general al reproducir:', error);
                this.showToast('Error al reproducir el audio', 'error');
                this.isPlaying = false;
                this.updatePlayPauseButton();
            }
        }

        async loadAndPlay(url) {
            return new Promise((resolve, reject) => {
                console.log(' Cargando audio:', url);

                // Limpiar eventos anteriores
                const cleanupEvents = () => {
                    this.audio.removeEventListener('canplay', onCanPlay);
                    this.audio.removeEventListener('error', onError);
                    this.audio.removeEventListener('loadeddata', onLoadedData);
                };

                const onCanPlay = async () => {
                    console.log(' Audio listo para reproducir');
                    cleanupEvents();
                    try {
                        await this.audio.play();
                        resolve();
                    } catch (playError) {
                        console.error(' Error al reproducir:', playError);
                        reject(playError);
                    }
                };

                const onError = (e) => {
                    console.error(' Error al cargar audio:', e);
                    cleanupEvents();
                    reject(new Error('Error al cargar audio'));
                };

                const onLoadedData = () => {
                    console.log(' Datos de audio cargados');
                };

                // Configurar eventos
                this.audio.addEventListener('canplay', onCanPlay);
                this.audio.addEventListener('error', onError);
                this.audio.addEventListener('loadeddata', onLoadedData);

                // Configurar y cargar
                this.audio.src = url;
                this.audio.load();
            });
        }

        async playWithAds(track) {
            try {
                console.log(' Iniciando flujo de anuncio...');

                this.isPlayingAd = true;
                this.originalTrackToPlay = track;

                // Obtener anuncio desde la API
                const response = await fetch('@Url.Action("GetRandomAd", "Clients")');
                if (!response.ok) {
                    throw new Error(`Error HTTP: ${response.status}`);
                }

                const adData = await response.json();
                console.log(' Anuncio obtenido:', adData);

                if (!adData.url) {
                    throw new Error('URL del anuncio no disponible');
                }

                this.showAdNotification(adData.duration);

                // Actualizar UI con información del anuncio
                if (this.trackTitle) this.trackTitle.textContent = 'Reproduciendo anuncio...';
                if (this.trackArtist) this.trackArtist.textContent = 'Anuncio publicitario';

                if (this.adEndedHandler) {
                    this.audio.removeEventListener('ended', this.adEndedHandler);
                }

                this.adEndedHandler = async () => {
                    console.log(' Anuncio terminado');
                    this.audio.removeEventListener('ended', this.adEndedHandler);
                    this.isPlayingAd = false;
                    this.adEndedHandler = null;

                    // Ocultar notificación
                    this.hideAdNotification();

                    setTimeout(async () => {
                        try {
                            await this.playDirectly(this.originalTrackToPlay);
                            this.showToast('¡Ahora reproduciendo tu música!', 'success');
                        } catch (error) {
                            console.error(' Error al reproducir música después del anuncio:', error);
                            this.showToast('Error al reproducir la música', 'error');
                        }
                    }, 500);
                };

                this.audio.addEventListener('ended', this.adEndedHandler);

                console.log(' Configurando anuncio:', adData.url);

                await this.loadAndPlay(adData.url);

                this.isPlaying = true;
                this.updatePlayPauseButton();
                console.log(' Anuncio reproduciendo');

            } catch (error) {
                console.error('❌ Error en sistema de anuncios:', error);
                this.isPlayingAd = false;
                this.adEndedHandler = null;
                this.hideAdNotification();

                // Si falla el anuncio, reproducir directamente la música
                console.log('🔄 Fallback: reproduciendo música directamente');
                await this.playDirectly(track);
                this.showToast('Reproduciendo sin anuncio (error técnico)', 'info');
            }
        }

        async playDirectly(track = this.currentTrack) {
            try {
                console.log('🎵 Reproduciendo directamente:', track.title);
                this.isPlayingAd = false;

                // Actualizar UI
                if (this.trackTitle) this.trackTitle.textContent = track.title || 'Canción desconocida';
                if (this.trackArtist) this.trackArtist.textContent = track.artist || 'Artista desconocido';

                await this.loadAndPlay(track.url);

                this.isPlaying = true;
                this.updatePlayPauseButton();
                console.log(' Música reproduciendo exitosamente:', track.title);

            } catch (error) {
                console.error(' Error al reproducir música:', error);
                this.showToast('Error al reproducir el audio', 'error');
                this.isPlaying = false;
                this.updatePlayPauseButton();
            }
        }

        showAdNotification(duration) {
            this.hideAdNotification();

            this.adNotification = document.createElement('div');
            this.adNotification.className = 'ad-notification';
            this.adNotification.style.cssText = `
                position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
                background: rgba(255, 152, 0, 0.95); color: #000; padding: 20px 28px;
                border-radius: 12px; font-size: 14px; z-index: 1001;
                box-shadow: 0 8px 32px rgba(0,0,0,0.4); text-align: center;
                font-weight: 600; border: 2px solid #ff8f00;
            `;
            this.adNotification.innerHTML = `
                <i class="fas fa-ad" style="margin-right: 8px; font-size: 18px;"></i>
                <strong>Reproduciendo anuncio...</strong>
                <div style="margin-top: 8px; font-size: 12px; opacity: 0.8;">
                    No se puede adelantar
                </div>
                <div class="ad-countdown" style="margin-top: 8px; font-size: 16px; font-weight: bold;">${duration}s</div>
            `;
            document.body.appendChild(this.adNotification);

            // Countdown
            let countdown = duration;
            this.adCountdownInterval = setInterval(() => {
                countdown--;
                const countdownEl = this.adNotification?.querySelector('.ad-countdown');
                if (countdownEl) {
                    countdownEl.textContent = countdown + 's';
                }

                if (countdown <= 0) {
                    clearInterval(this.adCountdownInterval);
                    this.hideAdNotification();
                }
            }, 1000);
        }

        hideAdNotification() {
            if (this.adCountdownInterval) {
                clearInterval(this.adCountdownInterval);
                this.adCountdownInterval = null;
            }

            if (this.adNotification && this.adNotification.parentNode) {
                this.adNotification.parentNode.removeChild(this.adNotification);
                this.adNotification = null;
            }
        }

        async togglePlayPause() {
            if (!this.audio || !this.currentTrack) {
                console.warn(' No hay audio o track para pausar/reproducir');
                return;
            }

            try {
                if (this.audio.paused) {
                    await this.audio.play();
                    this.isPlaying = true;
                    console.log(' Reproducción iniciada/reanudada');
                } else {
                    this.audio.pause();
                    this.isPlaying = false;
                    console.log(' Reproducción pausada');
                }
                this.updatePlayPauseButton();
            } catch (error) {
                console.error(' Error al cambiar estado de reproducción:', error);
                this.isPlaying = false;
                this.updatePlayPauseButton();
                this.showToast('Error al controlar la reproducción', 'error');
            }
        }

        updatePlayPauseButton() {
            if (!this.playPauseBtn) return;
            const icon = this.playPauseBtn.querySelector('i');
            if (icon) {
                icon.className = this.isPlaying ? 'fas fa-pause' : 'fas fa-play';
            }
        }

        updateTrackListUI(currentTrackId) {
            document.querySelectorAll('.song-item').forEach(item => {
                item.classList.remove('playing');
            });

            const currentItem = document.querySelector(`[data-content-id="${currentTrackId}"]`);
            if (currentItem) {
                currentItem.classList.add('playing');
            }
        }

        updatePlayerHeartButton() {
            const heartBtn = document.getElementById('like-current-btn');
            if (heartBtn && this.currentTrack) {
                if (this.likedContentIds.has(this.currentTrack.id)) {
                    heartBtn.classList.add('liked');
                } else {
                    heartBtn.classList.remove('liked');
                }
            }
        }

        findTrackInPlaylist(trackId) {
            return this.playlist.findIndex(track => track.id === trackId);
        }

        playNext() {
            if (this.playlist.length === 0) return;
            let nextIndex = (this.currentTrackIndex + 1) % this.playlist.length;
            const nextTrack = this.playlist[nextIndex];
            if (nextTrack && nextTrack.url && nextTrack.url.trim() !== '' && nextTrack.url !== 'null') {
                this.currentTrackIndex = nextIndex;
                this.playTrackAndStart(nextTrack);
            }
        }

        playPrevious() {
            if (this.playlist.length === 0) return;
            let prevIndex = this.currentTrackIndex > 0 ? this.currentTrackIndex - 1 : this.playlist.length - 1;
            const prevTrack = this.playlist[prevIndex];
            if (prevTrack && prevTrack.url && prevTrack.url.trim() !== '' && prevTrack.url !== 'null') {
                this.currentTrackIndex = prevIndex;
                this.playTrackAndStart(prevTrack);
            }
        }

        toggleRepeat() {
            this.isLooping = !this.isLooping;
            const btn = document.getElementById('repeat-btn');
            if (btn) {
                if (this.isLooping) {
                    btn.classList.add('active');
                } else {
                    btn.classList.remove('active');
                }
            }
        }

        toggleShuffle() {
            this.isShuffling = !this.isShuffling;
            const btn = document.getElementById('shuffle-btn');
            if (btn) {
                if (this.isShuffling) {
                    btn.classList.add('active');
                } else {
                    btn.classList.remove('active');
                }
            }
        }

        async toggleLike(button) {
            const contentId = button.getAttribute('data-content-id');
            const userId = button.getAttribute('data-user-id');

            if (!contentId || !userId) return;

            button.disabled = true;

            try {
                const formData = new FormData();
                formData.append('contentId', contentId);
                formData.append('userId', userId);

                const response = await fetch('@Url.Action("LikeContent", "Clients")', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();
                if (data.success) {
                    if (data.action === 'added') {
                        this.likedContentIds.add(contentId);
                        this.updateButtonState(button, true);
                        this.showToast('¡Agregado a favoritos!', 'success');
                    } else if (data.action === 'removed') {
                        this.likedContentIds.delete(contentId);
                        this.updateButtonState(button, false);
                        this.showToast('Removido de favoritos', 'info');
                    }
                }

                if (this.currentTrack && this.currentTrack.id === contentId) {
                    this.updatePlayerHeartButton();
                }

            } catch (error) {
                console.error('Error al procesar like:', error);
                this.showToast('Error al procesar la solicitud', 'error');
            } finally {
                button.disabled = false;
            }
        }

        setupProgressBar() {
            if (!this.progressBar) return;

            this.progressBar.addEventListener('mousedown', (e) => {
                if (this.isPlayingAd) {
                    console.log(' No se puede adelantar durante un anuncio');
                    return;
                }
                this.isProgressDragging = true;
                this.progressBar.classList.add('dragging');
                this.seekToPosition(e);
            });

            document.addEventListener('mousemove', (e) => {
                if (this.isProgressDragging && !this.isPlayingAd) {
                    this.seekToPosition(e);
                }
            });

            document.addEventListener('mouseup', () => {
                this.isProgressDragging = false;
                this.progressBar.classList.remove('dragging');
            });
        }

        setupVolumeControl() {
            if (!this.volumeControl) return;

            this.volumeControl.addEventListener('mousedown', (e) => {
                this.isVolumeDragging = true;
                this.setVolumeFromPosition(e);
            });

            document.addEventListener('mousemove', (e) => {
                if (this.isVolumeDragging) {
                    this.setVolumeFromPosition(e);
                }
            });

            document.addEventListener('mouseup', () => {
                this.isVolumeDragging = false;
            });
        }

        seekToPosition(e) {
            if (!this.audio || !this.audio.duration || !this.progressBar) return;
            if (this.isPlayingAd) return;

            const rect = this.progressBar.getBoundingClientRect();
            const x = Math.max(0, Math.min(e.clientX - rect.left, rect.width));
            const percent = x / rect.width;
            this.audio.currentTime = percent * this.audio.duration;
            this.updateProgressDisplay();
        }

        setVolumeFromPosition(e) {
            if (!this.volumeControl) return;
            const rect = this.volumeControl.getBoundingClientRect();
            const x = Math.max(0, Math.min(e.clientX - rect.left, rect.width));
            const volume = x / rect.width;
            this.setVolume(volume);
        }

        setVolume(volume) {
            this.volume = Math.max(0, Math.min(1, volume));
            if (this.audio) {
                this.audio.volume = this.volume;
            }
            if (this.volumeFill) {
                this.volumeFill.style.width = (this.volume * 100) + '%';
            }
            if (this.volumeHandle) {
                this.volumeHandle.style.left = (this.volume * 100) + '%';
            }
        }

        onLoadedMetadata() {
            this.duration = this.audio.duration;
            this.updateTimeDisplay();
        }

        onTimeUpdate() {
            if (!this.isProgressDragging) {
                this.currentTime = this.audio.currentTime;
                this.updateProgressDisplay();
                this.updateTimeDisplay();
            }
        }

        updateProgressDisplay() {
            if (!this.audio || !this.audio.duration) return;
            const percent = (this.audio.currentTime / this.audio.duration) * 100;
            if (this.progressFill) {
                this.progressFill.style.width = percent + '%';
            }
            if (this.progressHandle) {
                this.progressHandle.style.left = percent + '%';
            }
        }

        updateTimeDisplay() {
            if (this.currentTimeElement) {
                this.currentTimeElement.textContent = this.formatTime(this.audio.currentTime);
            }
            if (this.totalTimeElement) {
                this.totalTimeElement.textContent = this.formatTime(this.audio.duration);
            }
        }

        formatTime(seconds) {
            if (!seconds || isNaN(seconds)) return '0:00';
            const mins = Math.floor(seconds / 60);
            const secs = Math.floor(seconds % 60);
            return `${mins}:${secs.toString().padStart(2, '0')}`;
        }

        onTrackEnded() {
            console.log(' Canción terminada');
            this.isPlaying = false;
            this.updatePlayPauseButton();

            if (this.isPlayingAd) {
                console.log('📢 Anuncio terminó naturalmente');
                return;
            }

            if (this.isLooping) {
                console.log(' Repitiendo canción');
                setTimeout(() => {
                    this.playTrackAndStart(this.currentTrack);
                }, 500);
            } else {
                console.log(' Siguiente canción');
                setTimeout(() => {
                    this.playNext();
                }, 1000);
            }
        }

        onError(e) {
            console.error(' Error en audio:', e);
            console.error(' Audio src actual:', this.audio?.src);
            console.error(' Audio readyState:', this.audio?.readyState);
            console.error(' Audio networkState:', this.audio?.networkState);

            let errorMessage = 'Error al cargar el audio';
            if (this.audio?.error) {
                switch (this.audio.error.code) {
                    case 1: errorMessage = 'Error: Carga de audio cancelada'; break;
                    case 2: errorMessage = 'Error: Error de red al cargar audio'; break;
                    case 3: errorMessage = 'Error: Error de decodificación de audio'; break;
                    case 4: errorMessage = 'Error: Formato de audio no soportado'; break;
                }
            }

            this.showToast(errorMessage, 'error');
            this.isPlaying = false;
            this.updatePlayPauseButton();
        }

        showToast(message, type = 'info') {
            console.log(` Toast: ${message} (${type})`);
            const toastElement = document.getElementById('liveToast');
            const messageElement = document.getElementById('toast-message');

            if (!toastElement || !messageElement) return;

            toastElement.className = 'toast';
            if (type === 'success') {
                toastElement.classList.add('bg-success', 'text-white');
            } else if (type === 'error') {
                toastElement.classList.add('bg-danger', 'text-white');
            } else {
                toastElement.classList.add('bg-info', 'text-white');
            }

            messageElement.textContent = message;

            if (typeof bootstrap !== 'undefined') {
                const toast = new bootstrap.Toast(toastElement);
                toast.show();
            }
        }
    }

    // Función global para redirección a playlists
    function redirectToPlaylistsWithContent(contentId) {
        if (!contentId) {
            console.error('ContentId no válido');
            return;
        }
        window.location.href = '@Url.Action("Index", "Playlists")?contentId=' + contentId;
    }

    document.addEventListener('DOMContentLoaded', () => {
        console.log(' Inicializando vista Index de Clientes...');
        try {
            window.indexPlayer = new IndexAudioPlayer();
            console.log(' Vista Index de Clientes inicializada correctamente');
        } catch (error) {
            console.error(' Error al inicializar reproductor:', error);
        }
    });
</script>