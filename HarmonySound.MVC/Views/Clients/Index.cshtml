@model IEnumerable<HarmonySound.MVC.Models.ContentWithArtistDto>

@{
    ViewData["Title"] = "Contenido de Audio";
}

<div class="music-library-container">
    <div class="library-header">
        <div class="navigation-bar">
            <a href="@Url.Action("Home", "Clients")" class="btn-home">
                <i class="fas fa-home me-2"></i>
                Home
            </a>
        </div>

        <div class="logout-section">
            <form asp-action="Logout" asp-controller="Account" method="post" class="logout-form">
                <button type="submit" class="btn-logout">
                    <i class="fas fa-sign-out-alt me-2"></i>
                    Cerrar Sesión
                </button>
            </form>
        </div>

        <h1 class="library-title">
            <i class="fas fa-music me-3"></i>
            Biblioteca Musical
        </h1>
        <p class="library-subtitle">Descubre y reproduce tu música favorita</p>
    </div>

    <div class="songs-container">
        <div class="songs-header">
            <h2>Canciones</h2>
        </div>

        <div class="songs-list">
            @foreach (var content in Model)
            {
                <div class="song-item" data-content-id="@content.Id">
                    <div class="song-main-info">
                        <div class="song-cover">
                            <div class="cover-placeholder">
                                <i class="fas fa-music"></i>
                            </div>
                        </div>

                        <div class="song-details">
                            <div class="song-title">@content.Title</div>
                            <div class="song-meta">
                                <span class="content-type">@content.Type</span>
                                <span class="artist-name">@content.ArtistName</span>
                            </div>
                        </div>
                    </div>

                    <div class="song-actions">
                        <button class="btn btn-like like-btn"
                                data-content-id="@content.Id"
                                data-user-id="@ViewBag.UserId"
                                title="Me gusta">
                            <i class="far fa-heart"></i>
                        </button>

                        <button class="btn btn-playlist"
                                onclick="redirectToPlaylistsWithContent(@content.Id)"
                                title="Agregar a Playlist">
                            <i class="fas fa-plus"></i>
                        </button>

                        <button class="btn btn-play play-in-player-btn"
                                data-content-id="@content.Id"
                                data-title="@content.Title"
                                data-artist="@content.ArtistName"
                                data-url="@content.UrlMedia"
                                title="Reproducir">
                            <i class="fas fa-play"></i>
                        </button>
                    </div>

                    <div class="song-duration">
                        <i class="fas fa-clock me-1"></i>
                        <span>@content.FormattedDuration</span>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@await Html.PartialAsync("_PlayerBar")

@{
    var subscriptionStatus = ViewBag.SubscriptionStatus as dynamic;
}
@if (subscriptionStatus?.IsCancelled == true && subscriptionStatus?.IsActive == true)
{
    <div class="subscription-status-banner">
        <div class="banner-content">
            <i class="fas fa-info-circle"></i>
            <div class="banner-text">
                <strong>Plan cancelado:</strong>
                Tienes acceso premium hasta el @subscriptionStatus.EndDate.ToString("dd/MM/yyyy")
            </div>
            <a href="@Url.Action("Index", "Plans")" class="banner-action">Reactivar</a>
        </div>
    </div>
}

<style>
    .container { max-width: none !important; padding: 0 !important; }
    body { background: #000 !important; color: #fff !important; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif !important; margin: 0; padding: 0; padding-bottom: 90px; }

    .navigation-bar { position: absolute; top: 0; left: 0; z-index: 10; }
    .btn-home { background: linear-gradient(135deg, #1a1a1a, #2a2a2a); color: #fff !important; border: 1px solid #333; padding: 8px 16px; border-radius: 20px; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; transition: all .3s; box-shadow: 0 2px 10px rgba(0,0,0,.3); font-size: .9rem; }
    .btn-home:hover { transform: translateY(-2px); color: #000 !important; border-color: #1db954; background: linear-gradient(135deg, #1db954, #1ed760); }

    .logout-section { position: absolute; top: 0; right: 0; z-index: 10; }
    .logout-form { margin: 0; padding: 0; }
    .btn-logout { background: linear-gradient(135deg, #dc2626, #ef4444); color: #fff !important; border: 1px solid #dc2626; padding: 8px 16px; border-radius: 20px; font-weight: 600; cursor: pointer; display: inline-flex; align-items: center; transition: all .3s; font-size: .9rem; }
    .btn-logout:hover { transform: translateY(-2px); background: linear-gradient(135deg, #b91c1c, #dc2626); }

    .music-library-container { max-width: 1200px; margin: 0 auto; padding: 2rem; position: relative; }
    .library-header { margin-bottom: 2rem; padding-top: 3rem; }
    .library-title { font-size: 2rem; font-weight: 700; margin-bottom: .5rem; color: #fff !important; }
    .library-subtitle { color: #b3b3b3 !important; font-size: 1rem; }
    .songs-container { background: #121212 !important; border-radius: 8px; padding: 1.5rem; }
    .songs-header h2 { font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem; color: #fff !important; }
    .songs-list { display: flex; flex-direction: column; gap: 4px; }

    .song-item { display: grid; grid-template-columns: 1fr 120px 80px; grid-template-areas: "info actions duration"; align-items: center; padding: 8px 16px; border-radius: 4px; min-height: 56px; border: 1px solid transparent; }
    .song-main-info { grid-area: info; display: flex; align-items: center; gap: 12px; min-width: 0; }
    .song-cover { width: 40px; height: 40px; flex-shrink: 0; }
    .cover-placeholder { width: 100%; height: 100%; background: #282828; border-radius: 4px; display: flex; align-items: center; justify-content: center; color: #b3b3b3; }
    .song-details { min-width: 0; flex-grow: 1; }
    .song-title { font-size: 16px; font-weight: 400; color: #fff !important; margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .song-meta { display: flex; align-items: center; gap: 8px; font-size: 14px; color: #b3b3b3; }
    .content-type { background: #1db954 !important; color: #000 !important; padding: 2px 8px; border-radius: 4px; font-size: 12px; font-weight: 500; }
    .artist-name { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: #b3b3b3 !important; }

    .song-actions { grid-area: actions; display: flex; gap: 4px; justify-content: flex-end; }
    .song-actions .btn { background: none !important; border: none !important; color: #b3b3b3 !important; padding: 6px !important; border-radius: 50% !important; cursor: pointer !important; transition: all .2s; width: 28px !important; height: 28px !important; display: flex !important; align-items: center !important; justify-content: center !important; font-size: 12px !important; }
    .song-actions .btn:hover { background: #333 !important; color: #fff !important; }
    .btn-like:hover, .btn-playlist:hover, .btn-play:hover { color: #1db954 !important; }

    .song-duration { grid-area: duration; font-size: 14px; color: #b3b3b3 !important; text-align: right; }

    .subscription-status-banner { background: rgba(255,152,0,.95); color: #000; padding: 12px 16px; border-radius: 8px; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 12px; }
    .banner-content { display: flex; align-items: center; gap: 8px; flex-grow: 1; }
    .banner-action { background: #fff; color: #000; padding: 8px 16px; border-radius: 20px; font-weight: 600; text-decoration: none; }
    .banner-action:hover { background: #1db954; }

    header, footer { display: none !important; }
</style>

<script>
window.harmonyConfig = {
    urls: {
        getUserLikes: '@Url.Action("GetUserLikes",       "Clients")',
        likeContent:  '@Url.Action("LikeContent",        "Clients")',
        checkPremium: '@Url.Action("CheckPremiumStatus", "Clients")',
        getRandomAd:  '@Url.Action("GetRandomAd",        "Clients")'
    },
    userId: '@ViewBag.UserId'
};

function redirectToPlaylistsWithContent(contentId) {
    window.location.href = '@Url.Action("Index", "Playlists")?contentId=' + contentId;
}
</script>
<script src="~/js/harmony-player.js"></script>
