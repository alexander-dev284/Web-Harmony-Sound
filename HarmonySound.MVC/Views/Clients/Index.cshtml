        setupEventListeners() {
            // Eventos del audio
            if (this.audio) {
                this.audio.addEventListener('loadedmetadata', () => this.onLoadedMetadata());
                this.audio.addEventListener('timeupdate', () => this.onTimeUpdate());
                this.audio.addEventListener('ended', () => this.onTrackEnded());
                this.audio.addEventListener('error', (e) => this.onError(e));
                this.audio.addEventListener('canplay', () => console.log('Audio listo para reproducir'));
            }

            // Botón play/pause
            if (this.playPauseBtn) {
                this.playPauseBtn.addEventListener('click', () => this.togglePlayPause());
            }

            // Controles de navegación
            if (this.prevBtn) {
                this.prevBtn.addEventListener('click', () => this.playPrevious());
            }

            if (this.nextBtn) {
                this.nextBtn.addEventListener('click', () => this.playNext());
            }

            if (this.repeatBtn) {
                this.repeatBtn.addEventListener('click', () => this.toggleRepeat());
            }

            if (this.shuffleBtn) {
                this.shuffleBtn.addEventListener('click', () => this.toggleShuffle());
            }

            // Barra de progreso
            if (this.progressBar) {
                this.setupProgressBar();
            }

            // Control de volumen
            if (this.volumeControl) {
                this.setupVolumeControl();
            }

            // Botones de las canciones
            document.querySelectorAll('.play-in-player-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    const track = this.extractTrackData(btn);
                    this.playTrackAndStart(track);
                });
            });

            // ✅ IMPORTANTE: Botones de like
            document.querySelectorAll('.like-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    this.toggleLike(btn);
                });
            });

            // ✅ IMPORTANTE: Botón de like en el reproductor
            const heartBtn = document.getElementById('like-current-btn');
            if (heartBtn) {
                heartBtn.addEventListener('click', () => {
                    if (this.currentTrack) {
                        const correspondingBtn = document.querySelector(`[data-content-id="${this.currentTrack.id}"]`)?.querySelector('.like-btn');
                        if (correspondingBtn) {
                            this.toggleLike(correspondingBtn);
                        }
                    }
                });
            }
        }

        // Encontrar índice de canción en playlist
        findTrackInPlaylist(trackId) {
            return this.playlist.findIndex(track => track.id === trackId);
        }

        // Reproducir canción anterior
        playPrevious() {
            if (this.playlist.length === 0) {
                console.warn('⚠️ No hay playlist');
                return;
            }

            let prevIndex;
            if (this.isShuffling) {
                prevIndex = Math.floor(Math.random() * this.playlist.length);
            } else {
                prevIndex = this.currentTrackIndex > 0 ? this.currentTrackIndex - 1 : this.playlist.length - 1;
            }

            const prevTrack = this.playlist[prevIndex];
            if (prevTrack && prevTrack.url) {
                console.log('⏮️ Reproduciendo canción anterior:', prevTrack.title);
                this.currentTrackIndex = prevIndex;
                this.playTrackAndStart(prevTrack);
            } else {
                console.warn('⚠️ Canción anterior no válida');
            }
        }

        // Reproducir canción siguiente
        playNext() {
            if (this.playlist.length === 0) {
                console.warn('⚠️ No hay playlist');
                return;
            }

            let nextIndex;
            if (this.isShuffling) {
                nextIndex = Math.floor(Math.random() * this.playlist.length);
            } else {
                nextIndex = (this.currentTrackIndex + 1) % this.playlist.length;
            }

            const nextTrack = this.playlist[nextIndex];
            if (nextTrack && nextTrack.url) {
                console.log('⏭️ Reproduciendo canción siguiente:', nextTrack.title);
                this.currentTrackIndex = nextIndex;
                this.playTrackAndStart(nextTrack);
            } else {
                console.warn('⚠️ Canción siguiente no válida');
            }
        }

        // Toggle modo repetir
        toggleRepeat() {
            this.isLooping = !this.isLooping;

            if (this.repeatBtn) {
                if (this.isLooping) {
                    this.repeatBtn.classList.add('active');
                    console.log('🔄 Modo bucle activado');
                } else {
                    this.repeatBtn.classList.remove('active');
                    console.log('🔄 Modo bucle desactivado');
                }
            }
        }

        // Toggle modo aleatorio
        toggleShuffle() {
            this.isShuffling = !this.isShuffling;

            if (this.shuffleBtn) {
                if (this.isShuffling) {
                    this.shuffleBtn.classList.add('active');
                    console.log('🔀 Modo aleatorio activado');
                } else {
                    this.shuffleBtn.classList.remove('active');
                    console.log('🔀 Modo aleatorio desactivado');
                }
            }
        }

        // Actualizar UI de lista de canciones
        updateTrackListUI(currentTrackId) {
            // Remover estado playing de todas las canciones
            document.querySelectorAll('.song-item').forEach(item => {
                item.classList.remove('playing');
            });

            // Añadir estado playing a la canción actual
            const currentItem = document.querySelector(`[data-content-id="${currentTrackId}"]`);
            if (currentItem) {
                currentItem.classList.add('playing');
                console.log('🎯 UI actualizada para canción:', currentTrackId);
            }
        }

        setupProgressBar() {
            this.progressBar.addEventListener('mousedown', (e) => {
                // ✅ CORREGIDO: Prevenir adelantar anuncios
                if (this.isPlayingAd) {
                    console.log('🚫 No se puede adelantar durante un anuncio');
                    return;
                }

                this.isProgressDragging = true;
                this.progressBar.classList.add('dragging');
                document.body.classList.add('noselect');
                this.seekToPosition(e);
            });

            this.progressHandle.addEventListener('mousedown', (e) => {
                // ✅ CORREGIDO: Prevenir adelantar anuncios
                if (this.isPlayingAd) {
                    console.log('🚫 No se puede adelantar durante un anuncio');
                    return;
                }

                e.stopPropagation();
                this.isProgressDragging = true;
                this.progressBar.classList.add('dragging');
                document.body.classList.add('noselect');
            });

            document.addEventListener('mousemove', (e) => {
                if (this.isProgressDragging && !this.isPlayingAd) {
                    this.seekToPosition(e);
                }
            });

            document.addEventListener('mouseup', () => {
                if (this.isProgressDragging) {
                    this.isProgressDragging = false;
                    this.progressBar.classList.remove('dragging');
                    document.body.classList.remove('noselect');
                }
            });
        }

        setupVolumeControl() {
            this.volumeControl.addEventListener('mousedown', (e) => {
                this.isVolumeDragging = true;
                this.setVolumeFromPosition(e);
            });

            this.volumeHandle.addEventListener('mousedown', (e) => {
                e.stopPropagation();
                this.isVolumeDragging = true;
            });

            document.addEventListener('mousemove', (e) => {
                if (this.isVolumeDragging) {
                    this.setVolumeFromPosition(e);
                }
            });

            document.addEventListener('mouseup', () => {
                this.isVolumeDragging = false;
            });
        }

        extractTrackData(button) {
            return {
                id: button.getAttribute('data-content-id'),
                title: button.getAttribute('data-title'),
                artist: button.getAttribute('data-artist'),
                url: button.getAttribute('data-url')
            };
        }

        // ✅ CORREGIDO: Cargar y reproducir automáticamente con navegación
        async playTrackAndStart(track) {
            if (!track || !track.url) {
                console.error('❌ Track inválido');
                return;
            }

            console.log('🎵 Reproduciendo:', track.title);

            this.currentTrack = track;
            this.currentTrackIndex = this.findTrackInPlaylist(track.id);

            // Actualizar información
            if (this.trackTitle) this.trackTitle.textContent = track.title || 'Canción desconocida';
            if (this.trackArtist) this.trackArtist.textContent = track.artist || 'Artista desconocido';

            // Actualizar estado del corazón en el reproductor
            this.updatePlayerHeartButton();

            // Mostrar reproductor
            if (this.playerElement) {
                this.playerElement.classList.remove('d-none');
            }

            // Actualizar UI de canciones
            this.updateTrackListUI(track.id);

            try {
                // ✅ CORREGIDO: Cargar primero
                this.audio.src = track.url;
                await this.audio.load();

                // ✅ CORREGIDO: Manejo robusto de autoplay
                if (this.isPremiumUser) {
                    try {
                        await this.audio.play();
                        this.isPlaying = true;
                        this.updatePlayPauseButton();
                        console.log('🎉 Reproduciendo automáticamente (usuario premium):', track.title);
                    } catch (playError) {
                        console.warn('⚠️ Autoplay bloqueado por el navegador, usuario debe hacer clic en play:', playError);
                        this.isPlaying = false;
                        this.updatePlayPauseButton();
                        this.showToast('Haz clic en ▶️ para reproducir', 'info');
                    }
                } else {
                    // Para usuarios no premium, iniciar con anuncios
                    await this.playWithAds(track);
                }
            } catch (error) {
                console.error('❌ Error al cargar/reproducir:', error);
                this.showToast('Error al cargar el audio. Verifica la URL.', 'error');
                this.isPlaying = false;
                this.updatePlayPauseButton();
            }
        }

        // ✅ CORREGIDO: Sistema de anuncios mejorado
        async playWithAds(track) {
            try {
                console.log('🎬 Iniciando reproducción con anuncio para usuario gratuito');

                // ✅ Marcar que estamos reproduciendo un anuncio
                this.isPlayingAd = true;
                this.originalTrackToPlay = track;

                // Obtener anuncio aleatorio
                const response = await fetch('@Url.Action("GetRandomAd", "Clients")');
                const adData = await response.json();

                console.log('📢 Anuncio obtenido:', adData);

                // Actualizar UI para mostrar que es un anuncio
                if (this.trackTitle) this.trackTitle.textContent = 'Reproduciendo anuncio...';
                if (this.trackArtist) this.trackArtist.textContent = 'Anuncio publicitario';

                // Mostrar notificación de anuncio
                this.showAdNotification(adData.duration);

                // Limpiar cualquier listener anterior
                if (this.adEndedHandler) {
                    this.audio.removeEventListener('ended', this.adEndedHandler);
                }

                // Configurar nuevo listener para el final del anuncio
                this.adEndedHandler = () => {
                    console.log('📢 Anuncio terminado, cambiando a música');
                    this.audio.removeEventListener('ended', this.adEndedHandler);
                    this.isPlayingAd = false;
                    this.adEndedHandler = null;

                    // Reproducir la canción original después del anuncio
                    setTimeout(() => {
                        this.playDirectly(this.originalTrackToPlay);
                        this.showToast('¡Ahora reproduciendo tu música!', 'success');
                    }, 500);
                };

                // Configurar y reproducir anuncio
                this.audio.addEventListener('ended', this.adEndedHandler);
                this.audio.src = adData.url;
                await this.audio.load();
                await this.audio.play();

                this.isPlaying = true;
                this.updatePlayPauseButton();

                console.log('📢 Anuncio iniciado correctamente');

            } catch (error) {
                console.error('❌ Error con anuncio:', error);
                this.isPlayingAd = false;
                this.adEndedHandler = null;
                // Si hay error con el anuncio, reproducir directamente la música
                await this.playDirectly(track);
            }
        }

        // ✅ CORREGIDO: Reproducir directamente sin anuncios
        async playDirectly(track = this.currentTrack) {
            try {
                console.log('🎵 Reproduciendo directamente:', track.title);

                // ✅ Asegurar que no estamos en modo anuncio
                this.isPlayingAd = false;

                // Actualizar información de la canción
                if (this.trackTitle) this.trackTitle.textContent = track.title || 'Canción desconocida';
                if (this.trackArtist) this.trackArtist.textContent = track.artist || 'Artista desconocido';

                // Configurar y reproducir música
                this.audio.src = track.url;
                await this.audio.load();
                await this.audio.play();

                this.isPlaying = true;
                this.updatePlayPauseButton();
                console.log('✅ Música reproduciendo exitosamente:', track.title);
            } catch (error) {
                console.error('❌ Error al reproducir música:', error);
                this.showToast('Error al reproducir el audio', 'error');
            }
        }

        // ✅ CORREGIDO: Control de play/pause mejorado
        async togglePlayPause() {
            if (!this.audio || !this.currentTrack) {
                console.warn('⚠️ No hay audio o track cargado');
                return;
            }

            try {
                if (this.audio.paused) {
                    // ✅ MEJORADO: Manejar casos especiales
                    if (this.audio.currentTime === 0 && !this.isPremiumUser && !this.isPlayingAd) {
                        // Primera reproducción para usuario gratuito
                        await this.playWithAds(this.currentTrack);
                    } else {
                        // Reproducción normal
                        await this.audio.play();
                        this.isPlaying = true;
                        console.log('▶️ Reproducción iniciada/reanudada');
                    }
                } else {
                    this.audio.pause();
                    this.isPlaying = false;
                    console.log('⏸️ Reproducción pausada');
                }
                this.updatePlayPauseButton();
            } catch (error) {
                console.error('❌ Error al cambiar estado de reproducción:', error);
                this.showToast('No se pudo reproducir. Intenta de nuevo.', 'error');
                this.isPlaying = false;
                this.updatePlayPauseButton();
            }
        }

        updatePlayPauseButton() {
            if (!this.playPauseBtn) return;

            const icon = this.playPauseBtn.querySelector('i');
            if (icon) {
                icon.className = this.isPlaying ? 'fas fa-pause' : 'fas fa-play';
            }
        }

        // ✅ CORREGIDO: Prevenir adelantar durante anuncios
        seekToPosition(e) {
            if (!this.audio || !this.audio.duration || !this.progressBar) return;

            // ✅ IMPORTANTE: Bloquear adelantar durante anuncios
            if (this.isPlayingAd) {
                console.log('🚫 No se puede adelantar durante un anuncio');
                return;
            }

            const rect = this.progressBar.getBoundingClientRect();
            const x = Math.max(0, Math.min(e.clientX - rect.left, rect.width));
            const percent = x / rect.width;

            this.audio.currentTime = percent * this.audio.duration;
            this.updateProgressDisplay();
        }

        setVolumeFromPosition(e) {
            if (!this.volumeControl) return;

            const rect = this.volumeControl.getBoundingClientRect();
            const x = Math.max(0, Math.min(e.clientX - rect.left, rect.width));
            const volume = x / rect.width;

            this.setVolume(volume);
        }

        setVolume(volume) {
            this.volume = Math.max(0, Math.min(1, volume));

            if (this.audio) {
                this.audio.volume = this.volume;
            }

            if (this.volumeFill) {
                this.volumeFill.style.width = (this.volume * 100) + '%';
            }

            if (this.volumeHandle) {
                this.volumeHandle.style.left = (this.volume * 100) + '%';
            }

            const volumeBtn = document.getElementById('volume-btn');
            if (volumeBtn) {
                const icon = volumeBtn.querySelector('i');
                if (icon) {
                    if (this.volume === 0) {
                        icon.className = 'fas fa-volume-mute';
                    } else if (this.volume < 0.5) {
                        icon.className = 'fas fa-volume-down';
                    } else {
                        icon.className = 'fas fa-volume-up';
                    }
                }
            }
        }

        onLoadedMetadata() {
            this.duration = this.audio.duration;
            this.updateTimeDisplay();
        }

        onTimeUpdate() {
            if (!this.isProgressDragging) {
                this.currentTime = this.audio.currentTime;
                this.updateProgressDisplay();
                this.updateTimeDisplay();
            }
        }

        updateProgressDisplay() {
            if (!this.audio || !this.audio.duration) return;

            const percent = (this.audio.currentTime / this.audio.duration) * 100;

            if (this.progressFill) {
                this.progressFill.style.width = percent + '%';
            }

            if (this.progressHandle) {
                this.progressHandle.style.left = percent + '%';
            }
        }

        updateTimeDisplay() {
            if (this.currentTimeElement) {
                this.currentTimeElement.textContent = this.formatTime(this.audio.currentTime);
            }

            if (this.totalTimeElement) {
                this.totalTimeElement.textContent = this.formatTime(this.audio.duration);
            }
        }

        formatTime(seconds) {
            if (!seconds || isNaN(seconds)) return '0:00';

            const mins = Math.floor(seconds / 60);
            const secs = Math.floor(seconds % 60);
            return `${mins}:${secs.toString().padStart(2, '0')}`;
        }

        // ✅ CORREGIDO: Manejar fin de canción con control de anuncios
        onTrackEnded() {
            console.log('🏁 Audio terminado');
            this.isPlaying = false;
            this.updatePlayPauseButton();

            // ✅ IMPORTANTE: Si era un anuncio, el listener adEndedHandler ya se encarga
            if (this.isPlayingAd) {
                console.log('📢 Anuncio terminó, el listener adEndedHandler se encargará');
                return;
            }

            // Solo manejar fin de música real (no anuncios)
            if (this.isLooping) {
                // Si está en modo bucle, repetir la misma canción
                console.log('🔄 Repitiendo canción en bucle');
                setTimeout(() => {
                    this.playTrackAndStart(this.currentTrack);
                }, 500);
            } else {
                // Si no está en bucle, reproducir la siguiente canción
                console.log('⏭️ Reproduciendo siguiente canción automáticamente');
                setTimeout(() => {
                    this.playNext();
                }, 1000);
            }
        }

        onError(e) {
            console.error('❌ Error en audio:', e);
            console.error('🔗 URL que causó el error:', this.audio?.src);

            let errorMessage = 'Error al cargar el audio';

            if (this.audio && this.audio.error) {
                switch (this.audio.error.code) {
                    case this.audio.error.MEDIA_ERR_ABORTED:
                        errorMessage = 'Reproducción cancelada';
                        break;
                    case this.audio.error.MEDIA_ERR_NETWORK:
                        errorMessage = 'Error de red al cargar audio';
                        break;
                    case this.audio.error.MEDIA_ERR_DECODE:
                        errorMessage = 'Error al decodificar el archivo de audio';
                        break;
                    case this.audio.error.MEDIA_ERR_SRC_NOT_SUPPORTED:
                        errorMessage = 'Formato de audio no soportado';
                        break;
                    default:
                        errorMessage = 'Error desconocido de audio';
                }
            }

            this.showToast(errorMessage, 'error');

            // Actualizar UI
            if (this.trackTitle) {
                this.trackTitle.textContent = 'Error al cargar audio';
            }
            if (this.trackArtist) {
                this.trackArtist.textContent = errorMessage;
            }

            this.isPlaying = false;
            this.updatePlayPauseButton();
        }

        async checkPremiumStatus() {
            try {
                const response = await fetch('@Url.Action("CheckPremiumStatus", "Clients")');
                const data = await response.json();
                this.isPremiumUser = data.isPremium;
                console.log('👑 Usuario premium:', this.isPremiumUser);
            } catch (error) {
                console.error('❌ Error al verificar estado premium:', error);
                this.isPremiumUser = false;
            }
        }

        // ✅ MEJORADO: Notificación de anuncio con información adicional
        showAdNotification(duration) {
            const notification = document.createElement('div');
            notification.className = 'ad-notification';
            notification.style.cssText = `
                position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
                background: rgba(255, 152, 0, 0.95); color: #000; padding: 20px 28px;
                border-radius: 12px; font-size: 14px; z-index: 1001;
                box-shadow: 0 8px 32px rgba(0,0,0,0.4); text-align: center;
                font-weight: 600; border: 2px solid #ff8f00;
            `;
            notification.innerHTML = `
                <i class="fas fa-ad" style="margin-right: 8px; font-size: 18px;"></i>
                <strong>Reproduciendo anuncio...</strong>
                <div style="margin-top: 8px; font-size: 12px; opacity: 0.8;">
                    No se puede adelantar
                </div>
                <div id="ad-countdown" style="margin-top: 8px; font-size: 16px; font-weight: bold;">${duration}s</div>
            `;
            document.body.appendChild(notification);

            let countdown = duration;
            const interval = setInterval(() => {
                countdown--;
                const countdownEl = document.getElementById('ad-countdown');
                if (countdownEl) {
                    countdownEl.textContent = countdown + 's';
                }

                if (countdown <= 0) {
                    clearInterval(interval);
                    if (notification.parentNode) {
                        notification.parentNode.removeChild(notification);
                    }
                }
            }, 1000);
        }

        showToast(message, type = 'info') {
            const toastElement = document.getElementById('liveToast');
            const messageElement = document.getElementById('toast-message');

            if (!toastElement || !messageElement) return;

            toastElement.className = 'toast';
            if (type === 'success') {
                toastElement.classList.add('bg-success', 'text-white');
            } else if (type === 'error') {
                toastElement.classList.add('bg-danger', 'text-white');
            } else {
                toastElement.classList.add('bg-info', 'text-white');
            }

            messageElement.textContent = message;

            if (typeof bootstrap !== 'undefined') {
                const toast = new bootstrap.Toast(toastElement);
                toast.show();
            }
        }
    }

    // ✅ FUNCIÓN GLOBAL CORREGIDA para redirección a playlists
    function redirectToPlaylistsWithContent(contentId) {
        if (!contentId) {
            console.error('ContentId no válido');
            return;
        }
        window.location.href = '@Url.Action("Index", "Playlists")?contentId=' + contentId;
    }

    // Inicializar reproductor cuando se carga el DOM
    document.addEventListener('DOMContentLoaded', () => {
        window.indexPlayer = new IndexAudioPlayer();

        // Función de debugging
        window.testControls = function() {
            console.log('🧪 Testing controles del reproductor...');
            console.log('Playlist:', window.indexPlayer.playlist.length, 'canciones');
            console.log('Índice actual:', window.indexPlayer.currentTrackIndex);
            console.log('Modo bucle:', window.indexPlayer.isLooping);
            console.log('Modo aleatorio:', window.indexPlayer.isShuffling);
        };
    });
</script>