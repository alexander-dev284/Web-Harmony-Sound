    .btn-logout:hover { transform: translateY(-2px); box-shadow: 0 4px 20px rgba(220, 38, 38, 0.5); background: linear-gradient(135deg, #b91c1c, #dc2626); border-color: #b91c1c; color: #fff !important; }
    
