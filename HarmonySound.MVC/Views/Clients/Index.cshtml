</style>

<!-- Asegurar que FontAwesome esté cargado -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

<script>
    // Variables globales
    let currentTrack = null;
    let isPlaying = false;
    let volume = 50;
    let isPremiumUser = false;
    let player, playPauseBtn, trackTitle, trackArtist, spotifyPlayer;

    // Inicialización cuando se carga el DOM
    document.addEventListener('DOMContentLoaded', function() {
        console.log('DOM cargado, inicializando reproductor...');
        
        // Inicializar elementos del DOM
        player = document.getElementById('main-player');
        playPauseBtn = document.getElementById('play-pause-btn');
        trackTitle = document.getElementById('track-title');
        trackArtist = document.getElementById('track-artist');
        spotifyPlayer = document.getElementById('spotify-player');
        
        // Verificar que los elementos existan
        if (!player || !spotifyPlayer) {
            console.error('Elementos del reproductor no encontrados');
            return;
        }

        // Configurar el reproductor
        player.controls = false;
        player.preload = 'metadata';
        player.volume = volume / 100;

        // Configurar event listeners
        setupEventListeners();
        
        // Verificar estado premium
        checkPremiumStatus();
        
        // Cargar likes
        loadLikes();
        
        console.log('Reproductor inicializado correctamente');
    });

    function setupEventListeners() {
        // Botones de reproducción
        document.querySelectorAll('.play-in-player-btn').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                
                const track = {
                    id: this.getAttribute('data-content-id'),
                    title: this.getAttribute('data-title'),
                    artist: this.getAttribute('data-artist'),
                    url: this.getAttribute('data-url')
                };
                
                console.log('Reproduciendo:', track.title);
                playTrack(track);
            });
        });

        // Botones de like
        document.querySelectorAll('.like-btn').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                
                const contentId = this.getAttribute('data-content-id');
                const userId = this.getAttribute('data-user-id');
                
                console.log('Like:', contentId, userId);
                toggleLike(contentId, userId, this);
            });
        });

        // Botones de playlist
        document.querySelectorAll('.btn-playlist').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                
                const songItem = this.closest('.song-item');
                const contentId = songItem ? songItem.getAttribute('data-content-id') : null;
                
                console.log('Playlist:', contentId);
                if (contentId) {
                    redirectToPlaylistsWithContent(contentId);
                }
            });
        });

        // Botón play/pause del reproductor
        if (playPauseBtn) {
            playPauseBtn.addEventListener('click', togglePlayPause);
        }

        // Eventos del reproductor
        if (player) {
            player.addEventListener('ended', handleTrackEnd);
            player.addEventListener('error', function(e) {
                console.error('Error en el reproductor:', e);
                showToast('Error al reproducir el audio', 'error');
            });
        }
    }

    function playTrack(track) {
        if (!track || !track.url) {
            console.error('Track inválido');
            return;
        }

        console.log('Reproduciendo track:', track.title);
        
        currentTrack = track;
        
        // Actualizar información del reproductor
        if (trackTitle) trackTitle.textContent = track.title || 'Canción desconocida';
        if (trackArtist) trackArtist.textContent = track.artist || 'Artista desconocido';
        
        // Mostrar reproductor
        if (spotifyPlayer) {
            spotifyPlayer.classList.remove('d-none');
        }
        
        // Actualizar UI de las canciones
        document.querySelectorAll('.song-item').forEach(item => {
            item.classList.remove('playing');
        });
        
        const songItem = document.querySelector(`[data-content-id="${track.id}"]`);
        if (songItem) {
            songItem.classList.add('playing');
        }

        // Configurar y reproducir
        if (!isPremiumUser) {
            playWithAds(track);
        } else {
            playDirectly(track);
        }
    }

    function playWithAds(track) {
        fetch('@Url.Action("GetRandomAd", "Clients")')
            .then(response => response.json())
            .then(adData => {
                showAdNotification(adData.duration);
                
                // Reproducir anuncio primero
                player.src = adData.url;
                player.load();
                
                player.play().then(() => {
                    isPlaying = true;
                    updatePlayPauseButton();
                    
                    // Cuando termine el anuncio, reproducir la canción
                    player.addEventListener('ended', function adEndedHandler() {
                        player.removeEventListener('ended', adEndedHandler);
                        playDirectly(track);
                        showToast('¡Ahora reproduciendo tu música!', 'success');
                    });
                });
            })
            .catch(error => {
                console.error('Error al obtener anuncio:', error);
                playDirectly(track);
            });
    }

    function playDirectly(track) {
        player.src = track.url;
        player.load();
        
        player.play().then(() => {
            isPlaying = true;
            updatePlayPauseButton();
            console.log('Reproduciendo exitosamente:', track.title);
        }).catch(error => {
            console.error('Error al reproducir:', error);
            showToast('Error al reproducir el audio', 'error');
        });
    }

    function togglePlayPause() {
        if (!currentTrack || !player) return;

        if (isPlaying) {
            player.pause();
            isPlaying = false;
        } else {
            player.play().then(() => {
                isPlaying = true;
            }).catch(error => {
                console.error('Error al reproducir:', error);
            });
        }
        updatePlayPauseButton();
    }

    function updatePlayPauseButton() {
        if (!playPauseBtn) return;
        
        const icon = playPauseBtn.querySelector('i');
        if (icon) {
            icon.className = isPlaying ? 'fas fa-pause' : 'fas fa-play';
        }
    }

    function handleTrackEnd() {
        isPlaying = false;
        updatePlayPauseButton();
    }

    function toggleLike(contentId, userId, button) {
        if (!contentId || !userId) {
            console.error('Datos faltantes para like');
            return;
        }

        button.disabled = true;
        const originalColor = button.style.color;

        const formData = new FormData();
        formData.append('contentId', contentId);
        formData.append('userId', userId);

        fetch('@Url.Action("LikeContent", "Clients")', {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                button.style.color = '#1db954';
                showToast('¡Contenido agregado a favoritos!', 'success');
            } else {
                // Intentar unlike
                fetch('@Url.Action("UnlikeContent", "Clients")', {
                    method: 'POST',
                    body: formData
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        button.style.color = '#b3b3b3';
                        showToast('Contenido removido de favoritos', 'info');
                    }
                });
            }
        })
        .catch(error => {
            console.error('Error al procesar like:', error);
            button.style.color = originalColor;
            showToast('Error al procesar la solicitud', 'error');
        })
        .finally(() => {
            button.disabled = false;
        });
    }

    function redirectToPlaylistsWithContent(contentId) {
        console.log('Agregando a playlist:', contentId);
        if (!contentId) {
            console.error('ContentId no válido');
            return;
        }
        window.location.href = '@Url.Action("Index", "Playlists")?contentId=' + contentId;
    }

    function showAdNotification(duration) {
        const notification = document.createElement('div');
        notification.className = 'ad-notification';
        notification.innerHTML = `
            <div style="text-align: center;">
                <i class="fas fa-ad" style="margin-right: 8px;"></i>
                <strong>Reproduciendo anuncio...</strong>
                <div id="ad-countdown" style="margin-top: 8px;">${duration}s</div>
            </div>
        `;
        document.body.appendChild(notification);

        let countdown = duration;
        const interval = setInterval(() => {
            countdown--;
            const countdownEl = document.getElementById('ad-countdown');
            if (countdownEl) {
                countdownEl.textContent = countdown + 's';
            }
            
            if (countdown <= 0) {
                clearInterval(interval);
                if (notification.parentNode) {
                    notification.parentNode.removeChild(notification);
                }
            }
        }, 1000);
    }

    function checkPremiumStatus() {
        fetch('@Url.Action("CheckPremiumStatus", "Clients")')
            .then(response => response.json())
            .then(data => {
                isPremiumUser = data.isPremium;
                console.log('Usuario premium:', isPremiumUser);
            })
            .catch(error => {
                console.error('Error al verificar estado premium:', error);
                isPremiumUser = false;
            });
    }

    function loadLikes() {
        document.querySelectorAll('.like-btn').forEach(btn => {
            const contentId = btn.getAttribute('data-content-id');
            if (contentId) {
                fetch(`@Url.Action("GetContentLikes", "Clients")?contentId=${contentId}`)
                    .then(response => response.json())
                    .then(data => {
                        const likeCount = document.querySelector(`[data-content-id="${contentId}"] .like-count`);
                        if (likeCount) {
                            likeCount.textContent = data.likes || 0;
                        }
                    })
                    .catch(error => {
                        console.error('Error al cargar likes:', error);
                    });
            }
        });
    }

    function showToast(message, type) {
        const toastElement = document.getElementById('liveToast');
        const messageElement = document.getElementById('toast-message');
        
        if (!toastElement || !messageElement) return;
        
        toastElement.className = 'toast';
        if (type === 'success') {
            toastElement.classList.add('bg-success', 'text-white');
        } else if (type === 'error') {
            toastElement.classList.add('bg-danger', 'text-white');
        } else {
            toastElement.classList.add('bg-info', 'text-white');
        }
        
        messageElement.textContent = message;
        
        const toast = new bootstrap.Toast(toastElement);
        toast.show();
    }

    // Funciones de debug
    window.testPlayButton = function(index = 0) {
        const btn = document.querySelectorAll('.play-in-player-btn')[index];
        if (btn) {
            console.log('Probando botón de play:', index);
            btn.click();
        } else {
            console.log('Botón no encontrado');
        }
    };

    window.testLikeButton = function(index = 0) {
        const btn = document.querySelectorAll('.like-btn')[index];
        if (btn) {
            console.log('Probando botón de like:', index);
            btn.click();
        } else {
            console.log('Botón no encontrado');
        }
    };
</script>