@model HarmonySound.MVC.Models.SearchResultsViewModel

@{
    ViewData["Title"] = "Bienvenido";
}

<div class="music-library-container">
    <div class="library-header">
        <!--  Botón de cerrar sesión -->
        <div class="logout-section">
            <form asp-action="Logout" asp-controller="Account" method="post" class="logout-form">
                <button type="submit" class="btn-logout">
                    <i class="fas fa-sign-out-alt me-2"></i>
                    Cerrar Sesión
                </button>
            </form>
        </div>

        <h1 class="library-title">
            <i class="fas fa-music me-3"></i>
            Bienvenido a UniSound
        </h1>
        <p class="library-subtitle">Descubre y reproduce música de tus artistas favoritos</p>
        
        <div class="header-actions">
            @if (!string.IsNullOrEmpty(Model.Profile?.ProfileImageUrl))
            {
                <img src="@Model.Profile.ProfileImageUrl" alt="Profile Image" class="profile-image" />
            }
            else
            {
                <img src="~/images/default-profile.png" alt="Profile Image" class="profile-image" />
            }
            
            <div class="action-buttons">
                <a href="@Url.Action("EditProfile", "Clients")" class="btn-action btn-primary">
                    <i class="fas fa-user-edit me-2"></i>Editar perfil
                </a>
                <a href="@Url.Action("Index", "Clients")" class="btn-action btn-success">
                    <i class="fas fa-music me-2"></i>Biblioteca musical
                </a>
                <a href="@Url.Action("Index", "Playlists")" class="btn-action btn-info">
                    <i class="fas fa-list me-2"></i>Mis playlists
                </a>
                <a href="@Url.Action("Index", "Plans")" class="btn-action btn-warning">
                    <i class="fas fa-crown me-2"></i>Suscripción
                </a>
            </div>
        </div>
    </div>

    <!-- Formulario de búsqueda -->
    <div class="search-container">
        <form asp-action="Home" method="get" class="search-form">
            <div class="search-input-group">
                <i class="fas fa-search search-icon"></i>
                <input type="text" name="query" value="@Model.Query" placeholder="Buscar artistas o canciones..." class="search-input" />
                <button type="submit" class="search-btn">
                    <i class="fas fa-search"></i>
                </button>
            </div>
        </form>
    </div>

    <!-- Resultados de búsqueda -->
    @if (!string.IsNullOrWhiteSpace(Model.Query))
    {
        <!-- Artistas encontrados -->
        @if (Model.Artists?.Any() == true)
        {
            <div class="results-section">
                <div class="section-header">
                    <h2 class="section-title">
                        <i class="fas fa-user-music me-2"></i>
                        Artistas encontrados
                    </h2>
                </div>
                
                <div class="artists-grid">
                    @foreach (var artist in Model.Artists)
                    {
                        <div class="artist-card">
                            <div class="artist-image">
                                <img src="@(artist.ProfileImageUrl ?? Url.Content("~/images/default-profile.png"))" 
                                     alt="@artist.Name" />
                            </div>
                            <div class="artist-info">
                                <h3 class="artist-name">@artist.Name</h3>
                                <p class="artist-role">Artista</p>
                                <!-- Nuevo botón para ver álbumes -->
                                <a href="@Url.Action("ArtistAlbums", "Clients", new { artistId = artist.Id })" 
                                   class="btn-view-albums">
                                    <i class="fas fa-compact-disc me-1"></i>
                                    Ver Álbumes
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Canciones encontradas -->
        @if (Model.Contents?.Any() == true)
        {
            <div class="songs-container">
                <div class="songs-header">
                    <h2>
                        <i class="fas fa-music me-2"></i>
                        Contenidos encontrados
                    </h2>
                </div>
                
                <div class="songs-list">
                    @foreach (var content in Model.Contents)
                    {
                        <div class="song-item" data-content-id="@content.Id">
                            <div class="song-main-info">
                                <div class="song-cover">
                                    <div class="cover-placeholder">
                                        <i class="fas fa-music"></i>
                                    </div>
                                </div>
                                
                                <div class="song-details">
                                    <div class="song-title">@content.Title</div>
                                    <div class="song-meta">
                                        <span class="content-type">@content.Type</span>
                                        <span class="artist-name">@content.ArtistName</span>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="song-actions">
                               
                                <button class="btn btn-playlist" 
                                        onclick="redirectToPlaylistsWithContent(@content.Id)"
                                        title="Agregar a Playlist">
                                    <i class="fas fa-plus"></i>
                                </button>
                                
                                <button class="btn btn-play play-in-player-btn" 
                                        data-content-id="@content.Id"
                                        data-title="@content.Title"
                                        data-artist="@content.ArtistName"
                                        data-url="@content.UrlMedia"
                                        title="Reproducir">
                                    <i class="fas fa-play"></i>
                                </button>
                            </div>
                            
                            <div class="song-duration">
                                <i class="fas fa-clock me-1"></i>
                                <span>@content.FormattedDuration</span>
                            </div>
                            
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Mensaje sin resultados -->
        @if ((Model.Artists == null || !Model.Artists.Any()) && (Model.Contents == null || !Model.Contents.Any()))
        {
            <div class="no-results">
                <div class="no-results-icon">
                    <i class="fas fa-search"></i>
                </div>
                <h3>No se encontraron resultados</h3>
                <p>No se encontraron resultados para "<strong>@Model.Query</strong>"</p>
                <p class="suggestion">Intenta buscar con palabras diferentes o revisa la ortografía</p>
            </div>
        }
    }
    else
    {
        <!-- ===== PANTALLA DE INICIO / DESCUBRIMIENTO ===== -->

        <!-- Canciones más populares del momento -->
        @if (Model.PopularContents?.Any() == true)
        {
            <div class="discovery-section">
                <div class="section-header">
                    <h2 class="section-title">
                        <i class="fas fa-fire me-2"></i>
                        Lo más popular del momento
                    </h2>
                    <p class="section-subtitle">Las canciones que todos están escuchando</p>
                </div>

                <div class="songs-container">
                    <div class="songs-list">
                        @{ var rank = 0; }
                        @foreach (var content in Model.PopularContents)
                        {
                            rank++;
                            <div class="song-item" data-content-id="@content.Id">
                                <div class="song-main-info">
                                    <div class="song-rank">@rank</div>
                                    <div class="song-cover">
                                        <div class="cover-placeholder">
                                            <i class="fas fa-music"></i>
                                        </div>
                                    </div>
                                    <div class="song-details">
                                        <div class="song-title">@content.Title</div>
                                        <div class="song-meta">
                                            <span class="content-type">@content.Type</span>
                                            <a class="artist-name artist-link" href="@Url.Action("ArtistAlbums", "Clients", new { artistId = content.ArtistId })">@content.ArtistName</a>
                                        </div>
                                    </div>
                                </div>

                                <div class="song-likes" title="Me gusta">
                                    <i class="fas fa-heart"></i>
                                    <span>@content.Likes</span>
                                </div>

                                <div class="song-actions">
                                    <button class="btn btn-playlist"
                                            onclick="redirectToPlaylistsWithContent(@content.Id)"
                                            title="Agregar a Playlist">
                                        <i class="fas fa-plus"></i>
                                    </button>
                                    <button class="btn btn-play play-in-player-btn"
                                            data-content-id="@content.Id"
                                            data-title="@content.Title"
                                            data-artist="@content.ArtistName"
                                            data-url="@content.UrlMedia"
                                            title="Reproducir">
                                        <i class="fas fa-play"></i>
                                    </button>
                                </div>

                                <div class="song-duration">
                                    <i class="fas fa-clock me-1"></i>
                                    <span>@content.FormattedDuration</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Álbumes destacados -->
        @if (Model.FeaturedAlbums?.Any() == true)
        {
            <div class="discovery-section">
                <div class="section-header">
                    <h2 class="section-title">
                        <i class="fas fa-compact-disc me-2"></i>
                        Álbumes destacados
                    </h2>
                    <p class="section-subtitle">Explora colecciones completas de tus artistas</p>
                </div>

                <div class="cards-grid">
                    @foreach (var album in Model.FeaturedAlbums)
                    {
                        <a class="media-card" href="@Url.Action("AlbumDetails", "Clients", new { id = album.Id })">
                            <div class="media-cover">
                                @if (!string.IsNullOrEmpty(album.ImageUrl))
                                {
                                    <img src="@album.ImageUrl" alt="@album.Title" />
                                }
                                else
                                {
                                    <div class="media-cover-placeholder"><i class="fas fa-compact-disc"></i></div>
                                }
                                <div class="media-play"><i class="fas fa-play"></i></div>
                            </div>
                            <div class="media-card-info">
                                <div class="media-card-title">@album.Title</div>
                                <div class="media-card-subtitle">@album.ArtistName</div>
                            </div>
                        </a>
                    }
                </div>
            </div>
        }

        <!-- Novedades -->
        @if (Model.RecentContents?.Any() == true)
        {
            <div class="discovery-section">
                <div class="section-header">
                    <h2 class="section-title">
                        <i class="fas fa-bolt me-2"></i>
                        Novedades
                    </h2>
                    <p class="section-subtitle">Lo último que se ha subido a UniSound</p>
                </div>

                <div class="songs-container">
                    <div class="songs-list">
                        @foreach (var content in Model.RecentContents)
                        {
                            <div class="song-item" data-content-id="@content.Id">
                                <div class="song-main-info">
                                    <div class="song-cover">
                                        <div class="cover-placeholder">
                                            <i class="fas fa-music"></i>
                                        </div>
                                    </div>
                                    <div class="song-details">
                                        <div class="song-title">@content.Title</div>
                                        <div class="song-meta">
                                            <span class="content-type">@content.Type</span>
                                            <a class="artist-name artist-link" href="@Url.Action("ArtistAlbums", "Clients", new { artistId = content.ArtistId })">@content.ArtistName</a>
                                        </div>
                                    </div>
                                </div>

                                <div class="song-actions">
                                    <button class="btn btn-playlist"
                                            onclick="redirectToPlaylistsWithContent(@content.Id)"
                                            title="Agregar a Playlist">
                                        <i class="fas fa-plus"></i>
                                    </button>
                                    <button class="btn btn-play play-in-player-btn"
                                            data-content-id="@content.Id"
                                            data-title="@content.Title"
                                            data-artist="@content.ArtistName"
                                            data-url="@content.UrlMedia"
                                            title="Reproducir">
                                        <i class="fas fa-play"></i>
                                    </button>
                                </div>

                                <div class="song-duration">
                                    <i class="fas fa-clock me-1"></i>
                                    <span>@content.FormattedDuration</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Artistas para explorar -->
        @if (Model.FollowedArtists?.Any() == true)
        {
            <div class="discovery-section">
                <div class="section-header">
                    <h2 class="section-title">
                        <i class="fas fa-heart me-2"></i>
                        Artistas que sigo
                    </h2>
                    <p class="section-subtitle">Los artistas que sigues, siempre a mano</p>
                </div>

                <div class="cards-grid">
                    @foreach (var artist in Model.FollowedArtists)
                    {
                        <a class="media-card artist-media-card" href="@Url.Action("ArtistAlbums", "Clients", new { artistId = artist.Id })">
                            <div class="media-cover media-cover-round">
                                @if (!string.IsNullOrEmpty(artist.ProfileImageUrl))
                                {
                                    <img src="@artist.ProfileImageUrl" alt="@artist.Name" />
                                }
                                else
                                {
                                    <div class="media-cover-placeholder"><i class="fas fa-user-music"></i></div>
                                }
                            </div>
                            <div class="media-card-info">
                                <div class="media-card-title">@artist.Name</div>
                                <div class="media-card-subtitle">Siguiendo</div>
                            </div>
                        </a>
                    }
                </div>
            </div>
        }

        @if (Model.FeaturedArtists?.Any() == true)
        {
            <div class="discovery-section">
                <div class="section-header">
                    <h2 class="section-title">
                        <i class="fas fa-user-music me-2"></i>
                        Artistas para explorar
                    </h2>
                    <p class="section-subtitle">Descubre nuevos artistas y escucha sus álbumes</p>
                </div>

                <div class="cards-grid">
                    @foreach (var artist in Model.FeaturedArtists)
                    {
                        <a class="media-card artist-media-card" href="@Url.Action("ArtistAlbums", "Clients", new { artistId = artist.Id })">
                            <div class="media-cover media-cover-round">
                                @if (!string.IsNullOrEmpty(artist.ProfileImageUrl))
                                {
                                    <img src="@artist.ProfileImageUrl" alt="@artist.Name" />
                                }
                                else
                                {
                                    <div class="media-cover-placeholder"><i class="fas fa-user-music"></i></div>
                                }
                            </div>
                            <div class="media-card-info">
                                <div class="media-card-title">@artist.Name</div>
                                <div class="media-card-subtitle">Artista</div>
                            </div>
                        </a>
                    }
                </div>
            </div>
        }

        <!-- Si no hay nada que mostrar -->
        @if ((Model.PopularContents == null || !Model.PopularContents.Any())
            && (Model.RecentContents == null || !Model.RecentContents.Any())
            && (Model.FeaturedAlbums == null || !Model.FeaturedAlbums.Any())
            && (Model.FeaturedArtists == null || !Model.FeaturedArtists.Any()))
        {
            <div class="welcome-state">
                <div class="welcome-icon">
                    <i class="fas fa-music"></i>
                </div>
                <h3>¡Comienza tu experiencia musical!</h3>
                <p>Aún no hay contenido disponible. Vuelve pronto o busca usando el campo de arriba.</p>
                <div class="quick-actions">
                    <a href="@Url.Action("Index", "Clients")" class="btn-create">
                        <i class="fas fa-music me-2"></i>
                        Explorar Biblioteca Musical
                    </a>
                </div>
            </div>
        }
    }
</div>
@await Html.PartialAsync("_PlayerBar")
<style>
    /* CSS Base - Tema oscuro igual que Index */
    .container { max-width: none !important; padding: 0 !important; }
    body {
        background: var(--us-bg) !important;
        color: var(--us-ink) !important;
        font-family: var(--us-font) !important;
        margin: 0; padding: 0; padding-bottom: 90px;
    }

    /* Biblioteca Musical */
    .music-library-container { max-width: 1200px; margin: 0 auto; padding: 2rem; }

    /* Encabezado en tarjeta limpia */
    .library-header {
        position: relative;
        background: var(--us-surface); border: 1px solid var(--us-border);
        border-radius: var(--us-radius-lg); box-shadow: var(--us-shadow-sm);
        padding: 2rem 1.75rem 1.75rem; margin-bottom: 2rem; text-align: center;
    }
    .library-title {
        font-size: 1.9rem; font-weight: 800; margin: 0 0 0.3rem; color: var(--us-ink) !important;
        letter-spacing: -0.02em; display: flex; align-items: center; justify-content: center;
    }
    .library-title i { color: #c8102e; }
    .library-subtitle { color: var(--us-ink-soft) !important; font-size: 1rem; margin: 0 0 1.5rem; }

    /* Perfil + acciones (fila centrada) */
    .header-actions {
        display: flex; align-items: center; justify-content: center; gap: 1.25rem;
        flex-wrap: wrap; margin-top: 0;
    }
    .profile-image {
        width: 56px; height: 56px; border-radius: 50%; object-fit: cover;
        border: 2px solid #c8102e; box-shadow: var(--us-shadow-sm); flex-shrink: 0;
    }
    .action-buttons { display: flex; gap: 0.6rem; flex-wrap: wrap; }
    .btn-action {
        background: var(--us-surface); color: var(--us-ink) !important;
        border: 1px solid var(--us-border); padding: 9px 16px; border-radius: var(--us-radius-pill);
        font-weight: 600; font-size: 0.9rem; text-decoration: none; display: inline-flex; align-items: center;
        transition: all 0.2s ease; box-shadow: none;
    }
    .btn-action:hover {
        transform: translateY(-1px); box-shadow: var(--us-shadow-sm);
        color: #c8102e !important; border-color: #c8102e;
    }

    /* Formulario de búsqueda */
    .search-container { margin-bottom: 3rem; }
    .search-form { max-width: 600px; margin: 0 auto; }
    .search-input-group { 
        position: relative; display: flex; align-items: center; 
        background: var(--us-surface-alt); border-radius: 25px; border: 2px solid var(--us-border);
        transition: border-color 0.3s ease; overflow: hidden;
    }
    .search-input-group:focus-within { border-color: #c8102e; }
    .search-icon { 
        position: absolute; left: 16px; color: var(--us-ink-soft); font-size: 16px; z-index: 2; 
    }
    .search-input { 
        flex: 1; background: transparent; border: none; color: var(--us-ink); 
        padding: 16px 16px 16px 50px; font-size: 16px; outline: none;
    }
    .search-input::placeholder { color: var(--us-ink-soft); }
    .search-btn { 
        background: #c8102e; border: none; color: #ffffff; padding: 16px 20px; 
        cursor: pointer; transition: background 0.3s ease; border-radius: 0;
    }
    .search-btn:hover { background: #a30d25; }

    /* Sección de resultados - Artistas */
    .results-section { margin-bottom: 3rem; }
    .section-header { margin-bottom: 1.5rem; }
    .section-title { font-size: 1.5rem; font-weight: 700; color: var(--us-ink) !important; }
    .artists-grid { 
        display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); 
        gap: 1.5rem; margin-bottom: 2rem; 
    }
    .artist-card {
        background: linear-gradient(135deg, var(--us-surface-alt), var(--us-surface-2)); border-radius: 12px; 
        padding: 1.5rem; text-align: center; transition: all 0.3s ease;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }
    .artist-card:hover { 
        transform: translateY(-5px); box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3); 
        border-color: rgba(200, 16, 46, 0.5); 
    }
    .artist-image { margin-bottom: 1rem; }
    .artist-image img { 
        width: 80px; height: 80px; border-radius: 50%; object-fit: cover; 
        border: 2px solid var(--us-border); 
    }
    .artist-name { color: var(--us-ink); font-size: 1.1rem; font-weight: 600; margin-bottom: 0.5rem; }
    .artist-role { color: var(--us-ink-soft); font-size: 0.9rem; }

    /* Contenedor de canciones - Igual que Index */
    .songs-container { background: var(--us-surface) !important; border-radius: 8px; padding: 1.5rem; }
    .songs-header h2 { font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem; color: var(--us-ink) !important; }
    .songs-list { display: flex; flex-direction: column; gap: 4px; }

    /* Items de Canciones - Igual que Index */
    .song-item {
        display: grid; grid-template-columns: 1fr 120px 80px 40px;
        grid-template-areas: "info actions duration menu"; align-items: center;
        padding: 8px 16px; border-radius: 4px; transition: background-color 0.3s ease;
        cursor: pointer; position: relative; min-height: 56px; border: 1px solid transparent;
    }
    .song-item:hover { background: var(--us-surface-alt) !important; border-color: var(--us-border) !important; }
    .song-item.playing { background: var(--us-surface-alt) !important; border-color: #c8102e !important; }
    .song-item.playing .song-title { color: #c8102e !important; }

    .song-main-info { grid-area: info; display: flex; align-items: center; gap: 12px; min-width: 0; }
    .song-cover { width: 40px; height: 40px; flex-shrink: 0; }
    .cover-placeholder { 
        width: 100%; height: 100%; background: var(--us-surface-2); border-radius: 4px; 
        display: flex; align-items: center; justify-content: center; color: var(--us-ink-soft); 
    }
    .song-details { min-width: 0; flex-grow: 1; }
    .song-title { 
        font-size: 16px; font-weight: 400; color: var(--us-ink) !important; margin-bottom: 4px; 
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis; 
    }
    .song-meta { display: flex; align-items: center; gap: 8px; font-size: 14px; color: var(--us-ink-soft); }
    .content-type {
        background: var(--us-surface-2) !important; color: var(--us-ink-soft) !important;
        padding: 2px 9px; border-radius: 999px; font-size: 10px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.05em; border: 1px solid var(--us-border);
        flex-shrink: 0;
    }
    .artist-name { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--us-ink-soft) !important; }

    /* Acciones de Canciones */
    .song-actions { 
        grid-area: actions; display: flex; gap: 4px; justify-content: flex-end; 
        opacity: 1 !important; visibility: visible !important; 
    }
    .song-actions .btn {
        background: none !important; border: none !important; color: var(--us-ink-soft) !important;
        padding: 6px !important; border-radius: 50% !important; cursor: pointer !important;
        transition: all 0.3s ease; width: 28px !important; height: 28px !important;
        display: flex !important; align-items: center !important; justify-content: center !important;
        font-size: 12px !important;
    }
    .song-actions .btn:hover { background: var(--us-surface-alt) !important; color: var(--us-ink) !important; transform: scale(1.1); }
    .btn-like:hover, .btn-playlist:hover, .btn-play:hover { color: #c8102e !important; }
    .song-actions .btn-like.liked { 
        color: #c8102e !important; 
        background: rgba(200, 16, 46, 0.1) !important;
        border: 1px solid rgba(200, 16, 46, 0.3) !important;
    }

    .song-actions .btn-like.liked:hover {
        color: #a30d25 !important;
        background: rgba(200, 16, 46, 0.2) !important;
        transform: scale(1.15) !important;
    }

    .btn-heart.liked { 
        color: #c8102e !important;
        background: rgba(200, 16, 46, 0.1) !important;
    }

    .btn-heart.liked:hover {
        color: #a30d25 !important;
        background: rgba(200, 16, 46, 0.2) !important;
    }

    .song-duration { 
        grid-area: duration; font-size: 14px; color: var(--us-ink-soft) !important; 
        font-variant-numeric: tabular-nums; text-align: right; 
    }
    .song-menu { grid-area: menu; opacity: 1 !important; visibility: visible !important; }
    .btn-menu {
        background: none !important; border: none !important; color: var(--us-ink-soft) !important;
        padding: 6px !important; cursor: pointer !important; border-radius: 50% !important;
        width: 28px !important; height: 28px !important; display: flex !important;
        align-items: center !important; justify-content: center !important; font-size: 12px !important;
    }
    .btn-menu:hover { background: var(--us-surface-alt) !important; color: var(--us-ink) !important; }

