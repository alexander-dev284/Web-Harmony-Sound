    /* Estilo para la notificación del anuncio */
    .ad-notification {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: rgba(255, 152, 0, 0.95);
        color: #000;
        padding: 20px 28px;
        border-radius: 12px;
        font-size: 14px;
        z-index: 1001;
        box-shadow: 0 8px 32px rgba(0,0,0,0.4);
