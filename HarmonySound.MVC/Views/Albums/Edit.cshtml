<!-- FontAwesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

<script>
// ===== LÓGICA PARA EDICIÓN DE ÁLBUM =====

// Datos de canciones para búsqueda rápida
let allSongsData = [];

// Inicializar cuando se carga el DOM
document.addEventListener('DOMContentLoaded', () => {
    // Cargar datos de canciones
    loadSongsData();
    
    // Configurar listeners
    setupEventListeners();
    
    // Actualizar vista previa inicial
    updateAlbumPreview();
    
    console.log('Editor de álbum inicializado correctamente');
});

function loadSongsData() {
    // Cargar datos de todas las canciones disponibles desde el servidor
    const songCards = document.querySelectorAll('.song-card');
    allSongsData = Array.from(songCards).map(card => ({
        id: parseInt(card.dataset.songId),
        title: card.querySelector('.song-title').textContent,
        type: card.querySelector('.song-type').textContent,
        duration: card.querySelector('.song-duration').textContent.replace(/[^\d:]/g, ''),
        selected: card.classList.contains('selected')
    }));
}

function setupEventListeners() {
    // Listener para cambios en el título del álbum
    const titleInput = document.querySelector('input[name="Title"]');
    if (titleInput) {
        titleInput.addEventListener('input', () => {
            document.getElementById('preview-album-title').textContent = titleInput.value || 'Álbum sin título';
        });
    }
    
    // Listeners para botones de vista previa
    document.querySelectorAll('.play-preview-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            const trackData = {
                id: btn.getAttribute('data-content-id'),
                title: btn.getAttribute('data-title'),
                artist: btn.getAttribute('data-artist'),
                url: btn.getAttribute('data-url')
            };
            playPreview(trackData);
        });
    });
}

function updateSongSelection(checkbox) {
    const songCard = checkbox.closest('.song-card');
    const songId = parseInt(songCard.dataset.songId);
    
    // Actualizar estado visual
    if (checkbox.checked) {
        songCard.classList.add('selected');
    } else {
        songCard.classList.remove('selected');
    }
    
    // Actualizar datos
    const songData = allSongsData.find(s => s.id === songId);
    if (songData) {
        songData.selected = checkbox.checked;
    }
    
    // Actualizar contador y vista previa
    updateSelectionCount();
    updateAlbumPreview();
}

function updateSelectionCount() {
    const selectedCount = document.querySelectorAll('.song-selection-checkbox:checked').length;
    document.getElementById('selection-count').textContent = selectedCount;
}

function selectAllSongs() {
    document.querySelectorAll('.song-selection-checkbox').forEach(checkbox => {
        checkbox.checked = true;
        updateSongSelection(checkbox);
    });
}

function clearAllSongs() {
    document.querySelectorAll('.song-selection-checkbox').forEach(checkbox => {
        checkbox.checked = false;
        updateSongSelection(checkbox); 
    });
}

function updateAlbumPreview() {
    const selectedSongs = allSongsData.filter(s => s.selected);
    const tracklistContainer = document.getElementById('preview-tracklist');
    const trackCountElement = document.getElementById('preview-track-count');
    
    // Actualizar contador
    trackCountElement.textContent = `${selectedSongs.length} canción(es)`;
    
    if (selectedSongs.length === 0) {
        tracklistContainer.innerHTML = '<div class="empty-preview"><p>Selecciona canciones para ver la vista previa del álbum</p></div>';
        return;
    }
    
    // Generar lista de canciones
    const tracklistHTML = selectedSongs.map((song, index) => `
        <div class="preview-track" data-content-id="${song.id}">
            <span class="track-number">${index + 1}</span>
            <span class="track-title">${song.title}</span>
            <span class="track-duration">${song.duration}</span>
        </div>
    `).join('');
    
    tracklistContainer.innerHTML = tracklistHTML;
}

// ===== REPRODUCTOR DE VISTA PREVIA =====
class PreviewPlayer {
    constructor() {
        this.audio = null;
        this.currentTrack = null;
        this.isPlaying = false;
        this.playerElement = null;
        
        this.init();
    }
    
    init() {
        this.audio = document.getElementById('preview-audio');
        this.playerElement = document.getElementById('preview-player');
        
        if (this.audio) {
            this.audio.addEventListener('loadedmetadata', () => this.onLoadedMetadata());
            this.audio.addEventListener('timeupdate', () => this.onTimeUpdate());
            this.audio.addEventListener('ended', () => this.onEnded());
            this.audio.addEventListener('error', (e) => this.onError(e));
        }
        
        // Controles
        const playPauseBtn = document.getElementById('preview-play-pause');
        const closeBtn = document.getElementById('preview-close');
        
        if (playPauseBtn) {
            playPauseBtn.addEventListener('click', () => this.togglePlayPause());
        }
        
        if (closeBtn) {
            closeBtn.addEventListener('click', () => this.close());
        }
    }
    
    async play(track) {
        if (!track || !track.url) {
            console.error('Track inválido para vista previa');
            return;
        }
        
        this.currentTrack = track;
        
        // Actualizar información
        document.getElementById('preview-track-title').textContent = track.title || 'Vista previa';
        document.getElementById('preview-track-artist').textContent = track.artist || 'Artista';
        
        // Mostrar reproductor
        this.playerElement.classList.remove('d-none');
        
        try {
            this.audio.src = track.url;
            await this.audio.load();
            await this.audio.play();
            this.isPlaying = true;
            this.updatePlayPauseButton();
        } catch (error) {
            console.error('Error al reproducir vista previa:', error);
        }
    }
    
    async togglePlayPause() {
        if (!this.audio || !this.currentTrack) return;
        
        try {
            if (this.audio.paused) {
                await this.audio.play();
                this.isPlaying = true;
            } else {
                this.audio.pause();
                this.isPlaying = false;
            }
            this.updatePlayPauseButton();
        } catch (error) {
            console.error('Error al cambiar estado de vista previa:', error);
        }
    }
    
    updatePlayPauseButton() {
        const btn = document.getElementById('preview-play-pause');
        const icon = btn?.querySelector('i');
        if (icon) {
            icon.className = this.isPlaying ? 'fas fa-pause' : 'fas fa-play';
        }
    }
    
    close() {
        if (this.audio) {
            this.audio.pause();
            this.audio.currentTime = 0;
        }
        this.isPlaying = false;
        this.currentTrack = null;
        this.playerElement.classList.add('d-none');
        this.updatePlayPauseButton();
    }
    
    onLoadedMetadata() {
        const totalTimeElement = document.getElementById('preview-total-time');
        if (totalTimeElement) {
            totalTimeElement.textContent = this.formatTime(this.audio.duration);
        }
    }
    
    onTimeUpdate() {
        const currentTimeElement = document.getElementById('preview-current-time');
        const progressFill = document.getElementById('preview-progress-fill');
        
        if (currentTimeElement) {
            currentTimeElement.textContent = this.formatTime(this.audio.currentTime);
        }
        
        if (progressFill && this.audio.duration) {
            const percent = (this.audio.currentTime / this.audio.duration) * 100;
            progressFill.style.width = percent + '%';
        }
    }
    
    onEnded() {
        this.isPlaying = false;
        this.updatePlayPauseButton();
        
        // Auto-cerrar después de unos segundos
        setTimeout(() => {
            this.close();
        }, 2000);
    }
    
    onError(e) {
        console.error('Error en reproductor de vista previa:', e);
    }
    
    formatTime(seconds) {
        if (!seconds || isNaN(seconds)) return '0:00';
        const mins = Math.floor(seconds / 60);
        const secs = Math.floor(seconds % 60);
        return `${mins}:${secs.toString().padStart(2, '0')}`;
    }
}

// Instancia global del reproductor
window.previewPlayer = new PreviewPlayer();

// Función global para reproducir vista previa
function playPreview(trackData) {
    window.previewPlayer.play(trackData);
}

// Función de validación antes del envío
document.getElementById('albumEditForm').addEventListener('submit', function(e) {
    const selectedSongs = document.querySelectorAll('.song-selection-checkbox:checked');
    
    if (selectedSongs.length === 0) {
        e.preventDefault();
        alert('Debes seleccionar al menos una canción para el álbum.');
        return false;
    }
    
    // Validación del título
    const titleInput = document.querySelector('input[name="Title"]');
    if (!titleInput.value.trim()) {
        e.preventDefault();
        alert('El título del álbum es obligatorio.');
        titleInput.focus();
        return false;
    }
    
    if (titleInput.value.length > 20) {
        e.preventDefault();
        alert('El título del álbum no puede exceder los 20 caracteres.');
        titleInput.focus();
        return false;
    }
    
    console.log('Formulario válido, enviando...');
});
</script>