        line-height: 1.4;
    }

    .alert {
        border-radius: 8px;
        border: none;
        margin-bottom: 1.5rem;
        padding: 1rem;
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
    }

    .alert-danger {
        background: rgba(200, 16, 46, 0.1);
        color: #c8102e;
        border: 1px solid rgba(200, 16, 46, 0.3);
    }

    .error-list {
        margin: 0.5rem 0 0 0;
        padding-left: 1rem;
    }

    .error-list li {
        margin-bottom: 0.25rem;
    }

    /* Contador de caracteres */
    .character-counter {
