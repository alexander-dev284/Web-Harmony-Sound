        padding: 2rem;
    }

    .form-title {
        color: var(--us-ink);
        font-size: 1.4rem;
        font-weight: 600;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        padding-bottom: 1rem;
