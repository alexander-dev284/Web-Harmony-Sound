    .mini-artist {
        color: var(--us-ink-soft);
        font-size: 0.9rem;
    }

    .form-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
        padding-top: 2rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    .btn-create, .btn-cancel {
        padding: 12px 24px;
        border-radius: 25px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        border: none;
        font-size: 1rem;
        display: inline-flex;
        align-items: center;
        min-width: 140px;
        justify-content: center;
    }

    .btn-create {
        background: linear-gradient(135deg, #c8102e, #a30d25);
        color: #ffffff;
        box-shadow: 0 4px 15px rgba(200, 16, 46, 0.3);
    }

    .btn-create:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(200, 16, 46, 0.4);
        color: #ffffff;
    }

    .btn-create:disabled {
        background: var(--us-ink-faint);
        color: var(--us-ink-faint);
        cursor: not-allowed;
        transform: none;
        box-shadow: none;
    }

    .btn-cancel {
        background: transparent;
        border: 2px solid var(--us-ink-faint);
        color: var(--us-ink-soft);
    }

    .btn-cancel:hover {
        background: var(--us-surface-alt);
        color: var(--us-ink);
        border-color: var(--us-ink-faint);
        transform: translateY(-2px);
    }


    /* Ocultar elementos del layout */
    header, footer {
        display: none !important;
    }

    .fas {
        font-family: "Font Awesome 5 Free" !important;
        font-weight: 900 !important;
    }
</style>

<!-- FontAwesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

<script>
// JavaScript para vista previa de imagen
document.addEventListener('DOMContentLoaded', () => {
    const titleInput = document.getElementById('album-title-input');
    const previewTitle = document.getElementById('preview-title');
    const miniPreviewTitle = document.getElementById('mini-preview-title');
    const charCount = document.getElementById('char-count');
    const characterCounter = document.querySelector('.character-counter');
    const createBtn = document.getElementById('create-btn');
    
    const imageInput = document.getElementById('image-file-input');
    const imagePreview = document.getElementById('image-preview');
    const coverPlaceholder = document.getElementById('cover-placeholder');
    const uploadArea = document.querySelector('.image-upload-area');
    const uploadPlaceholder = document.getElementById('upload-placeholder');
    const selectedImageDiv = document.getElementById('selected-image');
    const selectedImagePreview = document.getElementById('selected-image-preview');
    
    // Actualizar vista previa en tiempo real
    function updatePreview() {
        const title = titleInput.value.trim();
        const displayTitle = title || 'Álbum sin título';
        
        if (previewTitle) {
            previewTitle.textContent = displayTitle;
        }
        
        if (miniPreviewTitle) {
            miniPreviewTitle.textContent = displayTitle;
        }
        
        // Actualizar contador de caracteres
        if (charCount) {
            charCount.textContent = title.length;
        }
        
        // Cambiar color del contador según la longitud
        if (characterCounter) {
            characterCounter.classList.remove('warning', 'danger');
            
            if (title.length >= 18) {
                characterCounter.classList.add('danger');
            } else if (title.length >= 15) {
                characterCounter.classList.add('warning');
            }
        }
        
        // Habilitar/deshabilitar botón según validez
        if (createBtn) {
            createBtn.disabled = title.length === 0 || title.length > 20;
        }
    }
    
    // Manejo de imagen
    if (imageInput) {
        imageInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                // Validar tamaño (5MB)
                if (file.size > 5 * 1024 * 1024) {
                    alert('La imagen es demasiado grande. Máximo 5MB.');
                    return;
                }
                
                // Validar tipo
                const validTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif', 'image/webp'];
                if (!validTypes.includes(file.type)) {
                    alert('Formato de imagen no válido. Use JPG, PNG, GIF o WEBP.');
                    return;
                }
                
                const reader = new FileReader();
                reader.onload = function(e) {
                    // Actualizar vista previa grande
                    imagePreview.src = e.target.result;
                    imagePreview.style.display = 'block';
                    coverPlaceholder.querySelector('i').style.display = 'none';
                    
                    // Actualizar vista previa en el área de upload
                    selectedImagePreview.src = e.target.result;
                    uploadPlaceholder.style.display = 'none';
                    selectedImageDiv.style.display = 'block';
                };
                reader.readAsDataURL(file);
            }
        });
    }
    
    // Click en área de upload
    if (uploadArea) {
        uploadArea.addEventListener('click', function() {
            imageInput.click();
        });
    }
    
    // Drag & Drop
    if (uploadArea) {
        uploadArea.addEventListener('dragover', function(e) {
            e.preventDefault();
            this.style.borderColor = '#c8102e';
            this.style.background = 'rgba(200, 16, 46, 0.1)';
        });
        
        uploadArea.addEventListener('dragleave', function(e) {
            e.preventDefault();
            this.style.borderColor = 'rgba(255, 255, 255, 0.2)';
            this.style.background = 'transparent';
        });
        
        uploadArea.addEventListener('drop', function(e) {
            e.preventDefault();
            this.style.borderColor = 'rgba(255, 255, 255, 0.2)';
            this.style.background = 'transparent';
            
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                imageInput.files = files;
                imageInput.dispatchEvent(new Event('change', { bubbles: true }));
            }
        });
    }
    
    // Event listeners existentes
    if (titleInput) {
        titleInput.addEventListener('input', updatePreview);
        titleInput.addEventListener('keyup', updatePreview);
        titleInput.addEventListener('paste', () => {
            setTimeout(updatePreview, 10);
        });

        // Focus automático en el input
        titleInput.focus();
    }
    
    // Validación del formulario
    const form = document.getElementById('albumCreateForm');
    if (form) {
        form.addEventListener('submit', (e) => {
            const title = titleInput.value.trim();
            
            if (!title) {
                e.preventDefault();
                alert('El nombre del álbum es obligatorio.');
                titleInput.focus();
                return false;
            }
            
            if (title.length > 20) {
                e.preventDefault();
                alert('El nombre del álbum no puede exceder los 20 caracteres.');
                titleInput.focus();
                return false;
            }
            
            // Deshabilitar botón para evitar doble envío
            if (createBtn) {
                createBtn.disabled = true;
                createBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Creando...';
            }
        });
    }
    
    // Animaciones de entrada escalonadas
    const sections = document.querySelectorAll('.form-section > *');
    sections.forEach((section, index) => {
        section.style.opacity = '0';
        section.style.transform = 'translateY(20px)';
        
        setTimeout(() => {
            section.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
            section.style.opacity = '1';
            section.style.transform = 'translateY(0)';
        }, index * 200);
    });
    
    // Inicializar vista previa
    updatePreview();
    
    console.log('Vista de creación de álbum inicializada');
});

// Función para remover imagen seleccionada
function removeSelectedImage() {
    const imageInput = document.getElementById('image-file-input');
    const imagePreview = document.getElementById('image-preview');
    const coverPlaceholder = document.getElementById('cover-placeholder');
    const uploadPlaceholder = document.getElementById('upload-placeholder');
    const selectedImageDiv = document.getElementById('selected-image');
    
    // Limpiar input
    imageInput.value = '';
    
    // Restaurar vista previa grande
    imagePreview.style.display = 'none';
    coverPlaceholder.querySelector('i').style.display = 'block';
    
    // Restaurar área de upload
    uploadPlaceholder.style.display = 'block';
    selectedImageDiv.style.display = 'none';
}
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}