    }

    .info-icon {
        background: linear-gradient(135deg, #c8102e, #a30d25);
        color: #ffffff;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 1.2rem;
        box-shadow: 0 4px 15px rgba(200, 16, 46, 0.3);
    }

    .info-content h4 {
        color: var(--us-ink);
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    .info-content p {
        color: var(--us-ink-soft);
        font-size: 0.9rem;
        line-height: 1.4;
        margin: 0;
    }

    .form-right {
        display: flex;
