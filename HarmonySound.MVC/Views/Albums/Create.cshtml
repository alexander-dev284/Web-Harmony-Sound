    .remove-image-btn:hover {
        background: #a30d25;
        transform: scale(1.1);
    }

    /* Vista previa en tiempo real */
    .live-preview {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    .preview-section-title {
        color: var(--us-ink);
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
