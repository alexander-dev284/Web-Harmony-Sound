    .mini-album-card {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        padding: 1rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        transition: all 0.3s ease;
    }

    .mini-album-card:hover {
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(200, 16, 46, 0.3);
