    .create-subtitle {
        color: var(--us-ink-soft);
        font-size: 1.1rem;
        margin-bottom: 0;
    }

    .create-content {
        background: linear-gradient(135deg, var(--us-surface), var(--us-surface-alt));
        border-radius: 16px;
        padding: 2rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    }

    .create-form {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .form-section {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        align-items: start;
    }

    .form-left {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .album-preview {
        background: linear-gradient(135deg, rgba(200, 16, 46, 0.1), rgba(163, 13, 37, 0.05));
        border: 1px solid rgba(200, 16, 46, 0.3);
        border-radius: 12px;
        padding: 2rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .album-preview::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: linear-gradient(45deg, transparent, rgba(200, 16, 46, 0.1), transparent);
        animation: shimmer 3s infinite;
    }

    @@keyframes shimmer {
        0% {
            transform: translateX(-100%) translateY(-100%) rotate(45deg);
        }
        100% {
            transform: translateX(100%) translateY(100%) rotate(45deg);
        }
    }

    .preview-cover {
        width: 200px;
        height: 200px;
        margin: 0 auto 1.5rem;
        position: relative;
        z-index: 2;
    }

    .cover-placeholder {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, var(--us-surface-2), var(--us-border));
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
        color: #c8102e;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .cover-placeholder::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(200, 16, 46, 0.3), transparent);
        animation: slide 2s infinite;
    }

    @@keyframes slide {
        0% {
            left: -100%;
        }
        100% {
            left: 100%;
        }
    }

    .cover-placeholder:hover {
        transform: scale(1.05) rotate(2deg);
        box-shadow: 0 12px 40px rgba(200, 16, 46, 0.2);
    }

    .preview-info {
        text-align: center;
        position: relative;
