@model HarmonySound.API.DTOs.CreateAlbumDto

@{
    ViewData["Title"] = "Crear Nuevo Álbum";
}

<div class="create-album-container">
    <!-- Header con navegación -->
    <div class="create-header">
        <div class="navigation-bar">
            <a href="@Url.Action("Index", "Albums")" class="btn-back">
                <i class="fas fa-arrow-left me-2"></i>
                Volver a Álbumes
            </a>
        </div>

        <h1 class="create-title">
            <i class="fas fa-plus-circle me-3"></i>
            Crear Nuevo Álbum
        </h1>
        <p class="create-subtitle">Crea un álbum para organizar tus canciones</p>
    </div>

    <div class="create-content">
        <!-- Agregar enctype para archivos -->
        <form asp-action="Create" method="post" class="create-form" id="albumCreateForm" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            
            <!-- Sección principal del formulario -->
            <div class="form-section">
                <div class="form-left">
                    <!-- Vista previa del álbum -->
                    <div class="album-preview">
                        <div class="preview-cover">
                            <div class="cover-placeholder" id="cover-placeholder">
                                <i class="fas fa-compact-disc"></i>
                                <!-- Vista previa de imagen -->
                                <img id="image-preview" style="display: none; width: 100%; height: 100%; object-fit: cover; border-radius: 12px;" />
                            </div>
                            <!--  Botón para cambiar imagen -->
                            <div class="image-upload-overlay">
                                <label for="image-file-input" class="image-upload-btn">
                                    <i class="fas fa-camera"></i>
                                    <span>Elegir imagen</span>
                                </label>
                                <input type="file" id="image-file-input" name="imageFile" accept="image/*" style="display: none;" />
                            </div>
                        </div>
                        
                        <div class="preview-info">
                            <h3 class="preview-title" id="preview-title">Álbum sin título</h3>
                            <p class="preview-artist">Mi nuevo álbum</p>
                            <div class="preview-metadata">
                                <span class="preview-type">
                                    <i class="fas fa-compact-disc me-1"></i>
                                    Álbum
                                </span>
                                <span class="preview-year">@DateTime.Now.Year</span>
                            </div>
                        </div>
                    </div>

                    <!-- Información adicional -->
                    <div class="creation-info">
                        <div class="info-card">
                            <div class="info-icon">
                                <i class="fas fa-lightbulb"></i>
                            </div>
                            <div class="info-content">
                                <h4>Consejo</h4>
                                <p>Después de crear el álbum, podrás agregar canciones desde la sección de edición.</p>
                            </div>
                        </div>

                        <div class="info-card">
                            <div class="info-icon">
                                <i class="fas fa-image"></i>
                            </div>
                            <div class="info-content">
                                <h4>Imagen del Álbum</h4>
                                <p>Sube una imagen que represente tu álbum. Formatos soportados: JPG, PNG, GIF, WEBP (máx. 5MB).</p>
                            </div>
                        </div>

                        <div class="info-card">
                            <div class="info-icon">
                                <i class="fas fa-music"></i>
                            </div>
                            <div class="info-content">
                                <h4>Organización</h4>
                                <p>Los álbumes te ayudan a agrupar canciones relacionadas y ofrecen una mejor experiencia a tus oyentes.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-right">
                    <div class="form-container">
                        <h3 class="form-title">
                            <i class="fas fa-edit me-2"></i>
                            Información del Álbum
                        </h3>

                        <!-- Mostrar errores de validación -->
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <i class="fas fa-exclamation-circle me-2"></i>
                                <strong>Error:</strong> Por favor corrige los siguientes problemas:
                                <ul class="error-list">
                                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                </ul>
                            </div>
                        }

                        <div class="form-group">
                            <label asp-for="Title" class="form-label">
                                <i class="fas fa-compact-disc me-2"></i>
                                Nombre del Álbum
                            </label>
                            <input asp-for="Title" 
                                   class="form-control" 
                                   maxlength="20" 
                                   required 
                                   placeholder="Ingresa el nombre de tu álbum"
                                   id="album-title-input" />
                            <span asp-validation-for="Title" class="validation-error"></span>
                            <small class="form-text">Máximo 20 caracteres. Elige un nombre memorable y descriptivo.</small>
                        </div>

                        <!-- Contador de caracteres -->
                        <div class="character-counter">
                            <span id="char-count">0</span> / 20 caracteres
                        </div>

                        <!-- Sección de imagen -->
                        <div class="form-group">
                            <label class="form-label">
                                <i class="fas fa-image me-2"></i>
                                Imagen del Álbum (Opcional)
                            </label>
                            <div class="image-upload-area">
                                <div class="upload-placeholder" id="upload-placeholder">
                                    <i class="fas fa-cloud-upload-alt"></i>
                                    <p>Haz clic para seleccionar una imagen o arrastra aquí</p>
                                    <small>JPG, PNG, GIF, WEBP - Máximo 5MB</small>
                                </div>
                                <div class="selected-image" id="selected-image" style="display: none;">
                                    <img id="selected-image-preview" />
                                    <button type="button" class="remove-image-btn" onclick="removeSelectedImage()">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Vista previa en tiempo real -->
                        <div class="live-preview">
                            <h4 class="preview-section-title">Vista Previa</h4>
                            <div class="mini-album-card">
                                <div class="mini-cover">
                                    <i class="fas fa-compact-disc"></i>
                                </div>
                                <div class="mini-info">
                                    <div class="mini-title" id="mini-preview-title">Álbum sin título</div>
                                    <div class="mini-artist">Mi álbum</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Acciones del formulario -->
            <div class="form-actions">
                <button type="submit" class="btn-create" id="create-btn">
                    <i class="fas fa-plus me-2"></i>
                    Crear Álbum
                </button>
                <a asp-action="Index" class="btn-cancel">
                    <i class="fas fa-times me-2"></i>
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

<style>
    .container {
        max-width: none !important;
        padding: 0 !important;
