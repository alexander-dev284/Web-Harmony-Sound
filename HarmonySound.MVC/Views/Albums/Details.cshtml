<script>
window.harmonyConfig = { urls: {}, userId: '' };
let albumIdToDelete = null;
// Variables globales para el menú de canciones
let currentOpenMenu = null;
let albumIdForRemoval = null;
let trackIdForRemoval = null;

// Función para mostrar/ocultar menú de canción
function toggleTrackMenu(trackId) {
    const menu = document.getElementById(`trackMenu-${trackId}`);
    
    // Cerrar menú abierto actual
    if (currentOpenMenu && currentOpenMenu !== menu) {
        currentOpenMenu.classList.remove('show');
    }
    
    // Toggle del menú actual
    if (menu.classList.contains('show')) {
        menu.classList.remove('show');
        currentOpenMenu = null;
    } else {
        menu.classList.add('show');
        currentOpenMenu = menu;
    }
}

// Función para eliminar canción del álbum
function removeTrackFromAlbum(albumId, trackId, trackTitle) {
    albumIdForRemoval = albumId;
    trackIdForRemoval = trackId;
    
    document.getElementById('trackToRemove').textContent = trackTitle;
    document.getElementById('removeTrackModal').classList.remove('d-none');
    
    // Cerrar menú desplegable
    if (currentOpenMenu) {
        currentOpenMenu.classList.remove('show');
        currentOpenMenu = null;
    }
}

// Ocultar modal de eliminar canción
function hideRemoveTrackModal() {
    document.getElementById('removeTrackModal').classList.add('d-none');
    albumIdForRemoval = null;
    trackIdForRemoval = null;
}

// Confirmar eliminación de canción
function confirmRemoveTrack() {
    if (albumIdForRemoval && trackIdForRemoval) {
        document.getElementById('albumIdForTrackRemoval').value = albumIdForRemoval;
        document.getElementById('trackIdToRemove').value = trackIdForRemoval;
        document.getElementById('removeTrackForm').submit();
    }
}

// Cerrar modal de álbum al hacer click fuera
document.addEventListener('click', function(e) {
    const albumModal = document.getElementById('deleteAlbumModal');
    if (e.target === albumModal) {
        hideDeleteAlbumModal();
    }
});

// Cerrar modal de álbum con Escape
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
        hideDeleteAlbumModal();
        hideRemoveTrackModal();
    }
});
    function showDeleteAlbumModal(albumId, albumTitle) {
        albumIdToDelete = albumId;
        document.getElementById('albumToDeleteDetails').textContent = albumTitle;
        document.getElementById('albumIdToDeleteDetails').value = albumId;
        document.getElementById('deleteAlbumModal').classList.remove('d-none');
    }

    function hideDeleteAlbumModal() {
        document.getElementById('deleteAlbumModal').classList.add('d-none');
        albumIdToDelete = null;
    }

    function confirmDeleteAlbum() {
        if (albumIdToDelete) {
            document.getElementById('deleteAlbumForm').submit();
        }
    }
</script>
